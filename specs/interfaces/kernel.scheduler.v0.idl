idl_version: 1
kind: service
namespace: kernel.scheduler.v0
service: AscensionSchedulerService
summary: Method A/B/C ascension stage machine and substrate failover contract for the reference runtime.
imports:
  ascension_plan: ../schemas/ascension_plan.schema
  schedule_handle: ../schemas/schedule_handle.schema
operations:
  schedule:
    summary: Validate an ascension plan, bind its governance artifact bundle, and open the first stage with append-only continuity evidence.
    input:
      schema_ref: ascension_plan
    output:
      schema_ref: schedule_handle
    guarantees:
      - governance_artifact_digest must match the bound governance_artifacts bundle before scheduling starts
      - witness_refs must contain at least two third-party witnesses for every scheduled plan
  advance:
    summary: Complete the active stage and open the next stage in the fixed Method A/B/C reference blueprint.
    input:
      inline_schema:
        type: object
        required:
          - handle_id
          - stage_id
        properties:
          handle_id:
            type: string
          stage_id:
            type: string
    output:
      inline_schema:
        type: object
        required:
          - handle_id
          - plan_ref
          - completed_stage
          - status
          - continuity_event_refs
          - triggered_rollback
        properties:
          handle_id:
            type: string
          plan_ref:
            type: string
          completed_stage:
            type: string
          next_stage:
            type:
              - string
              - "null"
          status:
            type: string
          continuity_event_refs:
            type: array
            minItems: 1
            items:
              type: string
          triggered_rollback:
            type: boolean
  pause:
    summary: Pause the current stage without losing the active rollback target.
    input:
      inline_schema:
        type: object
        required:
          - handle_id
          - reason
        properties:
          handle_id:
            type: string
          reason:
            type: string
    output:
      schema_ref: schedule_handle
  resume:
    summary: Resume a paused schedule at the current stage.
    input:
      inline_schema:
        type: object
        required:
          - handle_id
        properties:
          handle_id:
            type: string
    output:
      schema_ref: schedule_handle
  rollback:
    summary: Roll back to an earlier stage while preserving history and continuity evidence.
    input:
      inline_schema:
        type: object
        required:
          - handle_id
          - to_stage_id
          - reason
        properties:
          handle_id:
            type: string
          to_stage_id:
            type: string
          reason:
            type: string
    output:
      schema_ref: schedule_handle
  enforce_timeout:
    summary: Detect a stage timeout and automatically roll back or fail according to the active stage policy.
    input:
      inline_schema:
        type: object
        required:
          - handle_id
          - elapsed_ms
        properties:
          handle_id:
            type: string
          elapsed_ms:
            type: integer
            minimum: 1
    output:
      inline_schema:
        type: object
        required:
          - handle_id
          - plan_ref
          - timed_out_stage
          - elapsed_ms
          - timeout_ms
          - action
          - status
          - continuity_event_refs
        properties:
          handle_id:
            type: string
          plan_ref:
            type: string
          timed_out_stage:
            type: string
          elapsed_ms:
            type: integer
          timeout_ms:
            type: integer
          action:
            type: string
            enum:
              - rollback
              - fail
          rollback_target:
            type:
              - string
              - "null"
          status:
            type: string
          continuity_event_refs:
            type: array
            minItems: 1
            items:
              type: string
  handle_substrate_signal:
    summary: Pause, roll back, or fail-closed one schedule in response to a SubstrateBroker signal.
    input:
      inline_schema:
        type: object
        required:
          - handle_id
          - severity
          - source_substrate
          - reason
        properties:
          handle_id:
            type: string
          severity:
            type: string
            enum:
              - watch
              - degraded
              - critical
          source_substrate:
            type: string
          reason:
            type: string
    output:
      inline_schema:
        type: object
        required:
          - handle_id
          - plan_ref
          - stage_id
          - severity
          - source_substrate
          - action
          - status
          - continuity_event_refs
        properties:
          handle_id:
            type: string
          plan_ref:
            type: string
          stage_id:
            type: string
          severity:
            type: string
          source_substrate:
            type: string
          action:
            type: string
            enum:
              - pause
              - rollback
              - fail
          rollback_target:
            type:
              - string
              - "null"
          status:
            type: string
          continuity_event_refs:
            type: array
            minItems: 1
            items:
              type: string
  cancel:
    summary: Cancel the current schedule and close the handle before external termination orchestration.
    input:
      inline_schema:
        type: object
        required:
          - handle_id
          - reason
        properties:
          handle_id:
            type: string
          reason:
            type: string
    output:
      schema_ref: schedule_handle
  observe:
    summary: Return the latest mutable handle state for one ascension schedule.
    input:
      inline_schema:
        type: object
        required:
          - handle_id
        properties:
          handle_id:
            type: string
    output:
      schema_ref: schedule_handle
compatibility:
  stability: bootstrap
  notes:
    - Method A/B/C stage blueprints are fixed in the reference runtime and reject custom reordering.
    - Timeout and substrate-signal handling always append continuity evidence before exposing completed state.
    - Clinical/legal attestation authenticity stays external to this repo, but every plan and handle must carry stable artifact refs and a bundle digest.
events:
  - name: ascension.scheduler.enter
    payload:
      schema_ref: schedule_handle
  - name: ascension.scheduler.rollback
    payload:
      schema_ref: schedule_handle
