idl_version: 1
kind: service
namespace: kernel.scheduler.v0
service: AscensionSchedulerService
summary: Method A/B/C ascension stage machine and substrate failover contract for the reference runtime.
imports:
  ascension_plan: ../schemas/ascension_plan.schema
  schedule_handle: ../schemas/schedule_handle.schema
  scheduler_method_b_handoff_receipt: ../schemas/scheduler_method_b_handoff_receipt.schema
  governance_artifact_sync: ../schemas/governance_artifact_sync.schema
  governance_verifier_roster: ../schemas/governance_verifier_roster.schema
  governance_verifier_connectivity_receipt: ../schemas/governance_verifier_connectivity_receipt.schema
operations:
  schedule:
    summary: Validate an ascension plan, bind its governance artifact bundle, and open the first stage with append-only continuity evidence.
    input:
      schema_ref: ascension_plan
    output:
      schema_ref: schedule_handle
    guarantees:
      - governance_artifact_digest must match the bound governance_artifacts bundle before scheduling starts
      - witness_refs must contain at least two third-party witnesses for every scheduled plan
  advance:
    summary: Complete the active stage and open the next stage in the fixed Method A/B/C reference blueprint.
    input:
      inline_schema:
        type: object
        required:
          - handle_id
          - stage_id
        properties:
          handle_id:
            type: string
          stage_id:
            type: string
    output:
      inline_schema:
        type: object
        required:
          - handle_id
          - plan_ref
          - completed_stage
          - status
          - continuity_event_refs
          - triggered_rollback
        properties:
          handle_id:
            type: string
          plan_ref:
            type: string
          completed_stage:
            type: string
          next_stage:
            type:
              - string
              - "null"
          status:
            type: string
          continuity_event_refs:
            type: array
            minItems: 1
            items:
              type: string
          triggered_rollback:
            type: boolean
  pause:
    summary: Pause the current stage without losing the active rollback target.
    input:
      inline_schema:
        type: object
        required:
          - handle_id
          - reason
        properties:
          handle_id:
            type: string
          reason:
            type: string
    output:
      schema_ref: schedule_handle
  resume:
    summary: Resume a paused schedule at the current stage.
    input:
      inline_schema:
        type: object
        required:
          - handle_id
        properties:
          handle_id:
            type: string
    output:
      schema_ref: schedule_handle
  rollback:
    summary: Roll back to an earlier stage while preserving history and continuity evidence.
    input:
      inline_schema:
        type: object
        required:
          - handle_id
          - to_stage_id
          - reason
        properties:
          handle_id:
            type: string
          to_stage_id:
            type: string
          reason:
            type: string
    output:
      schema_ref: schedule_handle
  enforce_timeout:
    summary: Detect a stage timeout and automatically roll back or fail according to the active stage policy.
    input:
      inline_schema:
        type: object
        required:
          - handle_id
          - elapsed_ms
        properties:
          handle_id:
            type: string
          elapsed_ms:
            type: integer
            minimum: 1
    output:
      inline_schema:
        type: object
        required:
          - handle_id
          - plan_ref
          - timed_out_stage
          - elapsed_ms
          - timeout_ms
          - action
          - status
          - continuity_event_refs
        properties:
          handle_id:
            type: string
          plan_ref:
            type: string
          timed_out_stage:
            type: string
          elapsed_ms:
            type: integer
          timeout_ms:
            type: integer
          action:
            type: string
            enum:
              - rollback
              - fail
          rollback_target:
            type:
              - string
              - "null"
          status:
            type: string
          continuity_event_refs:
            type: array
            minItems: 1
            items:
              type: string
  handle_substrate_signal:
    summary: Pause, roll back, or fail-closed one schedule in response to a SubstrateBroker signal.
    input:
      inline_schema:
        type: object
        required:
          - handle_id
          - severity
          - source_substrate
          - reason
        properties:
          handle_id:
            type: string
          severity:
            type: string
            enum:
              - watch
              - degraded
              - critical
          source_substrate:
            type: string
          reason:
            type: string
    output:
      inline_schema:
        type: object
        required:
          - handle_id
          - plan_ref
          - stage_id
          - severity
          - source_substrate
          - action
          - status
          - continuity_event_refs
        properties:
          handle_id:
            type: string
          plan_ref:
            type: string
          stage_id:
            type: string
          severity:
            type: string
          source_substrate:
            type: string
          action:
            type: string
            enum:
              - pause
              - rollback
              - fail
          rollback_target:
            type:
              - string
              - "null"
          status:
            type: string
          continuity_event_refs:
            type: array
            minItems: 1
            items:
              type: string
  prepare_method_b_handoff:
    summary: Bind one Method B cross-host broker handoff proof bundle to dual-channel-review before authority-handoff can open.
    input:
      inline_schema:
        type: object
        required:
          - handle_id
          - broker_signal
          - standby_probe
          - attestation_chain
          - dual_allocation_window
          - attestation_stream
        properties:
          handle_id:
            type: string
          broker_signal:
            type: object
          standby_probe:
            type: object
          attestation_chain:
            type: object
          dual_allocation_window:
            type: object
          attestation_stream:
            type: object
    output:
      schema_ref: scheduler_method_b_handoff_receipt
  confirm_method_b_handoff:
    summary: Confirm one prepared Method B broker handoff with hot-handoff migration and dual-allocation cleanup before bio-retirement can open.
    input:
      inline_schema:
        type: object
        required:
          - handle_id
          - migration
          - closed_dual_allocation_window
        properties:
          handle_id:
            type: string
          migration:
            type: object
          closed_dual_allocation_window:
            type: object
    output:
      schema_ref: scheduler_method_b_handoff_receipt
  cancel:
    summary: Cancel the current schedule and close the handle before external termination orchestration.
    input:
      inline_schema:
        type: object
        required:
          - handle_id
          - reason
        properties:
          handle_id:
            type: string
          reason:
            type: string
    output:
      schema_ref: schedule_handle
  observe:
    summary: Return the latest mutable handle state for one ascension schedule.
    input:
      inline_schema:
        type: object
        required:
          - handle_id
        properties:
          handle_id:
            type: string
    output:
      schema_ref: schedule_handle
  probe_live_verifier_roster:
    summary: Fetch one external verifier roster over bounded live HTTP JSON transport and attach a connectivity receipt before sync_governance_artifacts runs.
    input:
      inline_schema:
        type: object
        required:
          - handle_id
          - verifier_endpoint
        properties:
          handle_id:
            type: string
          verifier_endpoint:
            type: string
            pattern: "^https?://"
          request_timeout_ms:
            type: integer
            minimum: 1
    output:
      schema_ref: governance_verifier_roster
  sync_governance_artifacts:
    summary: Record one external proof sync snapshot and pause or fail-closed when artifacts are stale, verifier roots overlap, or verifier trust is revoked.
    input:
      inline_schema:
        type: object
        required:
          - handle_id
          - checked_at
          - artifacts
          - verifier_roster
        properties:
          handle_id:
            type: string
          checked_at:
            type: string
            format: date-time
          artifacts:
            type: array
            minItems: 5
            items:
              type: object
              required:
                - artifact_key
                - status
                - proof_digest
                - external_sync_ref
              properties:
                artifact_key:
                  type: string
                  enum:
                    - self_consent_ref
                    - ethics_attestation_ref
                    - council_attestation_ref
                    - legal_attestation_ref
                    - artifact_bundle_ref
                status:
                  type: string
                  enum:
                    - current
                    - stale
                    - revoked
                proof_digest:
                  type: string
                  pattern: "^[a-f0-9]{64}$"
                external_sync_ref:
                  type: string
                  pattern: "^sync://"
          verifier_roster:
            schema_ref: governance_verifier_roster
    output:
      inline_schema:
        type: object
        required:
          - handle_id
          - plan_ref
          - bundle_status
          - verifier_rotation_state
          - action
          - status
          - continuity_event_refs
          - handle
        properties:
          handle_id:
            type: string
          plan_ref:
            type: string
          bundle_status:
            type: string
            enum:
              - current
              - refresh-required
              - revoked
          verifier_rotation_state:
            type: string
            enum:
              - stable
              - overlap-required
              - rotated
              - revoked
          action:
            type: string
            enum:
              - accept
              - pause
              - fail
          status:
            type: string
          continuity_event_refs:
            type: array
            minItems: 1
            items:
              type: string
          handle:
            schema_ref: schedule_handle
compatibility:
  stability: bootstrap
  notes:
    - Method A/B/C stage blueprints are fixed in the reference runtime and reject custom reordering.
    - Timeout and substrate-signal handling always append continuity evidence before exposing completed state.
    - Clinical/legal attestation authenticity stays external to this repo, but every plan and handle must carry stable artifact refs and a bundle digest.
    - Protected handoff stages require one current governance artifact sync snapshot before they can open.
    - Method B authority-handoff requires one prepared broker handoff receipt, and bio-retirement requires the same receipt to be confirmed with hot-handoff migration plus cleanup release.
    - probe_live_verifier_roster materializes a bounded connectivity receipt and stores only endpoint, digest, latency, and roster summary fields.
    - Stale snapshots pause the active schedule, verifier overlap snapshots pause until cutover, and revoked snapshots fail-closed before destructive or authority-bearing handoff.
events:
  - name: ascension.scheduler.enter
    payload:
      schema_ref: schedule_handle
  - name: ascension.scheduler.rollback
    payload:
      schema_ref: schedule_handle
  - name: ascension.scheduler.sync
    payload:
      schema_ref: governance_artifact_sync
