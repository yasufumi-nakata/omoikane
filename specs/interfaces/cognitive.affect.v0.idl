idl_version: 1
kind: service
namespace: cognitive.affect.v0
service: AffectService
summary: Deterministic affect failover and continuity smoothing contract for the L3 reference runtime.
imports:
  affect_state: ../schemas/affect_state.schema
  affect_transition: ../schemas/affect_transition.schema
operations:
  regulate:
    summary: Produce one affect state from a qualia-derived tick and bounded memory cues.
    input:
      inline_schema:
        type: object
        required:
          - tick_id
          - summary
          - valence
          - arousal
          - clarity
          - self_awareness
          - lucidity
          - memory_cues
          - allow_artificial_dampening
        properties:
          tick_id:
            type: integer
            minimum: 0
          summary:
            type: string
          valence:
            type: number
            minimum: -1.0
            maximum: 1.0
          arousal:
            type: number
            minimum: 0.0
            maximum: 1.0
          clarity:
            type: number
            minimum: 0.0
            maximum: 1.0
          self_awareness:
            type: number
            minimum: 0.0
            maximum: 1.0
          lucidity:
            type: number
            minimum: 0.0
            maximum: 1.0
          memory_cues:
            type: array
            minItems: 1
            items:
              type: object
              required:
                - cue_id
                - valence_bias
                - arousal_bias
              properties:
                cue_id:
                  type: string
                valence_bias:
                  type: number
                  minimum: -1.0
                  maximum: 1.0
                arousal_bias:
                  type: number
                  minimum: -1.0
                  maximum: 1.0
          allow_artificial_dampening:
            type: boolean
    output:
      schema_ref: affect_state
    invariants:
      - no artificial dampening may occur unless allow_artificial_dampening is true
      - valence and arousal transitions must be bounded by the fixed smoothing deltas
      - fallback may switch at most once per request in the reference runtime
  validate_state:
    summary: Validate one affect state snapshot against the fixed failover policy.
    input:
      inline_schema:
        type: object
        required:
          - snapshot
        properties:
          snapshot:
            schema_ref: affect_state
    output:
      inline_schema:
        type: object
        required:
          - ok
          - selected_backend
          - recommended_guard
          - continuity_guard_preserved
          - errors
        properties:
          ok:
            type: boolean
          selected_backend:
            type: string
          recommended_guard:
            type: string
          continuity_guard_preserved:
            type: boolean
          errors:
            type: array
            items:
              type: string
  validate_transition:
    summary: Validate one ledger-safe affect transition record.
    input:
      inline_schema:
        type: object
        required:
          - transition
        properties:
          transition:
            schema_ref: affect_transition
    output:
      inline_schema:
        type: object
        required:
          - ok
          - selected_backend
          - recommended_guard
          - errors
        properties:
          ok:
            type: boolean
          selected_backend:
            type: string
          recommended_guard:
            type: string
          errors:
            type: array
            items:
              type: string
events:
  - name: cognitive.affect.failover
    payload:
      schema_ref: affect_transition
