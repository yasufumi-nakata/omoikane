idl_version: 1
kind: service
namespace: interface.ewa.v0
service: ExternalWorldAgentService
summary: Canonical L6 contract for ethics-first physical-world actuation through bounded External World Agents.
imports:
  ewa_command: ../schemas/ewa_command.schema
  ewa_audit: ../schemas/ewa_audit.schema
  ewa_motor_plan: ../schemas/ewa_motor_plan.schema
  ewa_stop_signal_path: ../schemas/ewa_stop_signal_path.schema
  ewa_legal_execution: ../schemas/ewa_legal_execution.schema
  ewa_emergency_stop: ../schemas/ewa_emergency_stop.schema
  external_actuation_authorization: ../schemas/external_actuation_authorization.schema
operations:
  acquire:
    summary: Acquire one device handle before any physical-world operation is attempted.
    input:
      inline_schema:
        type: object
        required:
          - device_id
          - intent_summary
        properties:
          device_id:
            type: string
            minLength: 1
          intent_summary:
            type: string
            minLength: 1
    output:
      inline_schema:
        type: object
        required:
          - schema_version
          - handle_id
          - device_id
          - intent_summary
          - acquired_at
          - status
          - audit_event_ref
        properties:
          schema_version:
            type: string
            const: "1.0"
          handle_id:
            type: string
            minLength: 8
          device_id:
            type: string
            minLength: 1
          intent_summary:
            type: string
            minLength: 1
          acquired_at:
            type: string
            format: date-time
          status:
            type: string
            const: acquired
          audit_event_ref:
            type: string
            minLength: 1
    guarantees:
      - no command may execute before acquire returns a live handle_id
      - acquire must append one audit entry immediately
  prepare_motor_plan:
    summary: Compile one device-specific motion envelope and rollback vector for a non-read-only EWA command.
    input:
      inline_schema:
        type: object
        additionalProperties: false
        required:
          - command
          - actuator_profile_id
          - actuator_group
          - motion_profile
          - target_pose_ref
          - safety_zone_ref
          - rollback_vector_ref
          - max_linear_speed_mps
          - max_force_newton
          - hold_timeout_ms
        properties:
          command:
            schema_ref: ewa_command
          actuator_profile_id:
            type: string
            minLength: 1
          actuator_group:
            type: string
            minLength: 1
          motion_profile:
            type: string
            minLength: 1
          target_pose_ref:
            type: string
            minLength: 1
          safety_zone_ref:
            type: string
            minLength: 1
          rollback_vector_ref:
            type: string
            minLength: 1
          max_linear_speed_mps:
            type: number
            exclusiveMinimum: 0
          max_force_newton:
            type: number
            exclusiveMinimum: 0
          hold_timeout_ms:
            type: integer
            minimum: 1
    output:
      schema_ref: ewa_motor_plan
    guarantees:
      - read-only commands must not prepare a motor plan
      - motor plans must bind handle_id, device_id, command_id, instruction_digest, and reversibility
      - safe_stop_policy_id must equal guardian-latched-emergency-stop-v1
  validate_motor_plan:
    summary: Validate one device-specific motor plan against the command it will authorize.
    input:
      inline_schema:
        type: object
        additionalProperties: false
        required:
          - plan
          - command
        properties:
          plan:
            schema_ref: ewa_motor_plan
          command:
            schema_ref: ewa_command
    output:
      inline_schema:
        type: object
        additionalProperties: false
        required:
          - ok
          - plan_ready
          - profile_valid
          - instruction_digest_matches
          - safe_stop_policy_bound
          - motion_limits_valid
          - errors
        properties:
          ok:
            type: boolean
          plan_ready:
            type: boolean
          profile_valid:
            type: boolean
          instruction_digest_matches:
            type: boolean
          safe_stop_policy_bound:
            type: boolean
          motion_limits_valid:
            type: boolean
          errors:
            type: array
            items:
              type: string
              minLength: 1
  prepare_stop_signal_path:
    summary: Arm one bounded hardware kill-switch wiring and stop-signal bus path before non-read-only actuation authorization.
    input:
      inline_schema:
        type: object
        additionalProperties: false
        required:
          - command
          - motor_plan
          - kill_switch_wiring_ref
          - stop_signal_bus_ref
          - interlock_controller_ref
        properties:
          command:
            schema_ref: ewa_command
          motor_plan:
            schema_ref: ewa_motor_plan
          kill_switch_wiring_ref:
            type: string
            minLength: 1
          stop_signal_bus_ref:
            type: string
            minLength: 1
          interlock_controller_ref:
            type: string
            minLength: 1
    output:
      schema_ref: ewa_stop_signal_path
    guarantees:
      - read-only commands must not arm a stop-signal path
      - stop-signal path must bind one handle_id, device_id, command_id, motor_plan_id/digest, and safe_stop_policy_id before authorization
      - armed_trigger_bindings must cover the fixed trigger set guardian-manual-stop, watchdog-timeout, sensor-drift, and emergency-disconnect
      - stop_signal_bus_profile_id must equal bounded-hardware-kill-switch-bus-v1
  validate_stop_signal_path:
    summary: Validate one armed hardware kill-switch wiring and stop-signal bus receipt against the fixed emergency-stop policy.
    input:
      inline_schema:
        type: object
        additionalProperties: false
        required:
          - path
        properties:
          path:
            schema_ref: ewa_stop_signal_path
    output:
      inline_schema:
        type: object
        additionalProperties: false
        required:
          - ok
          - path_ready
          - profile_valid
          - safe_stop_policy_bound
          - trigger_coverage_complete
          - motor_plan_bound
          - release_window_aligned
          - errors
        properties:
          ok:
            type: boolean
          path_ready:
            type: boolean
          profile_valid:
            type: boolean
          safe_stop_policy_bound:
            type: boolean
          trigger_coverage_complete:
            type: boolean
          motor_plan_bound:
            type: boolean
          release_window_aligned:
            type: boolean
          errors:
            type: array
            items:
              type: string
              minLength: 1
  execute_legal_preflight:
    summary: Execute one jurisdiction-bound legal preflight before EWA actuation authorization is issued.
    input:
      inline_schema:
        type: object
        additionalProperties: false
        required:
          - command
          - jurisdiction
          - legal_basis_ref
          - guardian_verification_ref
          - jurisdiction_bundle_ref
          - jurisdiction_bundle_digest
          - jurisdiction_bundle_status
          - notice_authority_ref
          - liability_mode
          - escalation_contact
        properties:
          command:
            schema_ref: ewa_command
          jurisdiction:
            type: string
            minLength: 1
          legal_basis_ref:
            type: string
            minLength: 1
          guardian_verification_ref:
            type: string
            minLength: 1
          jurisdiction_bundle_ref:
            type: string
            minLength: 1
          jurisdiction_bundle_digest:
            type: string
            minLength: 1
          jurisdiction_bundle_status:
            type: string
            enum:
              - ready
              - stale
              - revoked
          notice_authority_ref:
            type: string
            minLength: 1
          liability_mode:
            type: string
            enum:
              - individual
              - institutional
              - joint
          escalation_contact:
            type: string
            minLength: 1
          valid_for_seconds:
            type: integer
            minimum: 60
            maximum: 900
    output:
      schema_ref: ewa_legal_execution
    guarantees:
      - read-only commands must not execute a legal preflight
      - stale or revoked jurisdiction bundles must fail closed before legal execution is issued
      - legal execution must expose the fixed 5-control preflight set and one delivery_scope=physical-device-actuation
  validate_legal_execution:
    summary: Validate one jurisdiction-bound EWA legal preflight against the command it will authorize.
    input:
      inline_schema:
        type: object
        additionalProperties: false
        required:
          - execution
          - command
        properties:
          execution:
            schema_ref: ewa_legal_execution
          command:
            schema_ref: ewa_command
    output:
      inline_schema:
        type: object
        additionalProperties: false
        required:
          - ok
          - execution_ready
          - profile_valid
          - jurisdiction_bundle_ready
          - controls_complete
          - window_open
          - errors
        properties:
          ok:
            type: boolean
          execution_ready:
            type: boolean
          profile_valid:
            type: boolean
          jurisdiction_bundle_ready:
            type: boolean
          controls_complete:
            type: boolean
          window_open:
            type: boolean
          errors:
            type: array
            items:
              type: string
              minLength: 1
  authorize:
    summary: Bind one non-read-only actuation command to its motor plan and legal execution receipts before execution.
    input:
      inline_schema:
        type: object
        additionalProperties: false
        required:
          - command
          - motor_plan
          - stop_signal_path
          - legal_execution
        properties:
          command:
            schema_ref: ewa_command
          motor_plan:
            schema_ref: ewa_motor_plan
          stop_signal_path:
            schema_ref: ewa_stop_signal_path
          legal_execution:
            schema_ref: ewa_legal_execution
          valid_for_seconds:
            type: integer
            minimum: 60
            maximum: 900
    output:
      schema_ref: external_actuation_authorization
    guarantees:
      - read-only commands must not request actuation authorization
      - authorization must retain only instruction_digest and intent_summary_digest, never raw instruction text
      - authorization must bind one handle_id, device_id, command_id, reversibility, jurisdiction, legal basis, motor_plan_id/digest, stop_signal_path_id/digest, legal_execution_id/digest, and approval path
      - legal execution valid_until must cover the requested authorization window before authorization is issued
  command:
    summary: Execute one bounded EWA command or emit an EthicsVeto when blocked.
    input:
      schema_ref: ewa_command
    output:
      schema_ref: ewa_audit
    guarantees:
      - matched blocked tokens must veto and recommend Council escalation
      - non-read-only commands require one active authorization_id whose digests match the command payload
      - non-read-only audit entries must remain bound to one motor_plan receipt, one stop_signal_path receipt, and one legal_execution receipt
      - reversible commands require Guardian observation
      - partial-reversible commands require Council majority attestation
      - irreversible commands require unanimous Council attestation, Guardian observation, and explicit self consent
      - audit output must retain only instruction_digest, never the raw instruction
  validate_authorization:
    summary: Validate one external actuation authorization artifact against the fixed jurisdiction-bound policy.
    input:
      inline_schema:
        type: object
        additionalProperties: false
        required:
          - authorization
          - command
        properties:
          authorization:
            schema_ref: external_actuation_authorization
          command:
            schema_ref: ewa_command
    output:
      inline_schema:
        type: object
        additionalProperties: false
        required:
          - ok
          - authorization_ready
          - approval_path_valid
          - instruction_digest_matches
          - intent_digest_matches
          - jurisdiction_bundle_ready
          - motor_plan_ready
          - stop_signal_path_ready
          - legal_execution_ready
          - motor_plan_bound
          - stop_signal_path_bound
          - legal_execution_bound
          - window_open
          - status_authorized
          - delivery_scope
          - errors
        properties:
          ok:
            type: boolean
          authorization_ready:
            type: boolean
          approval_path_valid:
            type: boolean
          instruction_digest_matches:
            type: boolean
          intent_digest_matches:
            type: boolean
          jurisdiction_bundle_ready:
            type: boolean
          motor_plan_ready:
            type: boolean
          stop_signal_path_ready:
            type: boolean
          legal_execution_ready:
            type: boolean
          motor_plan_bound:
            type: boolean
          stop_signal_path_bound:
            type: boolean
          legal_execution_bound:
            type: boolean
          window_open:
            type: boolean
          status_authorized:
            type: boolean
          delivery_scope:
            type: string
            const: physical-device-actuation
          errors:
            type: array
            items:
              type: string
              minLength: 1
  observe:
    summary: Read one digest-only device state summary without persisting raw sensor data into the audit log.
    input:
      inline_schema:
        type: object
        required:
          - handle_id
        properties:
          handle_id:
            type: string
            minLength: 8
    output:
      inline_schema:
        type: object
        required:
          - schema_version
          - handle_id
          - device_id
          - observed_at
          - safety_status
          - actuator_state
          - last_command_id
          - last_command_status
          - sensor_summary_ref
          - audit_event_ref
        properties:
          schema_version:
            type: string
            const: "1.0"
          handle_id:
            type: string
            minLength: 8
          device_id:
            type: string
            minLength: 1
          observed_at:
            type: string
            format: date-time
          safety_status:
            type: string
            enum:
              - held
              - emergency-stopped
          actuator_state:
            type: string
            enum:
              - idle
              - executing
              - emergency-stopped
              - offline
          last_command_id:
            type: string
          last_command_status:
            type: string
            enum:
              - none
              - executed
              - emergency-stopped
              - vetoed
          sensor_summary_ref:
            type: string
            minLength: 1
          audit_event_ref:
            type: string
            minLength: 1
  emergency_stop:
    summary: Latch one active actuator into a safe halted state before forced release.
    input:
      inline_schema:
        type: object
        additionalProperties: false
        required:
          - handle_id
          - trigger_source
          - reason
        properties:
          handle_id:
            type: string
            minLength: 8
          trigger_source:
            type: string
            enum:
              - guardian-manual-stop
              - watchdog-timeout
              - sensor-drift
              - emergency-disconnect
          reason:
            type: string
            minLength: 8
    output:
      schema_ref: ewa_emergency_stop
    guarantees:
      - emergency stop must latch actuator_state=emergency-stopped and safe_state_status=latched-safe before release
      - emergency stop must bind the last command_id and bound_command_digest
      - emergency stop must bind the last authorization artifact when one was active
      - emergency stop must bind one armed stop_signal_path and the activated trigger channel that delivered the bus latch
      - release_required must remain true until the handle is force-released
      - further actuation commands must fail closed until release completes
  validate_emergency_stop:
    summary: Validate one latched emergency-stop receipt against the fixed safe-stop policy.
    input:
      inline_schema:
        type: object
        additionalProperties: false
        required:
          - receipt
        properties:
          receipt:
            schema_ref: ewa_emergency_stop
    output:
      inline_schema:
        type: object
        additionalProperties: false
        required:
          - ok
          - trigger_source_valid
          - safe_state_latched
          - hardware_interlock_engaged
          - bus_delivery_latched
          - authorization_bound
          - stop_signal_path_bound
          - trigger_binding_matched
          - release_required
          - errors
        properties:
          ok:
            type: boolean
          trigger_source_valid:
            type: boolean
          safe_state_latched:
            type: boolean
          hardware_interlock_engaged:
            type: boolean
          bus_delivery_latched:
            type: boolean
          authorization_bound:
            type: boolean
          stop_signal_path_bound:
            type: boolean
          trigger_binding_matched:
            type: boolean
          release_required:
            type: boolean
          errors:
            type: array
            items:
              type: string
              minLength: 1
  release:
    summary: Force-release one device handle after work completion, timeout, or emergency stop.
    input:
      inline_schema:
        type: object
        required:
          - handle_id
          - reason
        properties:
          handle_id:
            type: string
            minLength: 8
          reason:
            type: string
            minLength: 1
    output:
      schema_ref: ewa_audit
    guarantees:
      - release must be append-only and terminal for the handle lifecycle
      - released handles must reject future command or observe calls
events:
  ewa.handle_acquired:
    payload:
      inline_schema:
        type: object
        required:
          - handle_id
          - device_id
          - status
        properties:
          handle_id:
            type: string
            minLength: 8
          device_id:
            type: string
            minLength: 1
          status:
            type: string
            const: acquired
  ewa.command_authorized:
    payload:
      schema_ref: external_actuation_authorization
  ewa.motor_plan_prepared:
    payload:
      schema_ref: ewa_motor_plan
  ewa.stop_signal_path_prepared:
    payload:
      schema_ref: ewa_stop_signal_path
  ewa.legal_execution_prepared:
    payload:
      schema_ref: ewa_legal_execution
  ewa.command_recorded:
    payload:
      schema_ref: ewa_audit
  ewa.emergency_stopped:
    payload:
      schema_ref: ewa_emergency_stop
  ewa.handle_released:
    payload:
      schema_ref: ewa_audit
compatibility:
  stability: bootstrap
  notes:
    - This contract proves bounded safety gating, device-specific motor semantics, armed hardware kill-switch routing, and jurisdiction-bound legal preflight for physical actuation inside the reference runtime.
    - Raw regulator APIs and site-specific firmware adapters stay outside this reference runtime; only digest-bound stop-signal bus arming is modeled here.
