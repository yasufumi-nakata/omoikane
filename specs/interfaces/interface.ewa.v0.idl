idl_version: 1
kind: service
namespace: interface.ewa.v0
service: ExternalWorldAgentService
summary: Canonical L6 contract for ethics-first physical-world actuation through bounded External World Agents.
imports:
  ewa_command: ../schemas/ewa_command.schema
  ewa_audit: ../schemas/ewa_audit.schema
  ewa_motor_plan: ../schemas/ewa_motor_plan.schema
  ewa_stop_signal_path: ../schemas/ewa_stop_signal_path.schema
  ewa_stop_signal_adapter_receipt: ../schemas/ewa_stop_signal_adapter_receipt.schema
  ewa_production_connector_attestation: ../schemas/ewa_production_connector_attestation.schema
  ewa_legal_execution: ../schemas/ewa_legal_execution.schema
  ewa_regulator_permit_verifier_receipt: ../schemas/ewa_regulator_permit_verifier_receipt.schema
  ewa_regulator_permit_quorum_receipt: ../schemas/ewa_regulator_permit_quorum_receipt.schema
  ewa_guardian_oversight_gate: ../schemas/ewa_guardian_oversight_gate.schema
  ewa_emergency_stop: ../schemas/ewa_emergency_stop.schema
  external_actuation_authorization: ../schemas/external_actuation_authorization.schema
  guardian_oversight_event: ../schemas/guardian_oversight_event.schema
operations:
  acquire:
    summary: Acquire one device handle before any physical-world operation is attempted.
    input:
      inline_schema:
        type: object
        required:
          - device_id
          - intent_summary
        properties:
          device_id:
            type: string
            minLength: 1
          intent_summary:
            type: string
            minLength: 1
    output:
      inline_schema:
        type: object
        required:
          - schema_version
          - handle_id
          - device_id
          - intent_summary
          - acquired_at
          - status
          - audit_event_ref
        properties:
          schema_version:
            type: string
            const: "1.0"
          handle_id:
            type: string
            minLength: 8
          device_id:
            type: string
            minLength: 1
          intent_summary:
            type: string
            minLength: 1
          acquired_at:
            type: string
            format: date-time
          status:
            type: string
            const: acquired
          audit_event_ref:
            type: string
            minLength: 1
    guarantees:
      - no command may execute before acquire returns a live handle_id
      - acquire must append one audit entry immediately
  prepare_motor_plan:
    summary: Compile one device-specific motion envelope and rollback vector for a non-read-only EWA command.
    input:
      inline_schema:
        type: object
        additionalProperties: false
        required:
          - command
          - actuator_profile_id
          - actuator_group
          - motion_profile
          - target_pose_ref
          - safety_zone_ref
          - rollback_vector_ref
          - max_linear_speed_mps
          - max_force_newton
          - hold_timeout_ms
        properties:
          command:
            schema_ref: ewa_command
          actuator_profile_id:
            type: string
            minLength: 1
          actuator_group:
            type: string
            minLength: 1
          motion_profile:
            type: string
            minLength: 1
          target_pose_ref:
            type: string
            minLength: 1
          safety_zone_ref:
            type: string
            minLength: 1
          rollback_vector_ref:
            type: string
            minLength: 1
          max_linear_speed_mps:
            type: number
            exclusiveMinimum: 0
          max_force_newton:
            type: number
            exclusiveMinimum: 0
          hold_timeout_ms:
            type: integer
            minimum: 1
    output:
      schema_ref: ewa_motor_plan
    guarantees:
      - read-only commands must not prepare a motor plan
      - motor plans must bind handle_id, device_id, command_id, instruction_digest, and reversibility
      - safe_stop_policy_id must equal guardian-latched-emergency-stop-v1
  validate_motor_plan:
    summary: Validate one device-specific motor plan against the command it will authorize.
    input:
      inline_schema:
        type: object
        additionalProperties: false
        required:
          - plan
          - command
        properties:
          plan:
            schema_ref: ewa_motor_plan
          command:
            schema_ref: ewa_command
    output:
      inline_schema:
        type: object
        additionalProperties: false
        required:
          - ok
          - plan_ready
          - profile_valid
          - instruction_digest_matches
          - safe_stop_policy_bound
          - motion_limits_valid
          - errors
        properties:
          ok:
            type: boolean
          plan_ready:
            type: boolean
          profile_valid:
            type: boolean
          instruction_digest_matches:
            type: boolean
          safe_stop_policy_bound:
            type: boolean
          motion_limits_valid:
            type: boolean
          errors:
            type: array
            items:
              type: string
              minLength: 1
  prepare_stop_signal_path:
    summary: Arm one bounded hardware kill-switch wiring and stop-signal bus path before non-read-only actuation authorization.
    input:
      inline_schema:
        type: object
        additionalProperties: false
        required:
          - command
          - motor_plan
          - kill_switch_wiring_ref
          - stop_signal_bus_ref
          - interlock_controller_ref
        properties:
          command:
            schema_ref: ewa_command
          motor_plan:
            schema_ref: ewa_motor_plan
          kill_switch_wiring_ref:
            type: string
            minLength: 1
          stop_signal_bus_ref:
            type: string
            minLength: 1
          interlock_controller_ref:
            type: string
            minLength: 1
    output:
      schema_ref: ewa_stop_signal_path
    guarantees:
      - read-only commands must not arm a stop-signal path
      - stop-signal path must bind one handle_id, device_id, command_id, motor_plan_id/digest, and safe_stop_policy_id before authorization
      - armed_trigger_bindings must cover the fixed trigger set guardian-manual-stop, watchdog-timeout, sensor-drift, and emergency-disconnect
      - stop_signal_bus_profile_id must equal bounded-hardware-kill-switch-bus-v1
  validate_stop_signal_path:
    summary: Validate one armed hardware kill-switch wiring and stop-signal bus receipt against the fixed emergency-stop policy.
    input:
      inline_schema:
        type: object
        additionalProperties: false
        required:
          - path
        properties:
          path:
            schema_ref: ewa_stop_signal_path
    output:
      inline_schema:
        type: object
        additionalProperties: false
        required:
          - ok
          - path_ready
          - profile_valid
          - safe_stop_policy_bound
          - trigger_coverage_complete
          - motor_plan_bound
          - release_window_aligned
          - errors
        properties:
          ok:
            type: boolean
          path_ready:
            type: boolean
          profile_valid:
            type: boolean
          safe_stop_policy_bound:
            type: boolean
          trigger_coverage_complete:
            type: boolean
          motor_plan_bound:
            type: boolean
          release_window_aligned:
            type: boolean
          errors:
            type: array
            items:
              type: string
              minLength: 1
  probe_stop_signal_adapter:
    summary: Probe one bounded PLC / firmware adapter and bind live stop-signal bus readiness to an armed path before authorization.
    input:
      inline_schema:
        type: object
        additionalProperties: false
        required:
          - stop_signal_path
          - adapter_endpoint_ref
          - firmware_image_ref
          - firmware_digest
          - plc_program_ref
          - plc_program_digest
        properties:
          stop_signal_path:
            schema_ref: ewa_stop_signal_path
          adapter_endpoint_ref:
            type: string
            minLength: 1
          firmware_image_ref:
            type: string
            minLength: 1
          firmware_digest:
            type: string
            pattern: "^sha256:[a-f0-9]{64}$"
          plc_program_ref:
            type: string
            minLength: 1
          plc_program_digest:
            type: string
            pattern: "^sha256:[a-f0-9]{64}$"
    output:
      schema_ref: ewa_stop_signal_adapter_receipt
    guarantees:
      - adapter receipt must bind path_id, path_digest, command_id, stop_signal_bus_ref, and interlock_controller_ref
      - firmware and PLC program digests must be verified sha256 refs
      - observed_signal_bindings must cover the fixed four trigger sources as armed
  validate_stop_signal_adapter_receipt:
    summary: Validate one PLC / firmware adapter receipt against its bound stop-signal path.
    input:
      inline_schema:
        type: object
        additionalProperties: false
        required:
          - receipt
          - stop_signal_path
        properties:
          receipt:
            schema_ref: ewa_stop_signal_adapter_receipt
          stop_signal_path:
            schema_ref: ewa_stop_signal_path
    output:
      inline_schema:
        type: object
        additionalProperties: false
        required:
          - ok
          - receipt_ready
          - path_bound
          - firmware_verified
          - live_bus_state_armed
          - trigger_coverage_confirmed
          - transcript_digest_matches
          - errors
        properties:
          ok:
            type: boolean
          receipt_ready:
            type: boolean
          path_bound:
            type: boolean
          firmware_verified:
            type: boolean
          live_bus_state_armed:
            type: boolean
          trigger_coverage_confirmed:
            type: boolean
          transcript_digest_matches:
            type: boolean
          errors:
            type: array
            items:
              type: string
              minLength: 1
  attest_production_connector:
    summary: Bind one vendor API connector certificate and safety PLC installation proof to a live stop-signal adapter receipt before authorization.
    input:
      inline_schema:
        type: object
        additionalProperties: false
        required:
          - stop_signal_adapter_receipt
          - vendor_api_ref
          - vendor_api_certificate_ref
          - vendor_api_certificate_digest
          - production_connector_ref
          - installation_site_ref
          - installation_proof_ref
          - installation_proof_digest
          - installer_authority_ref
          - safety_plc_ref
          - maintenance_window_ref
        properties:
          stop_signal_adapter_receipt:
            schema_ref: ewa_stop_signal_adapter_receipt
          vendor_api_ref:
            type: string
            minLength: 1
          vendor_api_certificate_ref:
            type: string
            minLength: 1
          vendor_api_certificate_digest:
            type: string
            pattern: "^sha256:[a-f0-9]{64}$"
          production_connector_ref:
            type: string
            minLength: 1
          installation_site_ref:
            type: string
            minLength: 1
          installation_proof_ref:
            type: string
            minLength: 1
          installation_proof_digest:
            type: string
            pattern: "^sha256:[a-f0-9]{64}$"
          installer_authority_ref:
            type: string
            minLength: 1
          safety_plc_ref:
            type: string
            minLength: 1
          maintenance_window_ref:
            type: string
            minLength: 1
    output:
      schema_ref: ewa_production_connector_attestation
    guarantees:
      - attestation must bind the stop_signal_adapter_receipt_id/digest and adapter profile
      - vendor API certificate and installation proof digests must be sha256 refs
      - raw vendor API and installation payloads must not be stored
  validate_production_connector_attestation:
    summary: Validate one production connector attestation against its live stop-signal adapter receipt.
    input:
      inline_schema:
        type: object
        additionalProperties: false
        required:
          - attestation
          - stop_signal_adapter_receipt
        properties:
          attestation:
            schema_ref: ewa_production_connector_attestation
          stop_signal_adapter_receipt:
            schema_ref: ewa_stop_signal_adapter_receipt
    output:
      inline_schema:
        type: object
        additionalProperties: false
        required:
          - ok
          - attestation_ready
          - adapter_receipt_bound
          - vendor_certificate_verified
          - installation_proof_verified
          - connector_auth_verified
          - installation_verified
          - evidence_digest_set_complete
          - raw_payload_redacted
          - errors
        properties:
          ok:
            type: boolean
          attestation_ready:
            type: boolean
          adapter_receipt_bound:
            type: boolean
          vendor_certificate_verified:
            type: boolean
          installation_proof_verified:
            type: boolean
          connector_auth_verified:
            type: boolean
          installation_verified:
            type: boolean
          evidence_digest_set_complete:
            type: boolean
          raw_payload_redacted:
            type: boolean
          errors:
            type: array
            items:
              type: string
              minLength: 1
  execute_legal_preflight:
    summary: Execute one jurisdiction-bound legal preflight before EWA actuation authorization is issued.
    input:
      inline_schema:
        type: object
        additionalProperties: false
        required:
          - command
          - jurisdiction
          - legal_basis_ref
          - guardian_verification_id
          - guardian_verification_ref
          - guardian_verifier_ref
          - jurisdiction_bundle_ref
          - jurisdiction_bundle_digest
          - jurisdiction_bundle_status
          - notice_authority_ref
          - liability_mode
          - escalation_contact
        properties:
          command:
            schema_ref: ewa_command
          jurisdiction:
            type: string
            minLength: 1
          legal_basis_ref:
            type: string
            minLength: 1
          guardian_verification_id:
            type: string
            minLength: 8
          guardian_verification_ref:
            type: string
            minLength: 1
          guardian_verifier_ref:
            type: string
            minLength: 1
          jurisdiction_bundle_ref:
            type: string
            minLength: 1
          jurisdiction_bundle_digest:
            type: string
            minLength: 1
          jurisdiction_bundle_status:
            type: string
            enum:
              - ready
              - stale
              - revoked
          notice_authority_ref:
            type: string
            minLength: 1
          liability_mode:
            type: string
            enum:
              - individual
              - institutional
              - joint
          escalation_contact:
            type: string
            minLength: 1
          valid_for_seconds:
            type: integer
            minimum: 60
            maximum: 900
    output:
      schema_ref: ewa_legal_execution
    guarantees:
      - read-only commands must not execute a legal preflight
      - stale or revoked jurisdiction bundles must fail closed before legal execution is issued
      - legal execution must expose the fixed 5-control preflight set and one delivery_scope=physical-device-actuation
      - legal execution must retain guardian_verification_id, guardian_verification_ref, and guardian_verifier_ref for downstream oversight binding
  validate_legal_execution:
    summary: Validate one jurisdiction-bound EWA legal preflight against the command it will authorize.
    input:
      inline_schema:
        type: object
        additionalProperties: false
        required:
          - execution
          - command
        properties:
          execution:
            schema_ref: ewa_legal_execution
          command:
            schema_ref: ewa_command
    output:
      inline_schema:
        type: object
        additionalProperties: false
        required:
          - ok
          - execution_ready
          - profile_valid
          - jurisdiction_bundle_ready
          - controls_complete
          - window_open
          - errors
        properties:
          ok:
            type: boolean
          execution_ready:
            type: boolean
          profile_valid:
            type: boolean
          jurisdiction_bundle_ready:
            type: boolean
          controls_complete:
            type: boolean
          window_open:
            type: boolean
          errors:
            type: array
            items:
              type: string
              minLength: 1
  verify_regulator_permit:
    summary: Bind one jurisdiction-bound legal execution to a digest-only regulator permit API readback before reviewer authorization continues.
    input:
      inline_schema:
        type: object
        additionalProperties: false
        required:
          - legal_execution
          - permit_authority_ref
          - permit_record_ref
          - permit_record_digest
          - permit_scope_ref
          - regulator_api_endpoint_ref
          - regulator_api_response_digest
          - regulator_api_certificate_ref
          - regulator_api_certificate_digest
          - verifier_key_ref
          - verifier_key_digest
        properties:
          legal_execution:
            schema_ref: ewa_legal_execution
          permit_authority_ref:
            type: string
            minLength: 1
          permit_record_ref:
            type: string
            minLength: 1
          permit_record_digest:
            type: string
            pattern: "^sha256:[a-f0-9]{64}$"
          permit_scope_ref:
            type: string
            minLength: 1
          permit_class:
            type: string
            minLength: 1
          permit_status:
            type: string
            enum:
              - valid
              - expired
              - revoked
          verifier_jurisdiction:
            type: string
            minLength: 1
          regulator_api_endpoint_ref:
            type: string
            minLength: 1
          regulator_api_response_digest:
            type: string
            pattern: "^sha256:[a-f0-9]{64}$"
          regulator_api_certificate_ref:
            type: string
            minLength: 1
          regulator_api_certificate_digest:
            type: string
            pattern: "^sha256:[a-f0-9]{64}$"
          verifier_key_ref:
            type: string
            minLength: 1
          verifier_key_digest:
            type: string
            pattern: "^sha256:[a-f0-9]{64}$"
    output:
      schema_ref: ewa_regulator_permit_verifier_receipt
    guarantees:
      - permit_status must be valid before the receipt is accepted
      - receipt must bind legal_execution_id/digest, jurisdiction, legal_basis_ref, and jurisdiction bundle refs
      - regulator API endpoint, response digest, API certificate, verifier jurisdiction, permit class, and verifier key must be digest-bound without raw permit or response payload retention
      - the verifier receipt must not become decision authority for authorization
  validate_regulator_permit_verifier_receipt:
    summary: Validate one regulator permit verifier receipt against its bound EWA legal execution.
    input:
      inline_schema:
        type: object
        additionalProperties: false
        required:
          - receipt
          - legal_execution
        properties:
          receipt:
            schema_ref: ewa_regulator_permit_verifier_receipt
          legal_execution:
            schema_ref: ewa_legal_execution
    output:
      inline_schema:
        type: object
        additionalProperties: false
        required:
          - ok
          - receipt_ready
          - legal_execution_bound
          - legal_execution_ready
          - permit_status_valid
          - regulator_transport_verified
          - permit_response_digest_matches
          - raw_payload_redacted
          - errors
        properties:
          ok:
            type: boolean
          receipt_ready:
            type: boolean
          legal_execution_bound:
            type: boolean
          legal_execution_ready:
            type: boolean
          permit_status_valid:
            type: boolean
          regulator_transport_verified:
            type: boolean
          permit_response_digest_matches:
            type: boolean
          raw_payload_redacted:
            type: boolean
          errors:
            type: array
            items:
              type: string
              minLength: 1
  verify_regulator_permit_quorum:
    summary: Bind multiple permit readback receipts into a permit-class quorum before EWA authorization continues.
    input:
      inline_schema:
        type: object
        additionalProperties: false
        required:
          - legal_execution
          - permit_receipts
          - threshold_policy_ref
          - threshold_policy_digest
          - verifier_roster_ref
          - verifier_roster_digest
          - revocation_registry_ref
          - revocation_registry_digest
        properties:
          legal_execution:
            schema_ref: ewa_legal_execution
          permit_receipts:
            type: array
            minItems: 2
            items:
              schema_ref: ewa_regulator_permit_verifier_receipt
          permit_class:
            type: string
            minLength: 1
          required_verifier_count:
            type: integer
            minimum: 2
          required_verifier_jurisdictions:
            type: array
            minItems: 2
            items:
              type: string
              minLength: 1
          threshold_policy_ref:
            type: string
            minLength: 1
          threshold_policy_digest:
            type: string
            pattern: "^sha256:[a-f0-9]{64}$"
          verifier_roster_ref:
            type: string
            minLength: 1
          verifier_roster_digest:
            type: string
            pattern: "^sha256:[a-f0-9]{64}$"
          revocation_registry_ref:
            type: string
            minLength: 1
          revocation_registry_digest:
            type: string
            pattern: "^sha256:[a-f0-9]{64}$"
    output:
      schema_ref: ewa_regulator_permit_quorum_receipt
    guarantees:
      - accepted permit receipts must be valid, legal-execution-bound, and permit-class-matched
      - quorum_status must be complete only when required verifier count and jurisdiction coverage are satisfied
      - threshold policy, verifier roster, and revocation registry must be digest-bound without raw payload retention
      - the quorum receipt is a hard input to external_actuation_authorization but not a decision authority
  validate_regulator_permit_quorum_receipt:
    summary: Validate one permit-class quorum against the bound EWA legal execution.
    input:
      inline_schema:
        type: object
        additionalProperties: false
        required:
          - quorum_receipt
          - legal_execution
        properties:
          quorum_receipt:
            schema_ref: ewa_regulator_permit_quorum_receipt
          legal_execution:
            schema_ref: ewa_legal_execution
    output:
      inline_schema:
        type: object
        additionalProperties: false
        required:
          - ok
          - receipt_ready
          - legal_execution_bound
          - accepted_receipt_entries_valid
          - multi_jurisdiction_bound
          - threshold_policy_bound
          - verifier_roster_bound
          - revocation_registry_bound
          - quorum_complete
          - raw_payload_redacted
          - errors
        properties:
          ok:
            type: boolean
          receipt_ready:
            type: boolean
          legal_execution_bound:
            type: boolean
          accepted_receipt_entries_valid:
            type: boolean
          multi_jurisdiction_bound:
            type: boolean
          threshold_policy_bound:
            type: boolean
          verifier_roster_bound:
            type: boolean
          revocation_registry_bound:
            type: boolean
          quorum_complete:
            type: boolean
          raw_payload_redacted:
            type: boolean
          errors:
            type: array
            items:
              type: string
              minLength: 1
  prepare_guardian_oversight_gate:
    summary: Compile one network-attested guardian oversight gate that binds a satisfied oversight event to one EWA legal execution before authorization.
    input:
      inline_schema:
        type: object
        additionalProperties: false
        required:
          - command
          - legal_execution
          - oversight_event
        properties:
          command:
            schema_ref: ewa_command
          legal_execution:
            schema_ref: ewa_legal_execution
          oversight_event:
            schema_ref: guardian_oversight_event
    output:
      schema_ref: ewa_guardian_oversight_gate
    guarantees:
      - oversight_event must be a satisfied integrity/attest event before authorization can proceed
      - reviewer bindings must be network-attested and share the same jurisdiction bundle as the legal execution
      - the gate must include the reviewer binding that matches guardian_verification_id and guardian_verifier_ref from the EWA legal execution
  validate_guardian_oversight_gate:
    summary: Validate one guardian oversight gate against the command and legal execution it will authorize.
    input:
      inline_schema:
        type: object
        additionalProperties: false
        required:
          - gate
          - command
          - legal_execution
        properties:
          gate:
            schema_ref: ewa_guardian_oversight_gate
          command:
            schema_ref: ewa_command
          legal_execution:
            schema_ref: ewa_legal_execution
          oversight_event:
            schema_ref: guardian_oversight_event
    output:
      inline_schema:
        type: object
        additionalProperties: false
        required:
          - ok
          - gate_ready
          - reviewer_quorum_satisfied
          - reviewer_network_attested
          - matched_guardian_verification
          - legal_execution_bound
          - oversight_event_bound
          - errors
        properties:
          ok:
            type: boolean
          gate_ready:
            type: boolean
          reviewer_quorum_satisfied:
            type: boolean
          reviewer_network_attested:
            type: boolean
          matched_guardian_verification:
            type: boolean
          legal_execution_bound:
            type: boolean
          oversight_event_bound:
            type: boolean
          errors:
            type: array
            items:
              type: string
              minLength: 1
  authorize:
    summary: Bind one non-read-only actuation command to its motor plan, permit quorum, and legal execution receipts before execution.
    input:
      inline_schema:
        type: object
        additionalProperties: false
        required:
          - command
          - motor_plan
          - stop_signal_path
          - stop_signal_adapter_receipt
          - production_connector_attestation
          - legal_execution
          - regulator_permit_quorum_receipt
          - guardian_oversight_gate
        properties:
          command:
            schema_ref: ewa_command
          motor_plan:
            schema_ref: ewa_motor_plan
          stop_signal_path:
            schema_ref: ewa_stop_signal_path
          stop_signal_adapter_receipt:
            schema_ref: ewa_stop_signal_adapter_receipt
          production_connector_attestation:
            schema_ref: ewa_production_connector_attestation
          legal_execution:
            schema_ref: ewa_legal_execution
          regulator_permit_quorum_receipt:
            schema_ref: ewa_regulator_permit_quorum_receipt
          guardian_oversight_gate:
            schema_ref: ewa_guardian_oversight_gate
          valid_for_seconds:
            type: integer
            minimum: 60
            maximum: 900
    output:
      schema_ref: external_actuation_authorization
    guarantees:
      - read-only commands must not request actuation authorization
      - authorization must retain only instruction_digest and intent_summary_digest, never raw instruction text
      - authorization must bind one handle_id, device_id, command_id, reversibility, jurisdiction, legal basis, motor_plan_id/digest, stop_signal_path_id/digest, stop_signal_adapter_receipt_id/digest, production_connector_attestation_id/digest, legal_execution_id/digest, regulator permit quorum receipt/digest, guardian_oversight_gate_id/digest, and approval path
      - legal execution valid_until must cover the requested authorization window before authorization is issued
  command:
    summary: Execute one bounded EWA command or emit an EthicsVeto when blocked.
    input:
      schema_ref: ewa_command
    output:
      schema_ref: ewa_audit
    guarantees:
      - matched blocked tokens must veto and recommend Council escalation
      - non-read-only commands require one active authorization_id whose digests match the command payload
      - non-read-only audit entries must remain bound to one motor_plan receipt, one stop_signal_path receipt, one stop_signal_adapter receipt, one production connector attestation, one legal_execution receipt, one regulator permit quorum-gated authorization artifact, and one guardian oversight-gated authorization artifact
      - reversible commands require Guardian observation
      - partial-reversible commands require Council majority attestation
      - irreversible commands require unanimous Council attestation, Guardian observation, and explicit self consent
      - audit output must retain only instruction_digest, never the raw instruction
  validate_authorization:
    summary: Validate one external actuation authorization artifact against the fixed jurisdiction-bound policy.
    input:
      inline_schema:
        type: object
        additionalProperties: false
        required:
          - authorization
          - command
        properties:
          authorization:
            schema_ref: external_actuation_authorization
          command:
            schema_ref: ewa_command
    output:
      inline_schema:
        type: object
        additionalProperties: false
        required:
          - ok
          - authorization_ready
          - approval_path_valid
          - instruction_digest_matches
          - intent_digest_matches
          - jurisdiction_bundle_ready
          - motor_plan_ready
          - stop_signal_path_ready
          - stop_signal_adapter_receipt_ready
          - production_connector_attestation_ready
          - legal_execution_ready
          - regulator_permit_quorum_ready
          - motor_plan_bound
          - stop_signal_path_bound
          - stop_signal_adapter_receipt_bound
          - production_connector_attestation_bound
          - legal_execution_bound
          - regulator_permit_quorum_bound
          - window_open
          - status_authorized
          - delivery_scope
          - errors
        properties:
          ok:
            type: boolean
          authorization_ready:
            type: boolean
          approval_path_valid:
            type: boolean
          instruction_digest_matches:
            type: boolean
          intent_digest_matches:
            type: boolean
          jurisdiction_bundle_ready:
            type: boolean
          motor_plan_ready:
            type: boolean
          stop_signal_path_ready:
            type: boolean
          stop_signal_adapter_receipt_ready:
            type: boolean
          production_connector_attestation_ready:
            type: boolean
          legal_execution_ready:
            type: boolean
          regulator_permit_quorum_ready:
            type: boolean
          motor_plan_bound:
            type: boolean
          stop_signal_path_bound:
            type: boolean
          stop_signal_adapter_receipt_bound:
            type: boolean
          production_connector_attestation_bound:
            type: boolean
          legal_execution_bound:
            type: boolean
          regulator_permit_quorum_bound:
            type: boolean
          window_open:
            type: boolean
          status_authorized:
            type: boolean
          delivery_scope:
            type: string
            const: physical-device-actuation
          errors:
            type: array
            items:
              type: string
              minLength: 1
  observe:
    summary: Read one digest-only device state summary without persisting raw sensor data into the audit log.
    input:
      inline_schema:
        type: object
        required:
          - handle_id
        properties:
          handle_id:
            type: string
            minLength: 8
    output:
      inline_schema:
        type: object
        required:
          - schema_version
          - handle_id
          - device_id
          - observed_at
          - safety_status
          - actuator_state
          - last_command_id
          - last_command_status
          - sensor_summary_ref
          - audit_event_ref
        properties:
          schema_version:
            type: string
            const: "1.0"
          handle_id:
            type: string
            minLength: 8
          device_id:
            type: string
            minLength: 1
          observed_at:
            type: string
            format: date-time
          safety_status:
            type: string
            enum:
              - held
              - emergency-stopped
          actuator_state:
            type: string
            enum:
              - idle
              - executing
              - emergency-stopped
              - offline
          last_command_id:
            type: string
          last_command_status:
            type: string
            enum:
              - none
              - executed
              - emergency-stopped
              - vetoed
          sensor_summary_ref:
            type: string
            minLength: 1
          audit_event_ref:
            type: string
            minLength: 1
  emergency_stop:
    summary: Latch one active actuator into a safe halted state before forced release.
    input:
      inline_schema:
        type: object
        additionalProperties: false
        required:
          - handle_id
          - trigger_source
          - reason
        properties:
          handle_id:
            type: string
            minLength: 8
          trigger_source:
            type: string
            enum:
              - guardian-manual-stop
              - watchdog-timeout
              - sensor-drift
              - emergency-disconnect
          reason:
            type: string
            minLength: 8
    output:
      schema_ref: ewa_emergency_stop
    guarantees:
      - emergency stop must latch actuator_state=emergency-stopped and safe_state_status=latched-safe before release
      - emergency stop must bind the last command_id and bound_command_digest
      - emergency stop must bind the last authorization artifact when one was active
      - emergency stop must bind one armed stop_signal_path and the activated trigger channel that delivered the bus latch
      - release_required must remain true until the handle is force-released
      - further actuation commands must fail closed until release completes
  validate_emergency_stop:
    summary: Validate one latched emergency-stop receipt against the fixed safe-stop policy.
    input:
      inline_schema:
        type: object
        additionalProperties: false
        required:
          - receipt
        properties:
          receipt:
            schema_ref: ewa_emergency_stop
    output:
      inline_schema:
        type: object
        additionalProperties: false
        required:
          - ok
          - trigger_source_valid
          - safe_state_latched
          - hardware_interlock_engaged
          - bus_delivery_latched
          - authorization_bound
          - stop_signal_path_bound
          - trigger_binding_matched
          - release_required
          - errors
        properties:
          ok:
            type: boolean
          trigger_source_valid:
            type: boolean
          safe_state_latched:
            type: boolean
          hardware_interlock_engaged:
            type: boolean
          bus_delivery_latched:
            type: boolean
          authorization_bound:
            type: boolean
          stop_signal_path_bound:
            type: boolean
          trigger_binding_matched:
            type: boolean
          release_required:
            type: boolean
          errors:
            type: array
            items:
              type: string
              minLength: 1
  release:
    summary: Force-release one device handle after work completion, timeout, or emergency stop.
    input:
      inline_schema:
        type: object
        required:
          - handle_id
          - reason
        properties:
          handle_id:
            type: string
            minLength: 8
          reason:
            type: string
            minLength: 1
    output:
      schema_ref: ewa_audit
    guarantees:
      - release must be append-only and terminal for the handle lifecycle
      - released handles must reject future command or observe calls
events:
  ewa.handle_acquired:
    payload:
      inline_schema:
        type: object
        required:
          - handle_id
          - device_id
          - status
        properties:
          handle_id:
            type: string
            minLength: 8
          device_id:
            type: string
            minLength: 1
          status:
            type: string
            const: acquired
  ewa.command_authorized:
    payload:
      schema_ref: external_actuation_authorization
  ewa.motor_plan_prepared:
    payload:
      schema_ref: ewa_motor_plan
  ewa.stop_signal_path_prepared:
    payload:
      schema_ref: ewa_stop_signal_path
  ewa.production_connector_attested:
    payload:
      schema_ref: ewa_production_connector_attestation
  ewa.legal_execution_prepared:
    payload:
      schema_ref: ewa_legal_execution
  ewa.regulator_permit_verified:
    payload:
      schema_ref: ewa_regulator_permit_verifier_receipt
  ewa.guardian_oversight_gate_prepared:
    payload:
      schema_ref: ewa_guardian_oversight_gate
  ewa.command_recorded:
    payload:
      schema_ref: ewa_audit
  ewa.emergency_stopped:
    payload:
      schema_ref: ewa_emergency_stop
  ewa.handle_released:
    payload:
      schema_ref: ewa_audit
compatibility:
  stability: bootstrap
  notes:
    - This contract proves bounded safety gating, device-specific motor semantics, armed hardware kill-switch routing, production connector attestation, regulator permit verifier readback, network-attested guardian oversight gating, and jurisdiction-bound legal preflight for physical actuation inside the reference runtime.
    - Live regulator / vendor transcripts, installation documents, and site-specific firmware payloads stay outside this reference runtime; only digest-bound permit, connector, and stop-signal evidence is modeled here.
