idl_version: 1
kind: service
namespace: kernel.ethics.v0
service: EthicsEnforcerService
summary: Decision gate for approval, veto, and escalation of sensitive actions.
imports:
  ethics_query: ../schemas/ethics_query.yaml
  ethics_decision: ../schemas/ethics_decision.yaml
  ethics_event: ../schemas/ethics_event.schema
  ethics_rule: ../schemas/ethics_rule.schema
operations:
  check_action:
    summary: Evaluate one action against the encoded ethics ruleset.
    input:
      schema_ref: ethics_query
    output:
      schema_ref: ethics_decision
    guarantees:
      - activate-copy requests must evaluate A2-uniqueness
      - terminate requests must evaluate A3-termination and A4-refusal
      - when multiple rules match, the strongest outcome wins, then the higher resolution_priority, then lexical rule_id order
  record_decision:
    summary: Persist veto or escalation events to the EthicsLedger.
    input:
      schema_ref: ethics_decision
    output:
      schema_ref: ethics_event
  explain_rule:
    summary: Return structured interpretation notes for one ethics rule.
    input:
      inline_schema:
        type: object
        required:
          - rule_id
        properties:
          rule_id:
            type: string
    output:
      schema_ref: ethics_rule
compatibility:
  stability: bootstrap
  notes:
    - EthicsEnforcer remains immutable from L5 according to governance docs.
    - rule language is fixed to deterministic-rule-tree-v0 in the reference runtime.
    - decision payloads expose priority-then-lexical-ethics-resolution-v1 so reviewer-facing conflict resolution stays machine-checkable.
