idl_version: 1
kind: service
namespace: agentic.trust.v0
service: TrustRegistryService
summary: Deterministic trust scoring, provenance-bound anti-tamper guards, human pinning, and threshold evaluation for agent selection.
imports:
  trust_snapshot: ../schemas/trust_snapshot.schema
  trust_event: ../schemas/trust_event.schema
  trust_transfer_receipt: ../schemas/trust_transfer_receipt.schema
  guardian_verifier_network_receipt: ../schemas/guardian_verifier_network_receipt.schema
operations:
  register_agent:
    summary: Create or seed a trust record for one agent.
    input:
      inline_schema:
        type: object
        required:
          - agent_id
        properties:
          agent_id:
            type: string
          initial_score:
            type: number
            minimum: 0
            maximum: 1
          per_domain:
            type: object
            additionalProperties:
              type: number
              minimum: 0
              maximum: 1
          pinned_by_human:
            type: boolean
          pinned_reason:
            type: string
    output:
      schema_ref: trust_snapshot
  record_event:
    summary: Apply one audited trust update event to one domain.
    input:
      inline_schema:
        type: object
        required:
          - agent_id
          - event_type
          - domain
          - severity
          - evidence_confidence
          - triggered_by
          - rationale
        properties:
          agent_id:
            type: string
          event_type:
            type: string
          domain:
            type: string
          severity:
            type: string
          evidence_confidence:
            type: number
            minimum: 0
            maximum: 1
          triggered_by:
            type: string
          rationale:
            type: string
    output:
      schema_ref: trust_event
    guarantees:
      - raw_delta must equal base_delta[event_type] * severity_multiplier[severity] * evidence_confidence
      - positive events must fail closed when the target agent self-issues the update attempt
      - positive events must fail closed when event provenance does not match the required Council/Guardian/Human origin
      - reciprocal positive boosts between registered agents must fail closed within the same domain history
      - applied_delta must be 0 when pinned_by_human is true
      - scores must remain within [0.0, 1.0]
  snapshot:
    summary: Read current trust score, history, and eligibility flags for one agent.
    input:
      inline_schema:
        type: object
        required:
          - agent_id
        properties:
          agent_id:
            type: string
    output:
      schema_ref: trust_snapshot
  pin:
    summary: Freeze automatic updates and optionally overwrite seeded scores by human decision.
    input:
      inline_schema:
        type: object
        required:
          - agent_id
          - reason
        properties:
          agent_id:
            type: string
          reason:
            type: string
          global_score:
            type: number
            minimum: 0
            maximum: 1
          per_domain:
            type: object
            additionalProperties:
              type: number
              minimum: 0
              maximum: 1
    output:
      schema_ref: trust_snapshot
  transfer_snapshot:
    summary: Export one trust snapshot across a substrate boundary and seed it on the destination with bounded guardian/human attestation, live remote verifier federation, fixed re-attestation cadence, and append-only destination lifecycle history.
    input:
      inline_schema:
        type: object
        required:
          - agent_id
          - source_substrate_ref
          - destination_substrate_ref
          - destination_host_ref
          - source_guardian_agent_id
          - destination_guardian_agent_id
          - human_reviewer_ref
          - remote_verifier_receipts
          - council_session_ref
          - rationale
        properties:
          agent_id:
            type: string
          source_substrate_ref:
            type: string
          destination_substrate_ref:
            type: string
          destination_host_ref:
            type: string
          source_guardian_agent_id:
            type: string
          destination_guardian_agent_id:
            type: string
          human_reviewer_ref:
            type: string
          remote_verifier_receipts:
            type: array
            minItems: 2
            maxItems: 2
            items:
              schema_ref: guardian_verifier_network_receipt
          council_session_ref:
            type: string
          rationale:
            type: string
    output:
      schema_ref: trust_transfer_receipt
    guarantees:
      - source_snapshot and destination_snapshot must both validate against trust_snapshot
      - source_snapshot_digest and destination_snapshot_digest must bind the exported and imported snapshot payloads
      - source guardian, destination guardian, and one explicit human reviewer must satisfy the fixed attestation quorum before import completes
      - two live remote verifier receipts must bind the human reviewer attestation with distinct verifier refs before import completes
      - fixed re-attestation cadence must renew before the minimum verifier freshness window expires
      - destination lifecycle must preserve imported, renewed, and revocation-cleared history entries as one append-only ledger
      - import must preserve thresholds, provenance policy, eligibility flags, and append-only history without mutation
      - receipt_digest must stay stable for the fixed export/import/attestation payload family
  validate_transfer_receipt:
    summary: Validate one cross-substrate trust transfer receipt against the fixed export/import, verifier federation, and re-attestation policy.
    input:
      inline_schema:
        type: object
        required:
          - receipt
        properties:
          receipt:
            schema_ref: trust_transfer_receipt
    output:
      inline_schema:
        type: object
        required:
          - source_snapshot_digest_bound
          - destination_snapshot_digest_bound
          - history_preserved
          - thresholds_preserved
          - provenance_policy_preserved
          - eligibility_preserved
          - federation_quorum_attested
          - live_remote_verifier_attested
          - remote_verifier_receipts_bound
          - re_attestation_cadence_bound
          - re_attestation_current
          - destination_lifecycle_bound
          - destination_renewal_history_bound
          - destination_revocation_history_bound
          - destination_current
          - destination_seeded
          - receipt_digest_bound
          - ok
          - errors
        properties:
          source_snapshot_digest_bound:
            type: boolean
          destination_snapshot_digest_bound:
            type: boolean
          history_preserved:
            type: boolean
          thresholds_preserved:
            type: boolean
          provenance_policy_preserved:
            type: boolean
          eligibility_preserved:
            type: boolean
          federation_quorum_attested:
            type: boolean
          live_remote_verifier_attested:
            type: boolean
          remote_verifier_receipts_bound:
            type: boolean
          re_attestation_cadence_bound:
            type: boolean
          re_attestation_current:
            type: boolean
          destination_lifecycle_bound:
            type: boolean
          destination_renewal_history_bound:
            type: boolean
          destination_revocation_history_bound:
            type: boolean
          destination_current:
            type: boolean
          destination_seeded:
            type: boolean
          receipt_digest_bound:
            type: boolean
          ok:
            type: boolean
          errors:
            type: array
            items:
              type: string
compatibility:
  stability: bootstrap
  notes:
    - Guardian role requires global_score >= 0.99 and explicit human pin.
    - Self-modify eligibility requires both global_score and self_modify domain score to exceed 0.95.
    - Trust provenance is fixed to Council / Guardian / Human origins and blocks self-issued or reciprocal positive boosts.
    - Cross-substrate transfer is materialized as a snapshot-clone receipt with source guardian, destination guardian, human reviewer attestation quorum, live remote verifier federation, fixed re-attestation cadence, and append-only destination lifecycle history.
