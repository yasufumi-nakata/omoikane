idl_version: 1
kind: service
namespace: agentic.trust.v0
service: TrustRegistryService
summary: Deterministic trust scoring, human pinning, and threshold evaluation for agent selection.
imports:
  trust_snapshot: ../schemas/trust_snapshot.schema
  trust_event: ../schemas/trust_event.schema
operations:
  register_agent:
    summary: Create or seed a trust record for one agent.
    input:
      inline_schema:
        type: object
        required:
          - agent_id
        properties:
          agent_id:
            type: string
          initial_score:
            type: number
            minimum: 0
            maximum: 1
          per_domain:
            type: object
            additionalProperties:
              type: number
              minimum: 0
              maximum: 1
          pinned_by_human:
            type: boolean
          pinned_reason:
            type: string
    output:
      schema_ref: trust_snapshot
  record_event:
    summary: Apply one audited trust update event to one domain.
    input:
      inline_schema:
        type: object
        required:
          - agent_id
          - event_type
          - domain
          - severity
          - evidence_confidence
          - triggered_by
          - rationale
        properties:
          agent_id:
            type: string
          event_type:
            type: string
          domain:
            type: string
          severity:
            type: string
          evidence_confidence:
            type: number
            minimum: 0
            maximum: 1
          triggered_by:
            type: string
          rationale:
            type: string
    output:
      schema_ref: trust_event
    guarantees:
      - raw_delta must equal base_delta[event_type] * severity_multiplier[severity] * evidence_confidence
      - applied_delta must be 0 when pinned_by_human is true
      - scores must remain within [0.0, 1.0]
  snapshot:
    summary: Read current trust score, history, and eligibility flags for one agent.
    input:
      inline_schema:
        type: object
        required:
          - agent_id
        properties:
          agent_id:
            type: string
    output:
      schema_ref: trust_snapshot
  pin:
    summary: Freeze automatic updates and optionally overwrite seeded scores by human decision.
    input:
      inline_schema:
        type: object
        required:
          - agent_id
          - reason
        properties:
          agent_id:
            type: string
          reason:
            type: string
          global_score:
            type: number
            minimum: 0
            maximum: 1
          per_domain:
            type: object
            additionalProperties:
              type: number
              minimum: 0
              maximum: 1
    output:
      schema_ref: trust_snapshot
compatibility:
  stability: bootstrap
  notes:
    - Guardian role requires global_score >= 0.99 and explicit human pin.
    - Self-modify eligibility requires both global_score and self_modify domain score to exceed 0.95.
    - Cross-substrate transfer of trust remains outside the reference runtime.
