idl_version: 1
kind: service
namespace: selfctor.diff_eval.v0
service: DifferentialEvaluatorService
summary: Select and execute eval suites against sandbox and baseline variants.
imports:
  diff_eval_execution_receipt: ../schemas/diff_eval_execution_receipt.schema
operations:
  select_suite:
    summary: Resolve an eval list from a build request and affected subsystem.
    input:
      inline_schema:
        type: object
        required:
          - target_subsystem
          - requested_evals
        properties:
          target_subsystem:
            type: string
          requested_evals:
            type: array
            items:
              type: string
              pattern: "^evals/"
    output:
      inline_schema:
        type: object
        required:
          - selected_evals
        properties:
          selected_evals:
            type: array
            items:
              type: string
              pattern: "^evals/"
  run_ab_eval:
    summary: Execute one eval suite against baseline and sandbox variants with parsed evidence bindings.
    input:
      inline_schema:
        type: object
        required:
          - eval_ref
          - baseline_ref
          - sandbox_ref
        properties:
          eval_ref:
            type: string
            pattern: "^evals/"
          baseline_ref:
            type: string
          sandbox_ref:
            type: string
    output:
      inline_schema:
        type: object
        required:
          - eval_ref
          - outcome
          - profile_id
          - compared_dimensions
          - baseline_observation
          - sandbox_observation
          - triggered_rules
          - comparison_summary
          - comparison_digest
          - execution_bound
        properties:
          eval_ref:
            type: string
          outcome:
            type: string
            enum:
              - pass
              - fail
              - regression
          report_ref:
            type: string
          profile_id:
            type: string
          compared_dimensions:
            type: array
            items:
              type: string
          baseline_observation:
            type: object
          sandbox_observation:
            type: object
          triggered_rules:
            type: array
            items:
              type: string
          comparison_summary:
            type: string
          comparison_digest:
            type: string
            pattern: "^[a-f0-9]{64}$"
          execution_bound:
            type: boolean
          execution_receipt:
            schema_ref: diff_eval_execution_receipt
          execution_receipt_digest:
            type: string
            pattern: "^[a-f0-9]{64}$"
    guarantees:
      - every eval report binds parsed baseline and sandbox observations with a comparison digest
      - temp-workspace eval command evidence is bound when actual enactment receipts are available
      - regression classification remains fail-closed for rollback-triggering evidence
  classify_rollout:
    summary: Classify whether rollout may proceed after all evals complete.
    input:
      inline_schema:
        type: object
        required:
          - outcomes
        properties:
          outcomes:
            type: array
            items:
              type: string
              enum:
                - pass
                - fail
                - regression
    output:
      inline_schema:
        type: object
        required:
          - decision
        properties:
          decision:
            type: string
            enum:
              - promote
              - hold
              - rollback
compatibility:
  stability: bootstrap
  notes:
    - Any regression outcome forces rollback per self-modification governance.
