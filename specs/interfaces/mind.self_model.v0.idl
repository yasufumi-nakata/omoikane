idl_version: 1
kind: service
namespace: mind.self_model.v0
service: SelfModelMonitorService
summary: Reference self-model snapshot and divergence detection contract.
imports:
  self_model: ../schemas/self_model.schema
  self_model_observation: ../schemas/self_model_observation.schema
  self_model_calibration_receipt: ../schemas/self_model_calibration_receipt.schema
  self_model_pathological_self_assessment_escalation_receipt: ../schemas/self_model_pathological_self_assessment_escalation_receipt.schema
  self_model_care_trustee_handoff_receipt: ../schemas/self_model_care_trustee_handoff_receipt.schema
  self_model_value_generation_receipt: ../schemas/self_model_value_generation_receipt.schema
  self_model_value_autonomy_review_receipt: ../schemas/self_model_value_autonomy_review_receipt.schema
  self_model_value_acceptance_receipt: ../schemas/self_model_value_acceptance_receipt.schema
  self_model_value_reassessment_receipt: ../schemas/self_model_value_reassessment_receipt.schema
  self_model_value_timeline_receipt: ../schemas/self_model_value_timeline_receipt.schema
operations:
  profile:
    summary: Return the fixed divergence policy used by the reference runtime.
    output:
      inline_schema:
        type: object
        required:
          - policy_id
          - abrupt_change_threshold
          - comparison_components
          - trait_distance_mode
          - change_window
        properties:
          policy_id:
            type: string
            const: bounded-self-model-monitor-v1
          abrupt_change_threshold:
            type: number
            const: 0.35
          comparison_components:
            type: array
            items:
              type: string
            minItems: 3
            maxItems: 3
          trait_distance_mode:
            type: string
            const: mean-absolute-delta
          change_window:
            type: string
            const: adjacent-snapshot
  update:
    summary: Persist one self-model snapshot and compute divergence from the previous one.
    input:
      schema_ref: self_model
    output:
      schema_ref: self_model_observation
  build_advisory_calibration_receipt:
    summary: Bind external self-model calibration evidence as advisory-only, self-consented review without forced writeback.
    input:
      inline_schema:
        type: object
        required:
          - observation
          - reviewer_evidence_refs
          - self_consent_ref
          - council_resolution_ref
          - guardian_redaction_ref
          - proposed_adjustments
        properties:
          observation:
            schema_ref: self_model_observation
          reviewer_evidence_refs:
            type: array
            minItems: 1
            items:
              type: string
          self_consent_ref:
            type: string
            minLength: 1
          council_resolution_ref:
            type: string
            minLength: 1
          guardian_redaction_ref:
            type: string
            minLength: 1
          proposed_adjustments:
            type: array
            minItems: 1
            items:
              type: object
    output:
      schema_ref: self_model_calibration_receipt
  validate_advisory_calibration_receipt:
    summary: Fail closed unless the calibration receipt remains advisory-only, self-consented, Council-reviewed, and Guardian-redacted.
    input:
      schema_ref: self_model_calibration_receipt
    output:
      inline_schema:
        type: object
        required:
          - ok
          - advisory_only
          - self_consent_bound
          - council_resolution_bound
          - guardian_redaction_bound
        properties:
          ok:
            type: boolean
          advisory_only:
            type: boolean
          self_consent_bound:
            type: boolean
          council_resolution_bound:
            type: boolean
          guardian_redaction_bound:
            type: boolean
  build_pathology_escalation_receipt:
    summary: Escalate possible pathological self-assessment to external medical/legal systems without internal OS diagnosis or forced SelfModel writeback.
    input:
      inline_schema:
        type: object
        required:
          - calibration_receipt
          - risk_signal_refs
          - consent_or_emergency_review_ref
          - council_resolution_ref
          - guardian_boundary_ref
          - medical_system_ref
          - legal_system_ref
          - care_handoff_ref
        properties:
          calibration_receipt:
            schema_ref: self_model_calibration_receipt
          risk_signal_refs:
            type: array
            minItems: 1
            items:
              type: string
              minLength: 1
          consent_or_emergency_review_ref:
            type: string
            minLength: 1
          council_resolution_ref:
            type: string
            minLength: 1
          guardian_boundary_ref:
            type: string
            minLength: 1
          medical_system_ref:
            type: string
            minLength: 1
          legal_system_ref:
            type: string
            minLength: 1
          care_handoff_ref:
            type: string
            minLength: 1
    output:
      schema_ref: self_model_pathological_self_assessment_escalation_receipt
  validate_pathology_escalation_receipt:
    summary: Fail closed unless pathology escalation remains observe-and-refer-only, external-adjudicated, consent/emergency-reviewed, and raw-payload redacted.
    input:
      schema_ref: self_model_pathological_self_assessment_escalation_receipt
    output:
      inline_schema:
        type: object
        required:
          - ok
          - care_handoff_required
          - consent_or_emergency_review_required
          - boundary_only_review
          - internal_diagnosis_allowed
          - self_model_writeback_allowed
          - handoff_commit_digest_bound
        properties:
          ok:
            type: boolean
          care_handoff_required:
            type: boolean
          consent_or_emergency_review_required:
            type: boolean
          boundary_only_review:
            type: boolean
          internal_diagnosis_allowed:
            type: boolean
          self_model_writeback_allowed:
            type: boolean
          handoff_commit_digest_bound:
            type: boolean
  build_care_trustee_handoff_receipt:
    summary: Bind long-term external care-team, trustee, and legal-guardian responsibility refs after pathology escalation without making the OS a trustee, medical authority, or legal guardian.
    input:
      inline_schema:
        type: object
        required:
          - pathology_escalation_receipt
          - trustee_refs
          - care_team_refs
          - legal_guardian_refs
          - responsibility_boundary_refs
          - consent_or_emergency_review_ref
          - council_resolution_ref
          - guardian_boundary_ref
          - long_term_review_schedule_ref
          - escalation_continuity_ref
        properties:
          pathology_escalation_receipt:
            schema_ref: self_model_pathological_self_assessment_escalation_receipt
          trustee_refs:
            type: array
            minItems: 1
            items:
              type: string
              minLength: 1
          care_team_refs:
            type: array
            minItems: 1
            items:
              type: string
              minLength: 1
          legal_guardian_refs:
            type: array
            minItems: 1
            items:
              type: string
              minLength: 1
          responsibility_boundary_refs:
            type: array
            minItems: 1
            items:
              type: string
              minLength: 1
          consent_or_emergency_review_ref:
            type: string
            minLength: 1
          council_resolution_ref:
            type: string
            minLength: 1
          guardian_boundary_ref:
            type: string
            minLength: 1
          long_term_review_schedule_ref:
            type: string
            minLength: 1
          escalation_continuity_ref:
            type: string
            minLength: 1
    output:
      schema_ref: self_model_care_trustee_handoff_receipt
  validate_care_trustee_handoff_receipt:
    summary: Fail closed unless external care/trustee handoff remains digest-only, boundary-and-evidence-routing-only, long-term review bound, and raw-payload redacted.
    input:
      schema_ref: self_model_care_trustee_handoff_receipt
    output:
      inline_schema:
        type: object
        required:
          - ok
          - long_term_review_required
          - boundary_only_review
          - external_adjudication_required
          - os_trustee_role_allowed
          - responsibility_commit_digest_bound
        properties:
          ok:
            type: boolean
          long_term_review_required:
            type: boolean
          boundary_only_review:
            type: boolean
          external_adjudication_required:
            type: boolean
          os_trustee_role_allowed:
            type: boolean
          responsibility_commit_digest_bound:
            type: boolean
  build_value_generation_receipt:
    summary: Bind self-authored value-generation candidates without external veto, forced stability lock, or immediate writeback.
    input:
      inline_schema:
        type: object
        required:
          - observation
          - candidate_value_refs
          - continuity_context_refs
          - self_authorship_ref
          - self_consent_ref
          - council_review_ref
          - guardian_boundary_ref
        properties:
          observation:
            schema_ref: self_model_observation
          candidate_value_refs:
            type: array
            minItems: 1
            items:
              type: string
              minLength: 1
          continuity_context_refs:
            type: array
            minItems: 1
            items:
              type: string
              minLength: 1
          self_authorship_ref:
            type: string
            minLength: 1
          self_consent_ref:
            type: string
            minLength: 1
          council_review_ref:
            type: string
            minLength: 1
          guardian_boundary_ref:
            type: string
            minLength: 1
    output:
      schema_ref: self_model_value_generation_receipt
  validate_value_generation_receipt:
    summary: Fail closed unless new value candidates remain self-authored, autonomy-preserving, and not written back.
    input:
      schema_ref: self_model_value_generation_receipt
    output:
      inline_schema:
        type: object
        required:
          - ok
          - self_authored
          - autonomy_preserved
          - requires_future_self_acceptance
          - accepted_for_writeback
        properties:
          ok:
            type: boolean
          self_authored:
            type: boolean
          autonomy_preserved:
            type: boolean
          requires_future_self_acceptance:
            type: boolean
          accepted_for_writeback:
            type: boolean
  build_value_autonomy_review_receipt:
    summary: Bind witness and Council review to self-authored value generation while preserving candidate autonomy and future self acceptance.
    input:
      inline_schema:
        type: object
        required:
          - generation_receipt
          - witness_evidence_refs
          - self_authorship_continuation_ref
          - council_review_ref
          - guardian_boundary_ref
        properties:
          generation_receipt:
            schema_ref: self_model_value_generation_receipt
          witness_evidence_refs:
            type: array
            minItems: 1
            items:
              type: string
              minLength: 1
          self_authorship_continuation_ref:
            type: string
            minLength: 1
          council_review_ref:
            type: string
            minLength: 1
          guardian_boundary_ref:
            type: string
            minLength: 1
    output:
      schema_ref: self_model_value_autonomy_review_receipt
  validate_value_autonomy_review_receipt:
    summary: Fail closed unless witness/Council review remains advisory, digest-only, non-vetoing, and candidate-preserving.
    input:
      schema_ref: self_model_value_autonomy_review_receipt
    output:
      inline_schema:
        type: object
        required:
          - ok
          - candidate_set_unchanged
          - self_authorship_preserved
          - autonomy_preserved
          - future_self_acceptance_remains_required
          - review_commit_digest_bound
        properties:
          ok:
            type: boolean
          candidate_set_unchanged:
            type: boolean
          self_authorship_preserved:
            type: boolean
          autonomy_preserved:
            type: boolean
          future_self_acceptance_remains_required:
            type: boolean
          review_commit_digest_bound:
            type: boolean
  build_value_acceptance_receipt:
    summary: Bind future-self acceptance before moving a self-authored value candidate into bounded writeback.
    input:
      inline_schema:
        type: object
        required:
          - generation_receipt
          - accepted_value_refs
          - continuity_recheck_refs
          - future_self_acceptance_ref
          - council_resolution_ref
          - guardian_boundary_ref
          - writeback_ref
          - post_acceptance_snapshot_ref
        properties:
          generation_receipt:
            schema_ref: self_model_value_generation_receipt
          accepted_value_refs:
            type: array
            minItems: 1
            items:
              type: string
              minLength: 1
          continuity_recheck_refs:
            type: array
            minItems: 1
            items:
              type: string
              minLength: 1
          future_self_acceptance_ref:
            type: string
            minLength: 1
          council_resolution_ref:
            type: string
            minLength: 1
          guardian_boundary_ref:
            type: string
            minLength: 1
          writeback_ref:
            type: string
            minLength: 1
          post_acceptance_snapshot_ref:
            type: string
            minLength: 1
    output:
      schema_ref: self_model_value_acceptance_receipt
  validate_value_acceptance_receipt:
    summary: Fail closed unless future-self acceptance, boundary-only review, and digest-bound writeback are preserved.
    input:
      schema_ref: self_model_value_acceptance_receipt
    output:
      inline_schema:
        type: object
        required:
          - ok
          - future_self_acceptance_satisfied
          - accepted_for_writeback
          - boundary_only_review
          - writeback_digest_bound
        properties:
          ok:
            type: boolean
          future_self_acceptance_satisfied:
            type: boolean
          accepted_for_writeback:
            type: boolean
          boundary_only_review:
            type: boolean
          writeback_digest_bound:
            type: boolean
  build_value_reassessment_receipt:
    summary: Bind future-self reevaluation before retiring an accepted value from active writeback while retaining archived history.
    input:
      inline_schema:
        type: object
        required:
          - acceptance_receipt
          - retired_value_refs
          - continuity_recheck_refs
          - future_self_reevaluation_ref
          - council_resolution_ref
          - guardian_boundary_ref
          - retirement_writeback_ref
          - post_reassessment_snapshot_ref
          - archival_snapshot_ref
        properties:
          acceptance_receipt:
            schema_ref: self_model_value_acceptance_receipt
          retired_value_refs:
            type: array
            minItems: 1
            items:
              type: string
              minLength: 1
          continuity_recheck_refs:
            type: array
            minItems: 1
            items:
              type: string
              minLength: 1
          future_self_reevaluation_ref:
            type: string
            minLength: 1
          council_resolution_ref:
            type: string
            minLength: 1
          guardian_boundary_ref:
            type: string
            minLength: 1
          retirement_writeback_ref:
            type: string
            minLength: 1
          post_reassessment_snapshot_ref:
            type: string
            minLength: 1
          archival_snapshot_ref:
            type: string
            minLength: 1
    output:
      schema_ref: self_model_value_reassessment_receipt
  validate_value_reassessment_receipt:
    summary: Fail closed unless future-self reevaluation, boundary-only review, active writeback retirement, and archived history are preserved.
    input:
      schema_ref: self_model_value_reassessment_receipt
    output:
      inline_schema:
        type: object
        required:
          - ok
          - future_self_reevaluation_satisfied
          - active_writeback_retired
          - historical_value_archived
          - boundary_only_review
          - retirement_digest_bound
        properties:
          ok:
            type: boolean
          future_self_reevaluation_satisfied:
            type: boolean
          active_writeback_retired:
            type: boolean
          historical_value_archived:
            type: boolean
          boundary_only_review:
            type: boolean
          retirement_digest_bound:
            type: boolean
  build_value_timeline_receipt:
    summary: Bind value generation, future-self acceptance, and later retirement into one append-only lineage timeline.
    input:
      inline_schema:
        type: object
        required:
          - generation_receipt
          - acceptance_receipts
          - reassessment_receipts
          - continuity_audit_ref
          - council_resolution_ref
          - guardian_archive_ref
        properties:
          generation_receipt:
            schema_ref: self_model_value_generation_receipt
          acceptance_receipts:
            type: array
            minItems: 1
            items:
              schema_ref: self_model_value_acceptance_receipt
          reassessment_receipts:
            type: array
            minItems: 1
            items:
              schema_ref: self_model_value_reassessment_receipt
          continuity_audit_ref:
            type: string
            minLength: 1
          council_resolution_ref:
            type: string
            minLength: 1
          guardian_archive_ref:
            type: string
            minLength: 1
    output:
      schema_ref: self_model_value_timeline_receipt
  validate_value_timeline_receipt:
    summary: Fail closed unless the value lineage is chronological, digest-bound, archive-retained, and active/retired sets are disjoint.
    input:
      schema_ref: self_model_value_timeline_receipt
    output:
      inline_schema:
        type: object
        required:
          - ok
          - chronological_event_order_enforced
          - active_retired_disjoint
          - archive_retention_required
          - boundary_only_review
          - timeline_commit_digest_bound
        properties:
          ok:
            type: boolean
          chronological_event_order_enforced:
            type: boolean
          active_retired_disjoint:
            type: boolean
          archive_retention_required:
            type: boolean
          boundary_only_review:
            type: boolean
          timeline_commit_digest_bound:
            type: boolean
  history:
    summary: Return the most recent self-model snapshots for one monitor instance.
    input:
      inline_schema:
        type: object
        required:
          - count
        properties:
          count:
            type: integer
            minimum: 1
    output:
      inline_schema:
        type: array
        items:
          schema_ref: self_model
invariants:
  - abrupt_change_threshold is fixed at 0.35 in the reference runtime
  - values, goals, and traits contribute equally to divergence
  - update appends snapshots monotonically within a single monitor instance
  - calibration receipts can advise Council review but cannot assert external truth or write back changes without self acceptance
  - pathology escalation receipts can preserve risk signals and route external medical/legal handoff, but cannot diagnose, force correction, or write back SelfModel changes inside the OS
  - value generation receipts preserve self-authored candidate values without external veto or immediate writeback
  - value autonomy review receipts let witness/Council evidence remain advisory and digest-only while preserving candidate sets, self authorship, and future self acceptance
  - value acceptance receipts can write back only accepted candidate refs after future self acceptance and boundary-only review
  - value reassessment receipts retire only accepted value refs while retaining archived history
  - value timeline receipts keep generated, accepted, and retired value events append-only and digest-bound without raw value payload storage
