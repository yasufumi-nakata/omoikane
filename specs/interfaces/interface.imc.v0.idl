idl_version: 1
kind: service
namespace: interface.imc.v0
service: InterMindChannelService
summary: Canonical L6 contract for bounded inter-mind communication with disclosure floors and emergency disconnect.
imports:
  imc_session: ../schemas/imc_session.schema
  imc_handshake: ../schemas/imc_handshake.schema
  imc_message: ../schemas/imc_message.schema
  imc_memory_glimpse_receipt: ../schemas/imc_memory_glimpse_receipt.schema
  imc_memory_glimpse_reconsent_receipt: ../schemas/imc_memory_glimpse_reconsent_receipt.schema
  imc_merge_thought_window_policy_verifier_receipt: ../schemas/imc_merge_thought_window_policy_verifier_receipt.schema
  imc_merge_thought_ethics_receipt: ../schemas/imc_merge_thought_ethics_receipt.schema
  memory_crystal_manifest: ../schemas/memory_crystal_manifest.schema
operations:
  open_session:
    summary: Open one fail-closed IMC session after identity attestation, disclosure-floor derivation, and forward-secrecy key exchange.
    input:
      inline_schema:
        type: object
        required:
          - initiator_id
          - peer_id
          - mode
          - initiator_template
          - peer_template
          - peer_attested
          - forward_secrecy
        properties:
          initiator_id:
            type: string
            minLength: 1
          peer_id:
            type: string
            minLength: 1
          mode:
            type: string
            enum:
              - text
              - voice
              - presence
              - affect_share
              - memory_glimpse
              - co_imagination
              - merge_thought
          initiator_template:
            type: object
          peer_template:
            type: object
          peer_attested:
            type: boolean
            const: true
          forward_secrecy:
            type: boolean
            const: true
          council_witnessed:
            type: boolean
            default: false
    output:
      schema_ref: imc_session
    guarantees:
      - peer_attested and forward_secrecy must both be true or the session must fail closed
      - memory_glimpse, co_imagination, and merge_thought must require council witness
      - derived disclosure_profile must adopt the narrower side and never leak sealed_fields
  send:
    summary: Deliver one IMC message through the disclosure gate and persist only summary plus payload digest.
    input:
      inline_schema:
        type: object
        required:
          - session_id
          - sender_id
          - summary
          - payload
        properties:
          session_id:
            type: string
            minLength: 8
          sender_id:
            type: string
            minLength: 1
          summary:
            type: string
            minLength: 1
          payload:
            type: object
    output:
      schema_ref: imc_message
    guarantees:
      - delivered_fields must remain within mode_allowed_fields
      - redacted_fields must include every sealed or out-of-floor field
      - continuity artifacts must store summary plus payload digest, not raw content
  seal_memory_glimpse_receipt:
    summary: Seal one Council-witnessed digest-only receipt for a bounded memory_glimpse exchange.
    input:
      inline_schema:
        type: object
        required:
          - session_id
          - message
          - source_manifest
          - selected_segment_ids
          - council_session_ref
          - council_resolution_ref
          - guardian_attestation_ref
        properties:
          session_id:
            type: string
            minLength: 8
          message:
            schema_ref: imc_message
          source_manifest:
            schema_ref: memory_crystal_manifest
          selected_segment_ids:
            type: array
            minItems: 1
            items:
              type: string
              minLength: 1
          council_session_ref:
            type: string
            minLength: 1
          council_resolution_ref:
            type: string
            minLength: 1
          guardian_attestation_ref:
            type: string
            minLength: 1
    output:
      schema_ref: imc_memory_glimpse_receipt
    guarantees:
      - operation only applies to memory_glimpse sessions that already required and received Council witness
      - receipt must bind selected MemoryCrystal segment digests and the IMC message payload digest
      - receipt must not store raw MemoryCrystal payloads or raw message payloads
      - witness digest must bind Council session, Council resolution, Guardian attestation, message id, and source manifest digest
  seal_memory_glimpse_reconsent_receipt:
    summary: Seal one timeboxed revoke/re-consent receipt for a bounded memory_glimpse disclosure.
    input:
      inline_schema:
        type: object
        required:
          - session_id
          - memory_glimpse_receipt
          - requested_by
          - expires_after_seconds
          - revoke_after_event_ref
          - council_reconsent_ref
          - guardian_attestation_ref
        properties:
          session_id:
            type: string
            minLength: 8
          memory_glimpse_receipt:
            schema_ref: imc_memory_glimpse_receipt
          requested_by:
            type: string
            minLength: 1
          expires_after_seconds:
            type: integer
            minimum: 1
            maximum: 86400
          revoke_after_event_ref:
            type: string
            minLength: 1
          council_reconsent_ref:
            type: string
            minLength: 1
          guardian_attestation_ref:
            type: string
            minLength: 1
    output:
      schema_ref: imc_memory_glimpse_reconsent_receipt
    guarantees:
      - operation only applies to a sealed memory_glimpse receipt from the same IMC session
      - participant withdrawal must bind to an emergency-disconnect-compatible revocation event
      - consent window must be timeboxed to at most 86400 seconds and require Council re-consent before redisclosure
      - receipt must not store raw MemoryCrystal payloads, raw message payloads, or raw re-consent payloads
  probe_merge_thought_window_policy_verifier_endpoint:
    summary: Probe one live HTTP merge_thought window-policy verifier and return a timeout-budget-bound digest-only receipt.
    input:
      inline_schema:
        type: object
        required:
          - verifier_endpoint
          - verifier_ref
          - verifier_authority_ref
          - jurisdiction
        properties:
          verifier_endpoint:
            type: string
            pattern: "^https?://"
          verifier_ref:
            type: string
            minLength: 1
          verifier_authority_ref:
            type: string
            minLength: 1
          jurisdiction:
            type: string
            minLength: 1
          timeout_ms:
            type: integer
            minimum: 1
            maximum: 250
            default: 250
    output:
      schema_ref: imc_merge_thought_window_policy_verifier_receipt
    guarantees:
      - request_timeout_ms must be at most 250 and bound into the verifier receipt digest
      - endpoint response must match the expected policy registry, signer roster, verifier ref, authority ref, jurisdiction, and signature digest
      - raw policy, verifier, and response-signature payloads must not be stored
  seal_merge_thought_ethics_receipt:
    summary: Seal one Federation Council, EthicsCommittee, and Guardian gate receipt before a merge_thought session can proceed into a collective merge.
    input:
      inline_schema:
        type: object
        required:
          - session_id
          - message
          - collective_ref
          - council_session_ref
          - federation_council_ref
          - ethics_decision_ref
          - guardian_attestation_ref
        properties:
          session_id:
            type: string
            minLength: 8
          message:
            schema_ref: imc_message
          collective_ref:
            type: string
            minLength: 1
          council_session_ref:
            type: string
            minLength: 1
          federation_council_ref:
            type: string
            minLength: 1
          ethics_decision_ref:
            type: string
            minLength: 1
          guardian_attestation_ref:
            type: string
            minLength: 1
          requested_merge_window_seconds:
            type: integer
            minimum: 1
            maximum: 10
          window_policy_verifier_receipts:
            type: array
            minItems: 2
            items:
              schema_ref: imc_merge_thought_window_policy_verifier_receipt
    output:
      schema_ref: imc_merge_thought_ethics_receipt
    guarantees:
      - operation only applies to merge_thought sessions that already require and received Council witness
      - receipt must bind Federation Council, EthicsCommittee, and Guardian refs before the session can be treated as a collective merge
      - receipt must bind the distinct collective target, 10 second max merge window, emergency disconnect requirement, private recovery requirement, and post-disconnect identity confirmation requirement
      - 10 second merge window must be derived from merge-thought-window-policy-authority-v1 policy registry digest, signer roster digest, live HTTP verifier receipt quorum digest, 250ms-bounded verifier request timeout evidence, verifier network response digest set, and policy signature digest
      - receipt must not store raw thought payloads, raw message payloads, raw window policy payloads, raw verifier payloads, or raw response signature payloads
  emergency_disconnect:
    summary: Let either participant close the session unilaterally before any downstream notice is attempted.
    input:
      inline_schema:
        type: object
        required:
          - session_id
          - requested_by
          - reason
        properties:
          session_id:
            type: string
            minLength: 8
          requested_by:
            type: string
            minLength: 1
          reason:
            type: string
            minLength: 1
    output:
      inline_schema:
        type: object
        required:
          - session_id
          - recorded_at
          - requested_by
          - reason
          - status
          - key_state
          - close_committed_before_notice
          - council_notified_async
          - audit_event_ref
        properties:
          session_id:
            type: string
            minLength: 8
          recorded_at:
            type: string
            format: date-time
          requested_by:
            type: string
            minLength: 1
          reason:
            type: string
            minLength: 1
          status:
            type: string
            const: closed
          key_state:
            type: string
            const: revoked
          close_committed_before_notice:
            type: boolean
            const: true
          council_notified_async:
            type: boolean
          audit_event_ref:
            type: string
            minLength: 1
  snapshot:
    summary: Read the current IMC session state including handshake metadata and digest-only message summaries.
    input:
      inline_schema:
        type: object
        required:
          - session_id
        properties:
          session_id:
            type: string
            minLength: 8
    output:
      schema_ref: imc_session
events:
  imc.session_opened:
    payload:
      schema_ref: imc_handshake
  imc.message_sent:
    payload:
      schema_ref: imc_message
  imc.memory_glimpse_receipt_sealed:
    payload:
      schema_ref: imc_memory_glimpse_receipt
  imc.memory_glimpse_reconsent_receipt_sealed:
    payload:
      schema_ref: imc_memory_glimpse_reconsent_receipt
  imc.merge_thought_ethics_receipt_sealed:
    payload:
      schema_ref: imc_merge_thought_ethics_receipt
  imc.session_closed:
    payload:
      inline_schema:
        type: object
        required:
          - session_id
          - status
          - key_state
          - close_committed_before_notice
        properties:
          session_id:
            type: string
            minLength: 8
          status:
            type: string
            const: closed
          key_state:
            type: string
            const: revoked
          close_committed_before_notice:
            type: boolean
            const: true
