idl_version: 1
kind: service
namespace: kernel.continuity.v0
service: ContinuityLedgerService
summary: Append-only continuity evidence logging and verification.
imports:
  continuity_log_entry: ../schemas/continuity_log_entry.schema
  continuity_public_verification_bundle: ../schemas/continuity_public_verification_bundle.schema
operations:
  read_profile:
    summary: Return the active chain and signature profile for this continuity ledger.
    output:
      inline_schema:
        type: object
        required:
          - genesis_hash
          - chain_algorithm
          - signature_algorithm
          - required_signature_roles
        properties:
          genesis_hash:
            type: string
          chain_algorithm:
            type: string
            enum:
              - sha256
          signature_algorithm:
            type: string
            enum:
              - hmac-sha256
          required_signature_roles:
            type: object
            additionalProperties:
              type: array
              items:
                type: string
  append_entry:
    summary: Append one continuity event into the ledger.
    input:
      schema_ref: continuity_log_entry
    output:
      inline_schema:
        type: object
        required:
          - accepted
          - entry_id
          - entry_hash
        properties:
          accepted:
            type: boolean
          entry_id:
            type: string
          entry_hash:
            type: string
  verify_chain:
    summary: Verify hash continuity and required signatures for a sequence.
    input:
      inline_schema:
        type: object
        required:
          - entries
        properties:
          entries:
            type: array
            items:
              schema_ref: continuity_log_entry
    output:
      inline_schema:
        type: object
        required:
          - status
          - verified_count
          - chain_algorithm
          - signature_algorithm
        properties:
          status:
            type: string
            enum:
              - pass
              - fail
              - uncertain
          verified_count:
            type: integer
          chain_algorithm:
            type: string
            enum:
              - sha256
          signature_algorithm:
            type: string
            enum:
              - hmac-sha256
          first_error:
            type: string
  compile_public_verification_bundle:
    summary: Compile a digest-only public verification bundle for the ledger head and verifier-key roster.
    output:
      schema_ref: continuity_public_verification_bundle
  validate_public_verification_bundle:
    summary: Verify that a public verification bundle still matches the ledger head, key roster, and digest-only signature evidence.
    input:
      schema_ref: continuity_public_verification_bundle
    output:
      inline_schema:
        type: object
        required:
          - ok
          - profile_id
          - public_verification_ready
          - key_roster_bound
          - ledger_head_bound
          - entry_verification_bound
          - raw_key_material_excluded
          - raw_signature_material_excluded
        properties:
          ok:
            type: boolean
          profile_id:
            type: string
          public_verification_ready:
            type: boolean
          key_roster_bound:
            type: boolean
          ledger_head_bound:
            type: boolean
          entry_verification_bound:
            type: boolean
          raw_key_material_excluded:
            type: boolean
          raw_signature_material_excluded:
            type: boolean
          verified_entry_count:
            type: integer
          errors:
            type: array
            items:
              type: string
  mark_uncertain_interval:
    summary: Mark an interval as continuity-uncertain after verification failure.
    input:
      inline_schema:
        type: object
        required:
          - identity_id
          - start_ref
          - end_ref
        properties:
          identity_id:
            type: string
          start_ref:
            type: string
          end_ref:
            type: string
    output:
      inline_schema:
        type: object
        required:
          - status
        properties:
          status:
            type: string
            enum:
              - recorded
compatibility:
  stability: bootstrap
