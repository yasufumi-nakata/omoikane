idl_version: 1
kind: service
namespace: kernel.identity.v0
service: IdentityRegistryService
summary: Identity lifecycle contract for the reference runtime.
imports:
  identity_record: ../schemas/identity_record.schema
  identity_confirmation_profile: ../schemas/identity_confirmation_profile.schema
operations:
  create:
    summary: Create a new identity record from explicit consent.
    input:
      inline_schema:
        type: object
        required:
          - human_consent_proof
        properties:
          human_consent_proof:
            type: string
          metadata:
            type: object
    output:
      schema_ref: identity_record
  fork:
    summary: Fork an identity only with triple approval.
    input:
      inline_schema:
        type: object
        required:
          - identity_id
          - justification
          - approvals
        properties:
          identity_id:
            type: string
          justification:
            type: string
          approvals:
            type: object
            required:
              - self_signed
              - third_party_signed
              - legal_signed
            properties:
              self_signed:
                type: boolean
              third_party_signed:
                type: boolean
              legal_signed:
                type: boolean
    output:
      schema_ref: identity_record
  pause:
    summary: Pause an active identity at self request or by Council resolution.
    input:
      inline_schema:
        type: object
        required:
          - identity_id
          - requested_by
          - reason
        properties:
          identity_id:
            type: string
          requested_by:
            type: string
            enum:
              - self
              - council
          reason:
            type: string
            minLength: 1
          council_resolution_ref:
            type: string
            minLength: 1
    output:
      schema_ref: identity_record
  resume:
    summary: Resume a paused identity only with explicit self proof.
    input:
      inline_schema:
        type: object
        required:
          - identity_id
          - self_proof
        properties:
          identity_id:
            type: string
          self_proof:
            type: string
            minLength: 1
    output:
      schema_ref: identity_record
  confirm_active_transition:
    summary: Evaluate the Ascending to Active identity confirmation profile before activation.
    policy_refs:
      - multidimensional-identity-confirmation-v1
      - identity-self-report-witness-consistency-v1
      - identity-witness-registry-binding-v1
    input:
      inline_schema:
        type: object
        required:
          - identity_id
          - consent_ref
          - scheduler_stage_ref
          - episodic_recall_ref
          - self_model_ref
          - self_report
          - witness_receipts
          - episodic_recall_score
          - self_model_alignment_score
        properties:
          identity_id:
            type: string
            minLength: 1
          consent_ref:
            type: string
            minLength: 1
          scheduler_stage_ref:
            type: string
            minLength: 1
          episodic_recall_ref:
            type: string
            minLength: 1
          self_model_ref:
            type: string
            minLength: 1
          self_report:
            type: object
            required:
              - report_ref
              - statement
              - continuity_score
            properties:
              report_ref:
                type: string
                minLength: 1
              statement:
                type: string
                minLength: 1
              continuity_score:
                type: number
                minimum: 0
                maximum: 1
          witness_receipts:
            type: array
            minItems: 1
            items:
              type: object
              required:
                - witness_id
                - witness_role
                - observation_ref
                - alignment_score
              properties:
                witness_id:
                  type: string
                  minLength: 1
                witness_role:
                  type: string
                  minLength: 1
                observation_ref:
                  type: string
                  minLength: 1
                registry_entry_ref:
                  type: string
                  minLength: 1
                verifier_key_ref:
                  type: string
                  minLength: 1
                revocation_ref:
                  type: string
                  minLength: 1
                registry_status:
                  type: string
                  enum:
                    - current
                    - stale
                    - unknown
                revocation_status:
                  type: string
                  enum:
                    - not-revoked
                    - revoked
                    - unknown
                alignment_score:
                  type: number
                  minimum: 0
                  maximum: 1
          witness_registry_ref:
            type: string
            minLength: 1
          episodic_recall_score:
            type: number
            minimum: 0
            maximum: 1
          self_model_alignment_score:
            type: number
            minimum: 0
            maximum: 1
    output:
      schema_ref: identity_confirmation_profile
  terminate:
    summary: Terminate an identity only with self proof.
    input:
      inline_schema:
        type: object
        required:
          - identity_id
          - self_proof
        properties:
          identity_id:
            type: string
          self_proof:
            type: string
    output:
      schema_ref: identity_record
compatibility:
  stability: bootstrap
  notes:
    - status is fixed to active, paused, or terminated in the reference runtime.
    - council-initiated pause requires council_resolution_ref, while resume requires explicit self_proof.
    - pause_state preserves the most recent pause/resume cycle as machine-readable audit metadata.
    - confirm_active_transition uses a fixed multidimensional profile with episodic recall, self-model alignment, subjective self-report, and third-party witness quorum.
    - active transition also requires identity-self-report-witness-consistency-v1, which binds the self-report evidence digest, accepted witness digest set, required roles, and bounded score delta to the same continuity subject.
    - accepted witnesses must also bind current witness registry entries, verifier key refs, and not-revoked revocation refs via identity-witness-registry-binding-v1; raw registry payloads are not stored.
