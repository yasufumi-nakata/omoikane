idl_version: 1
kind: service
namespace: mind.memory_replication.v0
service: MemoryReplicationService
summary: >
  Deterministic four-target MemoryCrystal replication contract with plaintext
  metadata plus encrypted payload transfer, random-block Merkle audit, and
  council-escalated reconciliation plus threshold key succession recovery with
  multi-jurisdiction signer roster authority, long-term media renewal proof, and
  digest-only media registry verifier quorum.
imports:
  memory_crystal_manifest: ../schemas/memory_crystal_manifest.schema
  memory_replication_session: ../schemas/memory_replication_session.schema
operations:
  replicate:
    summary: Build one quorum-bound replication session from a validated MemoryCrystal manifest.
    input:
      inline_schema:
        type: object
        additionalProperties: false
        required:
          - identity_id
          - manifest
        properties:
          identity_id:
            type: string
            minLength: 1
          manifest:
            schema_ref: memory_crystal_manifest
    output:
      schema_ref: memory_replication_session
    guarantees:
      - source manifest must remain append-only and digest-bound throughout replication
      - required_targets must equal primary, mirror, coldstore, trustee
      - immediate targets must be primary and mirror, while coldstore and trustee remain delayed targets
      - verification audit must compare all targets and bind one consensus Merkle root before reconcile
      - any mismatch must escalate to council with one bounded rollback point and resync requirement
      - temporary identity-key loss must produce a guardian-quorum key_succession receipt without storing raw key or shard material
      - key_succession must bind successor-key preparation to a JP-13 primary signer roster policy with identity-guardian and integrity-guardian signatures, without storing raw roster payload
      - key_succession must additionally bind JP-13 and SG-01 signer roster policies into a digest-only multi-jurisdiction quorum without storing raw jurisdiction policy payloads
      - multi-jurisdiction key_succession quorum threshold must be bound to a digest-only policy registry and authority signature quorum before complete status is allowed
      - long_term_media_renewal must bind coldstore and trustee copies to renewed media proofs, readback digests, a 3650-day refresh interval, and a 1000-year target horizon without storing raw media or readback payloads
      - long_term_media_renewal.refresh_window must bind the source proof set to current-not-revoked status, 90-day revocation checks, next refresh refs, and fail-closed stale/revoked proof handling without storing raw revocation or refresh payloads
      - long_term_media_renewal.refresh_window.registry_verifier must bind JP-13 and SG-01 registry response digests, response signatures, timeout budget, and quorum digest to the source proof set without storing raw registry or response payloads
      - long_term_media_renewal.refresh_window.registry_verifier.endpoint_certificate_lifecycle must bind each registry endpoint to current certificate fingerprints, 3-generation chain digests, OCSP/revocation digests, renewal and previous-retirement evidence, and the registry response quorum without storing raw certificate payloads
      - long_term_media_renewal.refresh_window.registry_verifier.endpoint_certificate_lifecycle must additionally bind CT-style readback, two-log quorum, SCT timestamp window, and SCT policy authority evidence without storing raw CT log or SCT authority payloads
  validate_session:
    summary: Validate one replication session against the fixed quorum and reconciliation policy.
    input:
      inline_schema:
        type: object
        additionalProperties: false
        required:
          - session
        properties:
          session:
            schema_ref: memory_replication_session
    output:
      inline_schema:
        type: object
        additionalProperties: false
        required:
          - ok
          - immediate_target_ids
          - delayed_target_ids
          - consensus_target_ids
          - mismatch_target_ids
          - quorum_ok
          - council_escalated
          - resync_required
          - manifest_digest_bound
          - key_succession_bound
          - key_succession_guardian_quorum_ok
          - key_succession_threshold_ok
          - key_succession_signer_roster_policy_bound
          - key_succession_signer_roster_quorum_ok
          - key_succession_quorum_threshold_policy_bound
          - key_succession_quorum_threshold_policy_ok
          - long_term_media_renewal_bound
          - long_term_media_renewal_targets
          - long_term_media_renewal_readback_ok
          - long_term_media_renewal_refresh_interval_days
          - long_term_media_renewal_target_horizon_years
          - long_term_media_renewal_refresh_window_bound
          - long_term_media_renewal_source_proof_current
          - long_term_media_renewal_revocation_check_ok
          - long_term_media_renewal_revocation_check_window_days
          - long_term_media_renewal_registry_verifier_bound
          - long_term_media_renewal_registry_verifier_quorum_ok
          - long_term_media_renewal_registry_endpoint_certificate_lifecycle_bound
          - long_term_media_renewal_registry_endpoint_certificate_freshness_ok
          - long_term_media_renewal_registry_endpoint_certificate_quorum_ok
          - long_term_media_renewal_registry_endpoint_certificate_ct_log_bound
          - long_term_media_renewal_registry_endpoint_certificate_ct_log_quorum_ok
          - long_term_media_renewal_registry_endpoint_certificate_sct_policy_authority_bound
          - long_term_media_renewal_registry_endpoint_certificate_chain_generation_count
          - raw_key_material_stored
          - raw_shard_material_stored
          - raw_signer_roster_payload_stored
          - raw_jurisdiction_policy_payload_stored
          - raw_quorum_threshold_policy_payload_stored
          - raw_media_payload_stored
          - raw_media_readback_payload_stored
          - raw_media_revocation_payload_stored
          - raw_media_refresh_payload_stored
          - raw_media_registry_payload_stored
          - raw_media_registry_response_payload_stored
          - raw_media_registry_endpoint_certificate_payload_stored
          - raw_media_registry_endpoint_certificate_freshness_payload_stored
          - raw_media_registry_endpoint_certificate_lifecycle_payload_stored
          - raw_media_registry_endpoint_certificate_ct_log_payload_stored
          - raw_media_registry_endpoint_certificate_sct_policy_authority_payload_stored
          - errors
        properties:
          ok:
            type: boolean
          immediate_target_ids:
            type: array
            items:
              type: string
              minLength: 1
          delayed_target_ids:
            type: array
            items:
              type: string
              minLength: 1
          consensus_target_ids:
            type: array
            items:
              type: string
              minLength: 1
          mismatch_target_ids:
            type: array
            items:
              type: string
              minLength: 1
          quorum_ok:
            type: boolean
          council_escalated:
            type: boolean
          resync_required:
            type: boolean
          manifest_digest_bound:
            type: boolean
          key_succession_bound:
            type: boolean
          key_succession_guardian_quorum_ok:
            type: boolean
          key_succession_threshold_ok:
            type: boolean
          key_succession_signer_roster_policy_bound:
            type: boolean
          key_succession_signer_roster_quorum_ok:
            type: boolean
          key_succession_multi_jurisdiction_signer_roster_quorum_bound:
            type: boolean
          key_succession_multi_jurisdiction_signer_roster_quorum_ok:
            type: boolean
          key_succession_quorum_threshold_policy_bound:
            type: boolean
          key_succession_quorum_threshold_policy_ok:
            type: boolean
          long_term_media_renewal_bound:
            type: boolean
          long_term_media_renewal_targets:
            type: array
            items:
              type: string
              minLength: 1
          long_term_media_renewal_readback_ok:
            type: boolean
          long_term_media_renewal_refresh_interval_days:
            type: integer
          long_term_media_renewal_target_horizon_years:
            type: integer
          long_term_media_renewal_refresh_window_bound:
            type: boolean
          long_term_media_renewal_source_proof_current:
            type: boolean
          long_term_media_renewal_revocation_check_ok:
            type: boolean
          long_term_media_renewal_revocation_check_window_days:
            type: integer
          long_term_media_renewal_registry_verifier_bound:
            type: boolean
          long_term_media_renewal_registry_verifier_quorum_ok:
            type: boolean
          long_term_media_renewal_registry_endpoint_certificate_lifecycle_bound:
            type: boolean
          long_term_media_renewal_registry_endpoint_certificate_freshness_ok:
            type: boolean
          long_term_media_renewal_registry_endpoint_certificate_quorum_ok:
            type: boolean
          long_term_media_renewal_registry_endpoint_certificate_ct_log_bound:
            type: boolean
          long_term_media_renewal_registry_endpoint_certificate_ct_log_quorum_ok:
            type: boolean
          long_term_media_renewal_registry_endpoint_certificate_sct_policy_authority_bound:
            type: boolean
          long_term_media_renewal_registry_endpoint_certificate_chain_generation_count:
            type: integer
          raw_key_material_stored:
            type: boolean
          raw_shard_material_stored:
            type: boolean
          raw_signer_roster_payload_stored:
            type: boolean
          raw_jurisdiction_policy_payload_stored:
            type: boolean
          raw_quorum_threshold_policy_payload_stored:
            type: boolean
          raw_media_payload_stored:
            type: boolean
          raw_media_readback_payload_stored:
            type: boolean
          raw_media_revocation_payload_stored:
            type: boolean
          raw_media_refresh_payload_stored:
            type: boolean
          raw_media_registry_payload_stored:
            type: boolean
          raw_media_registry_response_payload_stored:
            type: boolean
          raw_media_registry_endpoint_certificate_payload_stored:
            type: boolean
          raw_media_registry_endpoint_certificate_freshness_payload_stored:
            type: boolean
          raw_media_registry_endpoint_certificate_lifecycle_payload_stored:
            type: boolean
          raw_media_registry_endpoint_certificate_ct_log_payload_stored:
            type: boolean
          raw_media_registry_endpoint_certificate_sct_policy_authority_payload_stored:
            type: boolean
          errors:
            type: array
            items:
              type: string
              minLength: 1
events:
  mind.memory.replication_reconciled:
    payload:
      schema_ref: memory_replication_session
