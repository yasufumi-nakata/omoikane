idl_version: 1
kind: service
namespace: kernel.broker.v0
service: SubstrateBrokerService
summary: Deterministic L1 substrate broker contract for neutrality-aware selection and bounded migration handoff.
imports:
  substrate_allocation: ../schemas/substrate_allocation.schema
  substrate_attestation: ../schemas/substrate_attestation.schema
  standby_health_probe: ../schemas/standby_health_probe.schema
  substrate_attestation_chain: ../schemas/substrate_attestation_chain.schema
  substrate_dual_allocation_window: ../schemas/substrate_dual_allocation_window.schema
  substrate_attestation_stream: ../schemas/substrate_attestation_stream.schema
  substrate_transfer: ../schemas/substrate_transfer.schema
  substrate_release: ../schemas/substrate_release.schema
  energy_floor: ../schemas/energy_floor.schema
operations:
  list_registry:
    summary: List broker-manageable substrates with current capability, health, and neutrality rotation index.
    input:
      inline_schema:
        type: object
        additionalProperties: false
        properties: {}
    output:
      inline_schema:
        type: object
        required:
          - policy_id
          - minimum_health_score
          - neutrality_window
          - registry
        properties:
          policy_id:
            type: string
          minimum_health_score:
            type: number
            minimum: 0
            maximum: 1
          neutrality_window:
            type: integer
            minimum: 1
          registry:
            type: array
            minItems: 1
            items:
              type: object
              required:
                - substrate_id
                - substrate_kind
                - capability_score
                - health_score
                - attestation_valid
                - energy_capacity_jps
                - substrate_kind_neutrality_index
              properties:
                substrate_id:
                  type: string
                  minLength: 1
                substrate_kind:
                  type: string
                  minLength: 1
                capability_score:
                  type: number
                  minimum: 0
                  maximum: 1
                health_score:
                  type: number
                  minimum: 0
                  maximum: 1
                attestation_valid:
                  type: boolean
                energy_capacity_jps:
                  type: integer
                  minimum: 1
                substrate_kind_neutrality_index:
                  type: integer
                  minimum: 0
    guarantees:
      - registry must expose the substrate_kind_neutrality_index used for tie-breaking
      - registry entries must retain capability_score, health_score, and energy capacity for deterministic filtering
  select_substrate:
    summary: Select one active substrate and one standby candidate for one requested method and workload class.
    input:
      inline_schema:
        type: object
        required:
          - identity_id
          - method
          - required_capability
          - workload_class
        properties:
          identity_id:
            type: string
            minLength: 1
          method:
            type: string
            enum:
              - A
              - B
              - C
          required_capability:
            type: number
            minimum: 0
            maximum: 1
          workload_class:
            type: string
            enum:
              - baseline
              - sandbox
              - council
              - migration
    output:
      inline_schema:
        type: object
        required:
          - selection_id
          - active_substrate
          - ranked_candidates
          - required_energy_floor_jps
          - neutrality_rotation_applied
        properties:
          selection_id:
            type: string
            minLength: 1
          required_energy_floor_jps:
            type: integer
            minimum: 1
          active_substrate:
            type: object
            required:
              - substrate_id
              - substrate_kind
              - health_score
              - substrate_kind_neutrality_index
            properties:
              substrate_id:
                type: string
                minLength: 1
              substrate_kind:
                type: string
                minLength: 1
              health_score:
                type: number
                minimum: 0
                maximum: 1
              substrate_kind_neutrality_index:
                type: integer
                minimum: 0
          standby_substrate:
            type:
              - object
              - "null"
          ranked_candidates:
            type: array
            minItems: 1
            items:
              type: object
          neutrality_rotation_applied:
            type: boolean
    guarantees:
      - candidates must satisfy capability, health, attestation validity, and energy floor filters before ranking
      - ties must be broken by substrate_kind_neutrality_index before stable substrate_id ordering
      - standby_substrate must prefer a different substrate_kind when an equally safe candidate exists
  lease:
    summary: Create one active lease on the selected substrate and bind one standby candidate for later migrate.
    input:
      inline_schema:
        type: object
        required:
          - identity_id
          - units
          - purpose
          - method
          - required_capability
          - workload_class
        properties:
          identity_id:
            type: string
            minLength: 1
          units:
            type: integer
            minimum: 1
          purpose:
            type: string
            minLength: 1
          method:
            type: string
            enum:
              - A
              - B
              - C
          required_capability:
            type: number
            minimum: 0
            maximum: 1
          workload_class:
            type: string
            enum:
              - baseline
              - sandbox
              - council
              - migration
    output:
      schema_ref: substrate_allocation
    guarantees:
      - lease must fail closed when the same identity already holds an open source lease
      - lease output must remain one SubstrateAllocation bound to the selected active substrate
      - standby target must be recorded without materializing a second active allocation until open_dual_allocation_window is called
  attest:
    summary: Emit one broker-bound attestation for the active lease before migrate.
    input:
      inline_schema:
        type: object
        required:
          - identity_id
          - integrity
        properties:
          identity_id:
            type: string
            minLength: 1
          integrity:
            type: object
            minProperties: 1
    output:
      schema_ref: substrate_attestation
    guarantees:
      - attestation must bind the active allocation_id selected by the lease
      - attestation status other than healthy must block migrate
  probe_standby:
    summary: Probe the pre-bound standby candidate so migrate readiness remains machine-checkable before handoff.
    input:
      inline_schema:
        type: object
        required:
          - identity_id
        properties:
          identity_id:
            type: string
            minLength: 1
          workload_class:
            type: string
            enum:
              - baseline
              - sandbox
              - council
              - migration
    output:
      schema_ref: standby_health_probe
    guarantees:
      - probe must resolve the same standby candidate selected by lease
      - probe must expose standby_class, health_score, attestation_valid, and energy headroom against the required floor
      - ready_for_migrate becomes true only when the standby candidate remains healthy, attested, and above the energy floor
  bridge_attestation_chain:
    summary: Bind a bounded cross-substrate attestation window between the healthy active lease and its standby target before migrate.
    input:
      inline_schema:
        type: object
        required:
          - identity_id
          - state
        properties:
          identity_id:
            type: string
            minLength: 1
          state:
            type: object
            minProperties: 1
          continuity_mode:
            type: string
            enum:
              - cold-copy
              - warm-standby
              - hot-handoff
    output:
      schema_ref: substrate_attestation_chain
    guarantees:
      - bridge_attestation_chain must fail closed when the latest active attestation is missing or unhealthy
      - bridge_attestation_chain must bind the latest standby probe and the expected destination substrate before migrate
      - the fixed attestation window must expose sequence-ordered observations and one expected_state_digest for the pending handoff
  open_dual_allocation_window:
    summary: Materialize one bounded Method B shadow-sync overlap window on the pre-bound standby substrate.
    input:
      inline_schema:
        type: object
        required:
          - identity_id
          - state
        properties:
          identity_id:
            type: string
            minLength: 1
          state:
            type: object
            minProperties: 1
          units:
            type: integer
            minimum: 1
          purpose:
            type: string
            minLength: 1
          continuity_mode:
            type: string
            enum:
              - hot-handoff
    output:
      schema_ref: substrate_dual_allocation_window
    guarantees:
      - open_dual_allocation_window must require Method B, a ready standby probe, a healthy source attestation, and a handoff-ready attestation chain
      - the shadow allocation must materialize on the pre-bound standby substrate and remain the only second live allocation in the reference runtime
      - the overlap window must bind one source state digest, fixed mirror cadence, and bounded drift before authority handoff
  close_dual_allocation_window:
    summary: Close one bounded Method B dual-allocation window and release its shadow allocation.
    input:
      inline_schema:
        type: object
        required:
          - identity_id
          - reason
        properties:
          identity_id:
            type: string
            minLength: 1
          reason:
            type: string
            minLength: 1
    output:
      schema_ref: substrate_dual_allocation_window
    guarantees:
      - close_dual_allocation_window must fail closed unless a shadow-active window exists
      - close_dual_allocation_window must release the shadow allocation and emit a closed receipt before source release completes
  seal_attestation_stream:
    summary: Seal one bounded cross-substrate keepalive stream while the Method B shadow-sync window remains open.
    input:
      inline_schema:
        type: object
        required:
          - identity_id
          - state
        properties:
          identity_id:
            type: string
            minLength: 1
          state:
            type: object
            minProperties: 1
          continuity_mode:
            type: string
            enum:
              - hot-handoff
    output:
      schema_ref: substrate_attestation_stream
    guarantees:
      - seal_attestation_stream must require a healthy source attestation, a handoff-ready attestation chain, and a shadow-active dual-allocation window
      - the stream must keep one expected_state_digest and destination binding across all keepalive beats before migrate
      - sealed-handoff-ready status must require the fixed keepalive beat count to remain healthy with drift at or below the dual-allocation ceiling
  migrate:
    summary: Migrate one attested active lease onto its standby target or an explicitly supplied safe destination.
    input:
      inline_schema:
        type: object
        required:
          - identity_id
          - state
        properties:
          identity_id:
            type: string
            minLength: 1
          state:
            type: object
            minProperties: 1
          destination_substrate:
            type: string
            minLength: 1
          continuity_mode:
            type: string
            enum:
              - cold-copy
              - warm-standby
              - hot-handoff
    output:
      schema_ref: substrate_transfer
    guarantees:
      - migrate must fail closed when the latest attestation is missing or unhealthy
      - destination_substrate must default to the bound standby candidate when omitted
      - hot-handoff migrate must require an open dual-allocation window, a sealed-handoff-ready attestation stream, and the shadow allocation substrate as the destination
      - hot-handoff migrate must fail closed when the attestation stream state digest or destination binding differs from the pending migrate request
      - transfer output must reuse the canonical substrate_transfer schema
  release:
    summary: Release the source lease after a successful migrate or explicit broker teardown.
    input:
      inline_schema:
        type: object
        required:
          - identity_id
          - reason
        properties:
          identity_id:
            type: string
            minLength: 1
          reason:
            type: string
            minLength: 1
    output:
      schema_ref: substrate_release
    guarantees:
      - release must apply to the active source lease bound by lease
      - released source leases must not accept a second release
  handle_energy_floor_signal:
    summary: Emit one scheduler-compatible signal when the active substrate approaches or violates its minimum energy floor.
    input:
      inline_schema:
        type: object
        required:
          - identity_id
          - current_joules_per_second
        properties:
          identity_id:
            type: string
            minLength: 1
          current_joules_per_second:
            type: integer
            minimum: 0
    output:
      inline_schema:
        type: object
        required:
          - signal_id
          - severity
          - source_substrate
          - recommended_action
          - status
          - minimum_joules_per_second
          - current_joules_per_second
          - scheduler_input
        properties:
          signal_id:
            type: string
            minLength: 1
          severity:
            type: string
            enum:
              - watch
              - degraded
              - critical
          source_substrate:
            type: string
            minLength: 1
          standby_substrate:
            type:
              - string
              - "null"
          recommended_action:
            type: string
            enum:
              - pause-and-review
              - migrate-standby
          status:
            type: string
            enum:
              - within-floor
              - standby-advised
              - standby-required
          minimum_joules_per_second:
            type: integer
            minimum: 1
          current_joules_per_second:
            type: integer
            minimum: 0
          scheduler_input:
            type: object
            required:
              - severity
              - source_substrate
              - reason
            properties:
              severity:
                type: string
                enum:
                  - watch
                  - degraded
                  - critical
              source_substrate:
                type: string
                minLength: 1
              reason:
                type: string
                minLength: 1
    guarantees:
      - energy floor violations must emit severity=critical and recommend migrate-standby
      - scheduler_input must stay compatible with kernel.scheduler.v0 handle_substrate_signal
      - standby_substrate must remain the pre-bound standby candidate when one exists
events:
  broker.selection_made:
    payload:
      inline_schema:
        type: object
        required:
          - selection_id
          - active_substrate_id
        properties:
          selection_id:
            type: string
          active_substrate_id:
            type: string
  substrate.attested:
    payload:
      schema_ref: substrate_attestation
  broker.standby_probed:
    payload:
      schema_ref: standby_health_probe
  substrate.attestation_chain.bound:
    payload:
      schema_ref: substrate_attestation_chain
  substrate.attestation_stream.sealed:
    payload:
      schema_ref: substrate_attestation_stream
  broker.dual_allocation_window.opened:
    payload:
      schema_ref: substrate_dual_allocation_window
  broker.dual_allocation_window.closed:
    payload:
      schema_ref: substrate_dual_allocation_window
  substrate.migrated:
    payload:
      schema_ref: substrate_transfer
  substrate.released:
    payload:
      schema_ref: substrate_release
compatibility:
  stability: bootstrap
  notes:
    - The reference runtime defaults to one active lease plus one standby candidate, then allows only one Method B shadow allocation window as the bounded exception.
    - The shadow allocation window is fixed to one standby-backed second allocation, 45s overlap, 250ms mirror cadence, and 3 sync observations before authority handoff.
    - The attestation stream is fixed to 5 healthy keepalive beats at the same 250ms cadence and must be sealed before hot-handoff migrate.
    - Cross-host dual allocation remains future work beyond the bounded broker contract.
