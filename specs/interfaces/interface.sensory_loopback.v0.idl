idl_version: 1
kind: service
namespace: interface.sensory_loopback.v0
service: SensoryLoopbackService
summary: Canonical L6 contract for bounded visual/audio/haptic self-feedback with guardian stabilization and shared-space arbitration.
imports:
  sensory_loopback_session: ../schemas/sensory_loopback_session.schema
  sensory_loopback_receipt: ../schemas/sensory_loopback_receipt.schema
  sensory_loopback_artifact_family: ../schemas/sensory_loopback_artifact_family.schema
  sensory_loopback_biodata_arbitration_binding: ../schemas/sensory_loopback_biodata_arbitration_binding.schema
  sensory_loopback_latency_weight_policy_verifier_quorum: ../schemas/sensory_loopback_latency_weight_policy_verifier_quorum.schema
operations:
  open_session:
    summary: Bind one loopback session to a world-state anchor, virtual body anchor, avatar body-map calibration, and optional bounded shared-space context before delivery begins.
    input:
      inline_schema:
        type: object
        required:
          - identity_id
          - world_state_ref
          - body_anchor_ref
          - avatar_body_map_ref
          - proprioceptive_calibration_ref
        properties:
          identity_id:
            type: string
            minLength: 1
          world_state_ref:
            type: string
            minLength: 1
          body_anchor_ref:
            type: string
            minLength: 1
          avatar_body_map_ref:
            type: string
            minLength: 1
          proprioceptive_calibration_ref:
            type: string
            minLength: 1
          calibration_confidence_gate:
            type: object
            description: Optional BioData calibration confidence gate receipt used only to adjust drift thresholds without replacing body-map calibration or Guardian hold.
            required:
              - profile_id
              - gate_ref
              - gate_receipt_digest
              - confidence_gate_status
              - confidence_score
              - sensory_loopback_gate_bound
              - target_gate_bindings
              - raw_calibration_payload_stored
              - raw_gate_payload_stored
              - subjective_equivalence_claimed
              - semantic_thought_content_generated
            properties:
              profile_id:
                const: biodata-calibration-confidence-gate-v1
              gate_ref:
                type: string
                minLength: 1
              gate_receipt_digest:
                type: string
                minLength: 32
              confidence_gate_status:
                const: bound
              confidence_score:
                type: number
                minimum: 0.7
                maximum: 1
              sensory_loopback_gate_bound:
                const: true
              target_gate_bindings:
                type: array
                minItems: 1
              raw_calibration_payload_stored:
                const: false
              raw_gate_payload_stored:
                const: false
              subjective_equivalence_claimed:
                const: false
              semantic_thought_content_generated:
                const: false
          participant_identity_ids:
            type: array
            minItems: 1
            maxItems: 4
            uniqueItems: true
            items:
              type: string
              minLength: 1
          shared_imc_session_id:
            type: string
            minLength: 1
          shared_collective_id:
            type: string
            minLength: 1
          channels:
            type: array
            minItems: 2
            uniqueItems: true
            items:
              type: string
              enum:
                - visual
                - auditory
                - haptic
    output:
      schema_ref: sensory_loopback_session
    guarantees:
      - loopback sessions must bind to one world_state_ref before any delivery occurs
      - loopback sessions must bind to one avatar_body_map_ref and one proprioceptive_calibration_ref before delivery occurs
      - an optional biodata-calibration-confidence-gate-v1 receipt may adjust body drift thresholds by at most 0.04 when the sensory-loopback target passes
      - the calibration confidence gate is advisory input only and may not replace body-map calibration, Guardian observation, Guardian hold, or stabilization
      - raw calibration and raw gate payloads must remain redacted when the confidence gate is bound
      - channels must cover at least 2 modalities to claim body-coherent feedback
      - participant_identity_ids with more than 1 entry require shared_imc_session_id and bind guardian-mediated arbitration metadata
      - shared_collective_id may only appear when shared_imc_session_id is also bound
  bind_latency_weight_policy_verifier_quorum:
    summary: Bind one live verifier quorum receipt proving the weighted latency policy authority remains fresh before weighted latency quorum can accept a blocked participant timing gate.
    input:
      inline_schema:
        type: object
        required:
          - authority_ref
          - authority_digest
          - source_digest_set
        properties:
          authority_ref:
            type: string
            minLength: 1
          authority_digest:
            type: string
            minLength: 32
          source_digest_set:
            type: string
            minLength: 32
          verifier_refs:
            type: array
            minItems: 2
            uniqueItems: true
            items:
              type: string
              minLength: 1
          verifier_jurisdictions:
            type: array
            minItems: 2
            uniqueItems: true
            items:
              type: string
              minLength: 1
    output:
      schema_ref: sensory_loopback_latency_weight_policy_verifier_quorum
    guarantees:
      - weighted-latency-policy-live-verifier-quorum-v1 must bind at least two distinct verifier refs and jurisdictions
      - verifier receipts must bind the same authority ref, authority digest, and source digest set used by the weighted latency policy
      - freshness_status must be fresh inside a 24 hour freshness window before weighted latency quorum is accepted
      - verifier response and signature evidence are digest-only and raw verifier / response / signature payloads remain redacted
  bind_participant_biodata_arbitration:
    summary: Bind participant-specific BioData calibration confidence, feature-window drift gate, and calibration refresh receipts into one shared loopback arbitration session.
    input:
      inline_schema:
        type: object
        required:
          - session_id
          - participant_gate_receipts
          - participant_latency_drift_gates
        properties:
          session_id:
            type: string
            minLength: 8
          participant_gate_receipts:
            type: object
            minProperties: 2
            description: Mapping from participant identity id to biodata-calibration-confidence-gate-v1 receipt.
            additionalProperties:
              type: object
              required:
                - profile_id
                - identity_id
                - gate_ref
                - gate_receipt_digest
                - confidence_gate_status
                - confidence_score
                - sensory_loopback_gate_bound
                - feature_window_series_drift_gate_ref
                - feature_window_series_drift_gate_digest
                - feature_window_series_drift_threshold_digest
                - feature_window_series_drift_gate_status
                - feature_window_series_drift_gate_bound
                - calibration_refresh_ref
                - calibration_refresh_digest
                - calibration_refresh_source_digest_set
                - calibration_refresh_window_bound
                - calibration_refresh_status
                - calibration_refresh_bound
                - target_gate_set_digest
                - target_gate_bindings
                - raw_calibration_payload_stored
                - raw_drift_payload_stored
                - raw_refresh_payload_stored
                - raw_gate_payload_stored
                - subjective_equivalence_claimed
                - semantic_thought_content_generated
              properties:
                profile_id:
                  const: biodata-calibration-confidence-gate-v1
                identity_id:
                  type: string
                  minLength: 1
                gate_ref:
                  type: string
                  minLength: 1
                gate_receipt_digest:
                  type: string
                  minLength: 32
                confidence_gate_status:
                  const: bound
                confidence_score:
                  type: number
                  minimum: 0.7
                  maximum: 1
                sensory_loopback_gate_bound:
                  const: true
                feature_window_series_drift_gate_ref:
                  type: string
                  minLength: 1
                feature_window_series_drift_gate_digest:
                  type: string
                  minLength: 32
                feature_window_series_drift_threshold_digest:
                  type: string
                  minLength: 32
                feature_window_series_threshold_policy_authority_ref:
                  type: string
                feature_window_series_threshold_policy_authority_digest:
                  type: string
                feature_window_series_threshold_policy_source_digest_set:
                  type: string
                feature_window_series_threshold_policy_authority_status:
                  type: string
                  enum:
                    - complete
                    - not-bound
                feature_window_series_threshold_policy_authority_bound:
                  type: boolean
                feature_window_series_drift_gate_status:
                  const: pass
                feature_window_series_drift_gate_bound:
                  const: true
                calibration_refresh_ref:
                  type: string
                  minLength: 1
                calibration_refresh_digest:
                  type: string
                  minLength: 32
                calibration_refresh_source_digest_set:
                  type: string
                  minLength: 32
                calibration_refresh_window_bound:
                  const: true
                calibration_refresh_status:
                  const: fresh
                calibration_refresh_bound:
                  const: true
                target_gate_set_digest:
                  type: string
                  minLength: 32
                target_gate_bindings:
                  type: array
                  minItems: 1
                raw_calibration_payload_stored:
                  const: false
                raw_drift_payload_stored:
                  const: false
                raw_refresh_payload_stored:
                  const: false
                raw_gate_payload_stored:
                  const: false
                subjective_equivalence_claimed:
                  const: false
                semantic_thought_content_generated:
                  const: false
          participant_latency_drift_gates:
            type: object
            minProperties: 2
            description: Mapping from participant identity id to participant-hardware-timing-latency-drift-gate-v1 receipt.
            additionalProperties:
              type: object
              required:
                - schema_version
                - profile_id
                - timing_gate_ref
                - created_at
                - participant_identity_id
                - hardware_adapter_ref
                - timing_evidence_ref
                - baseline_latency_ms
                - observed_latency_ms
                - absolute_latency_drift_ms
                - max_latency_drift_ms
                - latency_threshold_digest
                - threshold_policy_authority_ref
                - threshold_policy_authority_digest
                - threshold_policy_source_digest_set
                - threshold_policy_authority_status
                - threshold_policy_authority_bound
                - latency_drift_status
                - raw_timing_payload_stored
                - raw_hardware_adapter_payload_stored
                - raw_threshold_policy_payload_stored
                - raw_authority_payload_stored
                - timing_gate_digest
              properties:
                schema_version:
                  const: "1.0"
                profile_id:
                  const: participant-hardware-timing-latency-drift-gate-v1
                timing_gate_ref:
                  type: string
                  minLength: 1
                created_at:
                  type: string
                  format: date-time
                participant_identity_id:
                  type: string
                  minLength: 1
                hardware_adapter_ref:
                  type: string
                  minLength: 1
                timing_evidence_ref:
                  type: string
                  minLength: 1
                baseline_latency_ms:
                  type: number
                  minimum: 0
                observed_latency_ms:
                  type: number
                  minimum: 0
                absolute_latency_drift_ms:
                  type: number
                  minimum: 0
                max_latency_drift_ms:
                  const: 12.0
                latency_threshold_digest:
                  type: string
                  minLength: 32
                threshold_policy_authority_ref:
                  type: string
                threshold_policy_authority_digest:
                  type: string
                threshold_policy_source_digest_set:
                  type: string
                threshold_policy_authority_status:
                  type: string
                  enum:
                    - complete
                    - not-bound
                threshold_policy_authority_bound:
                  type: boolean
                latency_drift_status:
                  type: string
                  enum:
                    - pass
                    - blocked
                raw_timing_payload_stored:
                  const: false
                raw_hardware_adapter_payload_stored:
                  const: false
                raw_threshold_policy_payload_stored:
                  const: false
                raw_authority_payload_stored:
                  const: false
                timing_gate_digest:
                  type: string
                  minLength: 32
          participant_latency_weights:
            type: object
            minProperties: 3
            maxProperties: 4
            description: Optional weighted-latency-quorum-v1 participant weights. When omitted, all participant latency gates must pass.
            additionalProperties:
              type: number
              exclusiveMinimum: 0
              maximum: 1
          latency_quorum_threshold:
            type: number
            exclusiveMinimum: 0
            maximum: 1
          latency_weight_policy_authority_ref:
            type: string
            description: Required authority reference when participant_latency_weights select weighted-latency-quorum-v1.
          latency_weight_policy_authority_digest:
            type: string
            minLength: 32
            description: Digest of the external authority that approved the participant latency weights.
          latency_weight_policy_source_digest_set:
            type: string
            minLength: 32
            description: Digest set for the source policy evidence used to approve the participant latency weights.
          latency_weight_policy_verifier_quorum:
            schema_ref: sensory_loopback_latency_weight_policy_verifier_quorum
            description: Required live verifier quorum receipt when participant_latency_weights select weighted-latency-quorum-v1.
    output:
      schema_ref: sensory_loopback_biodata_arbitration_binding
    guarantees:
      - participant_gate_receipts must cover exactly the shared session participant_identity_ids
      - participant_latency_drift_gates must cover exactly the same participant_identity_ids before shared arbitration accepts BioData gates
      - each participant gate must belong to the same participant identity and pass the sensory-loopback target gate
      - each participant gate must bind a passing feature-window series drift gate before shared loopback arbitration consumes it
      - each participant gate must propagate a fresh calibration refresh receipt with a bound freshness window
      - without participant_latency_weights, each participant latency gate must pass the hardware timing drift threshold
      - with weighted-latency-quorum-v1 on 3-4 participants, blocked participant timing gates are allowed only when the passing participant weight meets latency_quorum_threshold
      - weighted-latency-quorum-v1 also requires latency_weight_policy_authority_ref, latency_weight_policy_authority_digest, and latency_weight_policy_source_digest_set
      - weighted-latency-quorum-v1 also requires a fresh weighted-latency-policy-live-verifier-quorum-v1 receipt bound to the same authority and source digest set
      - every participant latency gate must share the BioData threshold policy authority digest when authority is bound
      - the output keeps only gate refs/digests, drift gate refs/digests, refresh refs/digests/source digest sets, threshold digests, timing gate digests, target gate-set digests, participant latency weights, weight-policy authority refs/digests, verifier quorum refs/digests, and latency quorum digests
      - raw BioData, calibration, drift, refresh, timing, hardware adapter, weight-policy authority, verifier, response, signature, and gate payloads remain redacted
  deliver_bundle:
    summary: Deliver one bounded multi-sensory bundle with avatar body-map alignment evidence, optional shared-space owner arbitration, or degrade it into a guardian-controlled safe baseline.
    input:
      inline_schema:
        type: object
        required:
          - session_id
          - scene_summary
          - artifact_refs
          - latency_ms
          - body_map_alignment_ref
          - body_map_alignment
          - attention_target
          - guardian_observed
        properties:
          session_id:
            type: string
            minLength: 8
          scene_summary:
            type: string
            minLength: 1
          artifact_refs:
            type: object
            minProperties: 2
            additionalProperties: false
            properties:
              visual:
                type: string
                minLength: 1
              auditory:
                type: string
                minLength: 1
              haptic:
                type: string
                minLength: 1
          latency_ms:
            type: number
            minimum: 0
          body_map_alignment_ref:
            type: string
            minLength: 1
          body_map_alignment:
            type: object
            additionalProperties: false
            required:
              - core
              - left-hand
              - right-hand
              - stance
            properties:
              core:
                type: number
                minimum: 0
                maximum: 1
              left-hand:
                type: number
                minimum: 0
                maximum: 1
              right-hand:
                type: number
                minimum: 0
                maximum: 1
              stance:
                type: number
                minimum: 0
                maximum: 1
          attention_target:
            type: string
            minLength: 1
          guardian_observed:
            type: boolean
          qualia_binding_ref:
            type: string
            minLength: 1
          owner_identity_id:
            type: string
            minLength: 1
          participant_attention_targets:
            type: object
            minProperties: 1
            propertyNames:
              type: string
              minLength: 1
            additionalProperties:
              type: string
              minLength: 1
          participant_presence_refs:
            type: object
            minProperties: 1
            propertyNames:
              type: string
              minLength: 1
            additionalProperties:
              type: string
              minLength: 1
    output:
      schema_ref: sensory_loopback_receipt
    guarantees:
      - body_coherence_score must be derived from the weighted body_map_alignment payload
      - coherent bundles must remain within 90ms latency and the applied body drift threshold, defaulting to 0.20 and allowing only bounded BioData calibration confidence adjustment
      - degraded bundles require guardian observation before attenuation or hold even when calibration confidence is bound
      - shared-space bundles must bind one owner_identity_id and complete participant attention/presence maps
      - conflicting participant_attention_targets require guardian observation and must emit guardian-mediated or guardian-hold arbitration_status
      - guardian-hold receipts must apply safe baseline and flag council review
      - audit output must retain artifact refs and digest only, never raw loopback payloads
  stabilize:
    summary: Recover a stabilizing or held session back to an active body anchor.
    input:
      inline_schema:
        type: object
        required:
          - session_id
          - reason
          - restored_body_anchor_ref
        properties:
          session_id:
            type: string
            minLength: 8
          reason:
            type: string
            minLength: 1
          restored_body_anchor_ref:
            type: string
            minLength: 1
    output:
      schema_ref: sensory_loopback_receipt
    guarantees:
      - stabilize may only resume sessions previously marked stabilizing or held
      - restored_body_anchor_ref must replace the previous drifted anchor on success
  snapshot:
    summary: Read the current loopback session state.
    input:
      inline_schema:
        type: object
        required:
          - session_id
        properties:
          session_id:
            type: string
            minLength: 8
    output:
      schema_ref: sensory_loopback_session
  capture_artifact_family:
    summary: Bind 2-4 loopback receipts from one session into a digest-only multi-scene artifact family.
    input:
      inline_schema:
        type: object
        required:
          - session_id
          - family_label
          - receipts
        properties:
          session_id:
            type: string
            minLength: 8
          family_label:
            type: string
            minLength: 1
          receipts:
            type: array
            minItems: 2
            maxItems: 4
            items:
              schema_ref: sensory_loopback_receipt
    output:
      schema_ref: sensory_loopback_artifact_family
    guarantees:
      - artifact families must only group receipts from the same loopback session
      - artifact families must preserve per-scene digest, guardian action, and recovery state without raw payload retention
      - shared-space artifact families must preserve participant bindings, arbitration refs, and arbitration counts across scenes
      - artifact family capture must expose the final session status at record time
  snapshot_artifact_family:
    summary: Read one recorded multi-scene loopback artifact family.
    input:
      inline_schema:
        type: object
        required:
          - family_id
        properties:
          family_id:
            type: string
            minLength: 8
    output:
      schema_ref: sensory_loopback_artifact_family
events:
  sensory_loopback.bundle_recorded:
    payload:
      schema_ref: sensory_loopback_receipt
  sensory_loopback.session_stabilized:
    payload:
      schema_ref: sensory_loopback_receipt
  sensory_loopback.artifact_family_recorded:
    payload:
      schema_ref: sensory_loopback_artifact_family
  sensory_loopback.biodata_arbitration_bound:
    payload:
      schema_ref: sensory_loopback_biodata_arbitration_binding
compatibility:
  stability: bootstrap
  notes:
    - This contract proves digest-only, body-coherent loopback handling, avatar body-map calibration binding, shared IMC/collective arbitration metadata, participant BioData gate arbitration, and bounded multi-scene artifact family capture inside the reference runtime.
    - Raw payload capture and device-driver timing stay outside this bootstrap boundary so the in-repo runtime remains deterministic and digest-only.
