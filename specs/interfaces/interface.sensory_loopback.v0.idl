idl_version: 1
kind: service
namespace: interface.sensory_loopback.v0
service: SensoryLoopbackService
summary: Canonical L6 contract for bounded visual/audio/haptic self-feedback with guardian stabilization.
imports:
  sensory_loopback_session: ../schemas/sensory_loopback_session.schema
  sensory_loopback_receipt: ../schemas/sensory_loopback_receipt.schema
  sensory_loopback_artifact_family: ../schemas/sensory_loopback_artifact_family.schema
operations:
  open_session:
    summary: Bind one loopback session to a world-state anchor and a virtual body anchor before delivery begins.
    input:
      inline_schema:
        type: object
        required:
          - identity_id
          - world_state_ref
          - body_anchor_ref
          - channels
        properties:
          identity_id:
            type: string
            minLength: 1
          world_state_ref:
            type: string
            minLength: 1
          body_anchor_ref:
            type: string
            minLength: 1
          channels:
            type: array
            minItems: 2
            uniqueItems: true
            items:
              type: string
              enum:
                - visual
                - auditory
                - haptic
    output:
      schema_ref: sensory_loopback_session
    guarantees:
      - loopback sessions must bind to one world_state_ref before any delivery occurs
      - channels must cover at least 2 modalities to claim body-coherent feedback
  deliver_bundle:
    summary: Deliver one bounded multi-sensory bundle or degrade it into a guardian-controlled safe baseline.
    input:
      inline_schema:
        type: object
        required:
          - session_id
          - scene_summary
          - artifact_refs
          - latency_ms
          - body_coherence_score
          - attention_target
          - guardian_observed
        properties:
          session_id:
            type: string
            minLength: 8
          scene_summary:
            type: string
            minLength: 1
          artifact_refs:
            type: object
            minProperties: 2
            additionalProperties: false
            properties:
              visual:
                type: string
                minLength: 1
              auditory:
                type: string
                minLength: 1
              haptic:
                type: string
                minLength: 1
          latency_ms:
            type: number
            minimum: 0
          body_coherence_score:
            type: number
            minimum: 0
            maximum: 1
          attention_target:
            type: string
            minLength: 1
          guardian_observed:
            type: boolean
          qualia_binding_ref:
            type: string
            minLength: 1
    output:
      schema_ref: sensory_loopback_receipt
    guarantees:
      - coherent bundles must remain within 90ms latency and 0.20 body drift
      - degraded bundles require guardian observation before attenuation or hold
      - guardian-hold receipts must apply safe baseline and flag council review
      - audit output must retain artifact refs and digest only, never raw loopback payloads
  stabilize:
    summary: Recover a stabilizing or held session back to an active body anchor.
    input:
      inline_schema:
        type: object
        required:
          - session_id
          - reason
          - restored_body_anchor_ref
        properties:
          session_id:
            type: string
            minLength: 8
          reason:
            type: string
            minLength: 1
          restored_body_anchor_ref:
            type: string
            minLength: 1
    output:
      schema_ref: sensory_loopback_receipt
    guarantees:
      - stabilize may only resume sessions previously marked stabilizing or held
      - restored_body_anchor_ref must replace the previous drifted anchor on success
  snapshot:
    summary: Read the current loopback session state.
    input:
      inline_schema:
        type: object
        required:
          - session_id
        properties:
          session_id:
            type: string
            minLength: 8
    output:
      schema_ref: sensory_loopback_session
  capture_artifact_family:
    summary: Bind 2-4 loopback receipts from one session into a digest-only multi-scene artifact family.
    input:
      inline_schema:
        type: object
        required:
          - session_id
          - family_label
          - delivery_ids
        properties:
          session_id:
            type: string
            minLength: 8
          family_label:
            type: string
            minLength: 1
          delivery_ids:
            type: array
            minItems: 2
            maxItems: 4
            uniqueItems: true
            items:
              type: string
              minLength: 8
    output:
      schema_ref: sensory_loopback_artifact_family
    guarantees:
      - artifact families must only group receipts from the same loopback session
      - artifact families must preserve per-scene digest, guardian action, and recovery state without raw payload retention
      - artifact family capture must expose the final session status at record time
  snapshot_artifact_family:
    summary: Read one recorded multi-scene loopback artifact family.
    input:
      inline_schema:
        type: object
        required:
          - family_id
        properties:
          family_id:
            type: string
            minLength: 8
    output:
      schema_ref: sensory_loopback_artifact_family
events:
  sensory_loopback.bundle_recorded:
    payload:
      schema_ref: sensory_loopback_receipt
  sensory_loopback.session_stabilized:
    payload:
      schema_ref: sensory_loopback_receipt
  sensory_loopback.artifact_family_recorded:
    payload:
      schema_ref: sensory_loopback_artifact_family
compatibility:
  stability: bootstrap
  notes:
    - This contract proves digest-only, body-coherent loopback handling and bounded multi-scene artifact family capture inside the reference runtime.
    - Raw retinal/audio/haptic streams, richer avatar-body maps, and hardware-specific actuator timing remain future work.
