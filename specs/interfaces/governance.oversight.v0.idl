idl_version: 1
kind: service
namespace: governance.oversight.v0
service: GuardianOversightService
summary: Deterministic human oversight quorum, attestation, breach propagation, and snapshot flow for Guardian actions.
imports:
  guardian_oversight_event: ../schemas/guardian_oversight_event.schema
  guardian_oversight_snapshot: ../schemas/guardian_oversight_snapshot.schema
  guardian_reviewer_record: ../schemas/guardian_reviewer_record.schema
operations:
  register_reviewer:
    summary: Register one human reviewer with identity proof, scope, and liability assignment before any Guardian attestation.
    input:
      schema_ref: guardian_reviewer_record
    output:
      schema_ref: guardian_reviewer_record
    guarantees:
      - reviewer_id must be unique
      - active reviewer records must include credential_id, proof_ref, legal_ack_ref, and non-empty scope lists
      - allowed_guardian_roles and allowed_categories must be subsets of the fixed Guardian role and oversight category enums
  verify_reviewer:
    summary: Bind one active reviewer record to a live-proof surrogate verification snapshot and jurisdiction evidence bundle before attestation.
    input:
      schema_ref: guardian_reviewer_record
    output:
      schema_ref: guardian_reviewer_record
    guarantees:
      - reviewer_id must resolve to an active guardian reviewer record
      - credential_verification must carry verifier_ref, challenge_ref, challenge_digest, transport_profile, and jurisdiction_bundle
      - credential_verification.valid_until must not exceed identity_proof.valid_until
      - jurisdiction_bundle.jurisdiction must match identity_proof.jurisdiction
  record:
    summary: Record one append-only oversight event for a Guardian veto, attestation, rule update, emergency trigger, or pin renewal.
    input:
      schema_ref: guardian_oversight_event
    output:
      schema_ref: guardian_oversight_event
    guarantees:
      - category must be one of veto, attest, rule-update, emergency-trigger, pin-renewal
      - escalation_path must not be empty
      - required_quorum and escalation_window_seconds must be derived deterministically from category
  attest:
    summary: Add one human reviewer attestation to an existing oversight event.
    input:
      schema_ref: guardian_oversight_event
    output:
      schema_ref: guardian_oversight_event
    guarantees:
      - reviewer id must resolve to an active guardian reviewer record
      - reviewer binding must snapshot credential_id, proof_ref, liability_mode, legal_ack_ref, verification_id, verifier_ref, challenge_digest, transport_profile, jurisdiction_bundle_ref, jurisdiction_bundle_digest, guardian_role, and category
      - reviewer responsibility scope must include the target guardian_role and oversight category
      - reviewer attestation must reject missing, stale, expired, or revoked credential_verification snapshots
      - reviewer ids must deduplicate without reordering existing reviewers
      - status becomes satisfied once received_quorum >= required_quorum
      - breached events must reject further attestation
  revoke_reviewer:
    summary: Revoke one reviewer record so that future attestations fail closed without erasing past bindings.
    input:
      schema_ref: guardian_reviewer_record
    output:
      schema_ref: guardian_reviewer_record
    guarantees:
      - revoked reviewers must preserve registered proof and legal ack refs for audit
      - revoked reviewers must reject future event attestation
  breach:
    summary: Mark one unsatisfied oversight event as breached after its escalation window elapses.
    input:
      schema_ref: guardian_oversight_event
    output:
      schema_ref: guardian_oversight_event
    guarantees:
      - unsatisfied pin breaches must clear human pin on the mapped Guardian agent
      - breach propagation must make guardian_role ineligible in trust snapshots
      - satisfied events must remain unchanged
  snapshot:
    summary: Return the current oversight policy, reviewer registry, and append-only event set.
    output:
      schema_ref: guardian_oversight_snapshot
    guarantees:
      - returned reviewer records must preserve registered proof refs and duty scope
      - returned events must preserve reviewer proof bindings once attached
compatibility:
  stability: bootstrap
  notes:
    - Reference runtime stores proof refs and legal acknowledgement refs, but not the raw identity documents or contracts themselves.
    - Reference runtime stores live-proof surrogate snapshots and jurisdiction evidence bundle refs, but not raw credentials or legal packages.
    - Remote reviewer attestation transport against a real verifier network and jurisdiction-specific enforcement remain future work.
