idl_version: 1
kind: service
namespace: mind.qualia.v0
service: QualiaBufferService
summary: Minimal monotonic qualia buffer contract.
imports:
  qualia_tick: ../schemas/qualia_tick.schema
operations:
  append:
    summary: Record one subjective-state sample.
    input:
      inline_schema:
        type: object
        required:
          - summary
          - valence
          - arousal
          - clarity
        properties:
          summary:
            type: string
            minLength: 1
          valence:
            type: number
            minimum: -1
            maximum: 1
          arousal:
            type: number
            minimum: 0
            maximum: 1
          clarity:
            type: number
            minimum: 0
            maximum: 1
          modality_salience:
            type: object
            additionalProperties: false
            properties:
              visual:
                type: number
                minimum: 0
                maximum: 1
              auditory:
                type: number
                minimum: 0
                maximum: 1
              somatic:
                type: number
                minimum: 0
                maximum: 1
              interoceptive:
                type: number
                minimum: 0
                maximum: 1
          attention_target:
            type: string
            minLength: 1
          self_awareness:
            type: number
            minimum: 0
            maximum: 1
          lucidity:
            type: number
            minimum: 0
            maximum: 1
    output:
      schema_ref: qualia_tick
  recent:
    summary: Return recent qualia ticks.
    input:
      inline_schema:
        type: object
        required:
          - count
        properties:
          count:
            type: integer
            minimum: 1
    output:
      inline_schema:
        type: array
        items:
          schema_ref: qualia_tick
