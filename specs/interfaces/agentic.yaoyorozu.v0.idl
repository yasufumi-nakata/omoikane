idl_version: 1
kind: service
namespace: agentic.yaoyorozu.v0
service: YaoyorozuRegistryService
summary: Repo-local agent registry sync plus bounded same-host workspace discovery, Council convocation, same-session ConsensusBus and profile-aware TaskGraph handoff binding, and path/delta/patch-candidate-bound local worker dispatch planning.
imports:
  yaoyorozu_workspace_discovery: ../schemas/yaoyorozu_workspace_discovery.schema
  yaoyorozu_registry_snapshot: ../schemas/yaoyorozu_registry_snapshot.schema
  council_convocation_session: ../schemas/council_convocation_session.schema
  yaoyorozu_worker_dispatch_plan: ../schemas/yaoyorozu_worker_dispatch_plan.schema
  yaoyorozu_worker_dispatch_receipt: ../schemas/yaoyorozu_worker_dispatch_receipt.schema
  yaoyorozu_consensus_dispatch_binding: ../schemas/yaoyorozu_consensus_dispatch_binding.schema
  yaoyorozu_task_graph_binding: ../schemas/yaoyorozu_task_graph_binding.schema
  consensus_message: ../schemas/consensus_message.schema
operations:
  discover_workspace_workers:
    summary: >
      Discover one bounded same-host local workspace catalog of builder-capable agent registries
      before any cross-workspace builder handoff is considered, using the selected
      proposal profile's review budget and required coverage policy.
    input:
      inline_schema:
        type: object
        required:
          - workspace_roots
          - proposal_profile
        properties:
          workspace_roots:
            type: array
            minItems: 2
            maxItems: 3
            items:
              type: string
              minLength: 1
          proposal_profile:
            type: string
            enum:
              - self-modify-patch-v1
              - memory-edit-v1
              - fork-request-v1
              - inter-mind-negotiation-v1
          review_budget:
            type: integer
            minimum: 2
            maximum: 3
    output:
      schema_ref: yaoyorozu_workspace_discovery
    guarantees:
      - discovery must stay on the same host and only scan explicit local workspace_roots
      - proposal_profile must fix the review budget, required coverage areas, and TaskGraph bundle strategy echoed by the discovery output
      - accepted workspaces must expose builder agents, machine-readable role/capability indexes, and coverage summaries
      - review_budget must cap accepted workspaces and preserve the input ordering of source then accepted candidates
  sync_registry:
    summary: Materialize one trust-bound registry snapshot from repo-local agents/ definitions.
    input:
      inline_schema:
        type: object
        required:
          - source_root
        properties:
          source_root:
            type: string
            const: agents
    output:
      schema_ref: yaoyorozu_registry_snapshot
    guarantees:
      - synced entries must remain bound to repo-local agents/ definitions
      - every entry must carry a trust_snapshot and trust_floor
      - role_index and capability_index must remain machine-readable
  prepare_council_convocation:
    summary: >
      Derive one deterministic Council convocation and builder handoff plan from the synced registry,
      optionally binding the selected workspace-discovery policy and its accepted candidate set.
    input:
      inline_schema:
        type: object
        required:
          - proposal_profile
          - session_mode
          - target_identity_ref
          - workspace_discovery
        properties:
          proposal_profile:
            type: string
            enum:
              - self-modify-patch-v1
              - memory-edit-v1
              - fork-request-v1
              - inter-mind-negotiation-v1
          session_mode:
            type: string
            enum:
              - standard
              - expedited
          target_identity_ref:
            type: string
          workspace_discovery:
            schema_ref: yaoyorozu_workspace_discovery
    output:
      schema_ref: council_convocation_session
    guarantees:
      - standing roles must include speaker, recorder, guardian_liaison, and self_liaison
      - when workspace_discovery is bound, its proposal_profile and profile policy must match the selected convocation profile
      - council panel must satisfy weighted vote quorum before emit_build_request
      - proposal_profile must fix the required builder coverage surfaced by builder_handoff and exclude optional worker coverage areas from the convocation artifact
  prepare_worker_dispatch:
    summary: >
      Convert one selected bounded Yaoyorozu convocation into a repo-local worker dispatch plan
      that launches bounded builder processes only for the proposal profile's required worker coverage.
    input:
      inline_schema:
        type: object
        required:
          - convocation_session
        properties:
          convocation_session:
            schema_ref: council_convocation_session
    output:
      schema_ref: yaoyorozu_worker_dispatch_plan
    guarantees:
      - dispatch units must be derived only from selected builder_handoff entries
      - proposal_profile must fix the required and optional worker coverage policy echoed by the dispatch plan summary
      - every command preview must remain repo-local, subprocess-bound, and temp-workspace-only
      - every required worker coverage area must map to exactly one dispatch unit and optional worker coverage areas must not be launched
  execute_worker_dispatch:
    summary: >
      Execute one repo-local worker dispatch plan as bounded subprocess workers and return
      the resulting process-bound execution receipt.
    input:
      inline_schema:
        type: object
        required:
          - dispatch_plan
        properties:
          dispatch_plan:
            schema_ref: yaoyorozu_worker_dispatch_plan
    output:
      schema_ref: yaoyorozu_worker_dispatch_receipt
    guarantees:
      - every launched worker must emit a ready report bound to the same dispatch_plan_ref and dispatch_unit_ref
      - worker reports must verify that every target path exists and remains inside the repo-local workspace
      - worker reports must bind one git-target-path delta receipt that stays inside the same target_paths and dispatch unit
      - worker reports must materialize one patch_descriptor-compatible patch candidate receipt from the same delta evidence before the ready gate passes
      - worker execution must stay inside the repo-local workspace and inherit the dispatch profile
      - only zero-exit, ready-reported workers count toward completed dispatch coverage
  bind_consensus_dispatch:
    summary: >
      Bind one convocation, worker dispatch plan, and worker dispatch receipt to the same
      ConsensusBus session with builder reports, guardian gate, and blocked direct handoff evidence.
    input:
      inline_schema:
        type: object
        required:
          - convocation_session
          - dispatch_plan
          - dispatch_receipt
          - messages
          - blocked_direct_attempt
          - audit_summary
        properties:
          convocation_session:
            schema_ref: council_convocation_session
          dispatch_plan:
            schema_ref: yaoyorozu_worker_dispatch_plan
          dispatch_receipt:
            schema_ref: yaoyorozu_worker_dispatch_receipt
          messages:
            type: array
            items:
              schema_ref: consensus_message
          blocked_direct_attempt:
            type: object
            required:
              - session_id
              - status
              - enforced_policy
            properties:
              session_id:
                type: string
              status:
                type: string
                const: blocked
              enforced_policy:
                type: string
                const: consensus-bus-only
          audit_summary:
            type: object
            required:
              - session_id
              - blocked_direct_attempts
              - all_transport_bus_only
              - guardian_gate_present
              - resolve_present
              - ordered_phases
              - related_claim_ids
            properties:
              session_id:
                type: string
              blocked_direct_attempts:
                type: integer
                const: 1
              all_transport_bus_only:
                type: boolean
                const: true
              guardian_gate_present:
                type: boolean
                const: true
              resolve_present:
                type: boolean
                const: true
              ordered_phases:
                type: boolean
                const: true
              related_claim_ids:
                type: array
                items:
                  type: string
    output:
      schema_ref: yaoyorozu_consensus_dispatch_binding
    guarantees:
      - every bus message must reuse the convocation session_id and remain consensus-bus-only
      - dispatch plan, dispatch receipt, and every worker unit claim must be tracked by the audit summary
      - guardian gate and final resolve must bind the same dispatch_receipt_digest before the handoff is considered complete
      - direct builder-to-builder handoff attempts must be recorded as blocked and never silently bypass the bus
  bind_task_graph_dispatch:
    summary: >
      Collapse one coverage-complete worker dispatch into the selected proposal-profile's fixed
      three-root TaskGraph bundle strategy and bind it to the same Council session,
      ConsensusBus claim chain, guardian gate, and synthesis receipt.
    input:
      inline_schema:
        type: object
        required:
          - convocation_session
          - dispatch_plan
          - dispatch_receipt
          - consensus_binding
        properties:
          convocation_session:
            schema_ref: council_convocation_session
          dispatch_plan:
            schema_ref: yaoyorozu_worker_dispatch_plan
          dispatch_receipt:
            schema_ref: yaoyorozu_worker_dispatch_receipt
          consensus_binding:
            schema_ref: yaoyorozu_consensus_dispatch_binding
    output:
      schema_ref: yaoyorozu_task_graph_binding
    guarantees:
      - root TaskGraph bundles must stay within max_parallelism=3 and match the fixed bundle strategy selected by proposal_profile
      - every dispatch unit must bind exactly once to one ready root node together with its ConsensusBus report claim
      - guardian gate and final resolve digests must bind the review and synthesis nodes before the execution bundle is considered complete
      - synthesis must accept exactly one result ref per ready root node and must not bypass the Council review node
compatibility:
  stability: bootstrap
  notes:
    - The reference runtime supports the bounded `self-modify-patch-v1`, `memory-edit-v1`, `fork-request-v1`, and `inter-mind-negotiation-v1` proposal profiles.
    - Cross-workspace worker discovery is bounded to same-host local workspace catalogs with profile-aware review_budget, required coverage policy, and no external runtime execution.
    - ConsensusBus handoff binding is fixed to the same convocation session_id as the Council artifact.
    - TaskGraph bundle binding keeps the proposal profile's required worker coverage within the fixed 3-root complexity ceiling, with `self-modify` grouping eval+docs, `inter-mind-negotiation` grouping schema+docs, and `memory-edit` / `fork-request` binding one required surface per root node.
    - Live process orchestration is intentionally bounded to repo-local subprocess workers and not external runtimes.
