idl_version: 1
kind: service
namespace: agentic.yaoyorozu.v0
service: YaoyorozuRegistryService
summary: Repo-local agent registry sync plus digest-only source manifest ContinuityLedger binding, advisory researcher evidence exchange and multi-researcher synthesis binding, bounded same-host workspace discovery, Guardian-gated external workspace seeding and dependency materialization, Council convocation, same-session ConsensusBus and profile-aware TaskGraph handoff binding, path/delta/priority-ranked patch-candidate-bound local worker dispatch planning, an L5 build_request-ready handoff binding, and a reviewer-facing builder execution-chain binding.
imports:
  agent_source_definition: ../schemas/agent_source_definition.schema
  research_evidence_request: ../schemas/research_evidence_request.schema
  research_evidence_report: ../schemas/research_evidence_report.schema
  yaoyorozu_research_evidence_exchange: ../schemas/yaoyorozu_research_evidence_exchange.schema
  yaoyorozu_research_evidence_synthesis: ../schemas/yaoyorozu_research_evidence_synthesis.schema
  yaoyorozu_workspace_discovery: ../schemas/yaoyorozu_workspace_discovery.schema
  yaoyorozu_workspace_guardian_preseed_gate: ../schemas/yaoyorozu_workspace_guardian_preseed_gate.schema
  yaoyorozu_dependency_materialization_manifest: ../schemas/yaoyorozu_dependency_materialization_manifest.schema
  yaoyorozu_registry_snapshot: ../schemas/yaoyorozu_registry_snapshot.schema
  yaoyorozu_source_manifest_ledger_binding: ../schemas/yaoyorozu_source_manifest_ledger_binding.schema
  yaoyorozu_source_manifest_public_verification_bundle: ../schemas/yaoyorozu_source_manifest_public_verification_bundle.schema
  council_convocation_session: ../schemas/council_convocation_session.schema
  yaoyorozu_worker_dispatch_plan: ../schemas/yaoyorozu_worker_dispatch_plan.schema
  yaoyorozu_worker_dispatch_receipt: ../schemas/yaoyorozu_worker_dispatch_receipt.schema
  yaoyorozu_consensus_dispatch_binding: ../schemas/yaoyorozu_consensus_dispatch_binding.schema
  yaoyorozu_task_graph_binding: ../schemas/yaoyorozu_task_graph_binding.schema
  yaoyorozu_build_request_binding: ../schemas/yaoyorozu_build_request_binding.schema
  yaoyorozu_execution_chain_binding: ../schemas/yaoyorozu_execution_chain_binding.schema
  build_request: ../schemas/build_request.yaml
  build_artifact: ../schemas/build_artifact.yaml
  sandbox_apply_receipt: ../schemas/sandbox_apply_receipt.schema
  builder_live_enactment_session: ../schemas/builder_live_enactment_session.schema
  staged_rollout_session: ../schemas/staged_rollout_session.schema
  builder_rollback_session: ../schemas/builder_rollback_session.schema
  consensus_message: ../schemas/consensus_message.schema
operations:
  discover_workspace_workers:
    summary: >
      Discover one bounded same-host local workspace catalog of builder-capable agent registries
      before any cross-workspace builder handoff is considered, using the selected
      proposal profile's review budget and required coverage policy.
    input:
      inline_schema:
        type: object
        required:
          - workspace_roots
          - proposal_profile
        properties:
          workspace_roots:
            type: array
            minItems: 2
            maxItems: 3
            items:
              type: string
              minLength: 1
          proposal_profile:
            type: string
            enum:
              - self-modify-patch-v1
              - memory-edit-v1
              - fork-request-v1
              - inter-mind-negotiation-v1
          review_budget:
            type: integer
            minimum: 2
            maximum: 3
    output:
      schema_ref: yaoyorozu_workspace_discovery
    guarantees:
      - discovery must stay on the same host and only scan explicit local workspace_roots
      - proposal_profile must fix the review budget, required coverage areas, and TaskGraph bundle strategy echoed by the discovery output
      - accepted workspaces must expose builder agents, machine-readable role/capability indexes, and coverage summaries
      - review_budget must cap accepted workspaces and preserve the input ordering of source then accepted candidates
  sync_registry:
    summary: Materialize one trust-bound registry snapshot from repo-local agents/ definitions.
    input:
      inline_schema:
        type: object
        required:
          - source_root
        properties:
          source_root:
            type: string
            const: agents
    output:
      schema_ref: yaoyorozu_registry_snapshot
    guarantees:
      - synced entries must remain bound to repo-local agents/ definitions
      - raw agent definitions must satisfy agent_source_definition before registry materialization
      - councilor definitions must bind non-empty deliberation_scope_refs and deliberation_policy_ref before registry materialization
      - researcher definitions must bind non-empty research_domain_refs and evidence_policy_ref before registry materialization
      - researcher definitions must use research_evidence_request and research_evidence_report schema refs instead of Council session schemas
      - builder definitions must bind non-empty build_surface_refs and execution_policy_ref before registry materialization
      - guardian definitions must bind non-empty oversight_scope_refs and attestation_policy_ref before registry materialization
      - every entry must carry a trust_snapshot and trust_floor
      - role_index and capability_index must remain machine-readable
      - source_definition_digests must bind every raw agents/**/*.yaml file by source_ref, agent_id, role, sha256, and byte_length
      - source_manifest_digest must be derived from the ordered source_definition_digests while raw_source_payload_stored remains false
      - councilor registry entries must preserve deliberation surface refs and deliberation policy refs without storing raw deliberation transcripts
      - researcher registry entries must preserve research domain refs, evidence policy refs, and role-specific evidence schema refs without storing raw research payloads
      - builder registry entries must preserve repo-local build surface refs and execution policy refs before handoff
      - guardian registry entries must preserve reviewer-facing oversight scope refs and attestation policy refs without storing raw audit payloads
  bind_source_manifest_ledger_entry:
    summary: >
      Bind one registry source digest manifest to a self+guardian signed ContinuityLedger entry
      without storing raw agent source definitions or the raw registry payload.
    input:
      inline_schema:
        type: object
        required:
          - registry_snapshot
        properties:
          registry_snapshot:
            schema_ref: yaoyorozu_registry_snapshot
    output:
      schema_ref: yaoyorozu_source_manifest_ledger_binding
    guarantees:
      - source_definition_digests must remain ordered and match source_manifest_digest
      - continuity_event_digest must be derived from the digest-only event payload
      - ContinuityLedger category must be yaoyorozu-agent-source-manifest
      - ledger entry must be signed by self and guardian roles
      - public verification bundle must bind the same source manifest digest, ledger entry ref/hash/payload ref, self+guardian signature digests, and verifier key refs
      - public verification bundle must expose no raw source, registry, continuity event, or signature payload
      - raw_source_payload_stored, raw_registry_payload_stored, and raw_continuity_event_payload_stored must remain false
  bind_research_evidence_exchange:
    summary: >
      Bind one selected researcher request/report pair to the synced registry source manifest,
      repo-local evidence digest, and a Council+Guardian signed ContinuityLedger entry without
      granting decision authority or storing raw research payloads.
    input:
      inline_schema:
        type: object
        required:
          - registry_snapshot
          - requested_by_ref
        properties:
          registry_snapshot:
            schema_ref: yaoyorozu_registry_snapshot
          requested_by_ref:
            type: string
            pattern: "^(council|guardian|selfctor|agent)://"
          preferred_researcher_agent_id:
            type: string
            default: neuroscience-scout
    output:
      schema_ref: yaoyorozu_research_evidence_exchange
    guarantees:
      - selected researcher must be a researcher registry entry with role-specific research_evidence_request and research_evidence_report schema refs
      - request_digest and report_digest must bind the nested request/report payloads
      - report evidence_items must bind repo-local evidence refs and digests while raw_research_payload_stored remains false
      - claim_ceiling must remain implementation-advisory and all design implications must be advisory-only
      - decision_authority_claimed and request decision_authority_allowed must remain false
      - ContinuityLedger event must use the yaoyorozu-research-evidence category and council+guardian signature roles
      - exchange_digest must bind the researcher source digest, request/report digests, evidence refs, and ledger entry refs
  synthesize_research_evidence:
    summary: >
      Reduce multiple ledger-appended researcher request/report exchanges into one digest-only
      Council synthesis receipt without storing raw exchange or research payloads.
    input:
      inline_schema:
        type: object
        required:
          - exchange_receipts
          - registry_snapshot
          - council_session_ref
        properties:
          exchange_receipts:
            type: array
            minItems: 2
            items:
              schema_ref: yaoyorozu_research_evidence_exchange
          registry_snapshot:
            schema_ref: yaoyorozu_registry_snapshot
          council_session_ref:
            type: string
            pattern: "^council://session/"
    output:
      schema_ref: yaoyorozu_research_evidence_synthesis
    guarantees:
      - synthesis must require at least two distinct researcher_agent_ids
      - every source exchange must already be valid, ledger-appended, and bound to the same registry snapshot and source manifest digest
      - exchange_refs, exchange_digests, research_domain_refs, evidence_refs, and evidence_digest_set must be derived from the source exchanges
      - synthesis must remain implementation-advisory and advisory-only
      - raw exchange payloads, raw research payloads, and researcher decision authority must remain absent
      - synthesis receipt must be appended to ContinuityLedger with council and guardian signature roles
  prepare_council_convocation:
    summary: >
      Derive one deterministic Council convocation and builder handoff plan from the synced registry,
      optionally binding the selected workspace-discovery policy and its accepted candidate set.
    input:
      inline_schema:
        type: object
        required:
          - proposal_profile
          - session_mode
          - target_identity_ref
          - workspace_discovery
        properties:
          proposal_profile:
            type: string
            enum:
              - self-modify-patch-v1
              - memory-edit-v1
              - fork-request-v1
              - inter-mind-negotiation-v1
          session_mode:
            type: string
            enum:
              - standard
              - expedited
          target_identity_ref:
            type: string
          requested_optional_builder_coverage_areas:
            type: array
            uniqueItems: true
            items:
              type: string
              enum:
                - runtime
                - schema
                - eval
                - docs
          workspace_discovery:
            schema_ref: yaoyorozu_workspace_discovery
    output:
      schema_ref: council_convocation_session
    guarantees:
      - standing roles must include speaker, recorder, guardian_liaison, and self_liaison
      - when workspace_discovery is bound, its proposal_profile and profile policy must match the selected convocation profile
      - council panel must satisfy weighted vote quorum before emit_build_request
      - selected Councilor, Guardian, and Builder entries must carry registry-selection-scope-binding-v1 scope refs and policy refs without raw deliberation, audit, or build payloads
      - proposal_profile must fix the required and optional builder coverage policy surfaced by the convocation artifact
      - requested_optional_builder_coverage_areas, when present, must stay within the selected profile's optional coverage and become first-class dispatch_builder_coverage_areas
      - each selected Builder handoff must bind coverage_area to fixed coverage_target_path_refs using coverage-area-target-path-binding-v1
      - selected Builder build_surface_refs must cover every target path ref bound to its coverage_area
  prepare_worker_dispatch:
    summary: >
      Convert one selected bounded Yaoyorozu convocation into a same-host worker dispatch plan
      that launches bounded builder processes for the proposal profile's required worker coverage plus any explicitly requested optional coverage.
    input:
      inline_schema:
        type: object
        required:
          - convocation_session
        properties:
          convocation_session:
            schema_ref: council_convocation_session
    output:
      schema_ref: yaoyorozu_worker_dispatch_plan
    guarantees:
      - dispatch units must be derived only from selected builder_handoff entries
      - proposal_profile must fix the required and optional worker coverage policy echoed by the dispatch plan summary
      - requested optional worker coverage, when present, must remain a subset of the proposal profile's optional coverage and bind dispatch_coverage_areas deterministically
      - every command preview must remain same-host, subprocess-bound, and temp-workspace-only
      - when workspace_discovery is bound, every dispatch unit must choose one profile-covered candidate workspace and bind execution_workspace_ref, selected_workspace_root, execution_workspace_root, and sandbox_seed_strategy
      - same-host external workspace units must carry one integrity Guardian preseed gate that passes before workspace seed, execution-root creation, or dependency materialization
      - same-host external workspace units must declare the fixed dependency materialization profile and source runtime dependency snapshot path set in the dispatch plan
      - external preseed gates must bind a satisfied HumanOversightChannel reviewer-network attested oversight event before the gate is considered ready
      - every dispatch_coverage_area must map to exactly one dispatch unit
  execute_worker_dispatch:
    summary: >
      Execute one same-host worker dispatch plan as bounded subprocess workers and return
      the resulting process-bound execution receipt.
    input:
      inline_schema:
        type: object
        required:
          - dispatch_plan
        properties:
          dispatch_plan:
            schema_ref: yaoyorozu_worker_dispatch_plan
    output:
      schema_ref: yaoyorozu_worker_dispatch_receipt
    guarantees:
      - every launched worker must emit a ready report bound to the same dispatch_plan_ref and dispatch_unit_ref
      - external candidate workers must have a passing same-host-external-workspace-preseed-guardian-gate-v1 artifact before any snapshot seed, execution root creation, or dependency materialization occurs
      - external candidate workers must carry the preseed gate's oversight event ref, digest, reviewer quorum, and verifier-network attestation status into the dispatch receipt
      - external candidate workers must first receive a source target-path snapshot copy in an execution workspace with a seed commit receipt and a same-host-external-workspace-dependency-materialization-v1 manifest for the minimal runtime dependency snapshot
      - external candidate dependency manifests must bind a materialized-dependency-lockfile-v1 digest and a materialized-dependency-wheel-attestation-v1 sealed wheel artifact digest before worker launch
      - external candidate workers must launch with materialized-dependency-sealed-import-v1 import isolation, placing only the materialized dependency src root in the receipt-bound path order and omitting the source checkout fallback
      - external candidate workers must bind materialized-dependency-module-origin-v1 so the emitted worker_module_origin proves omoikane.agentic.local_worker_stub was imported from the sealed materialized dependency snapshot
      - worker reports must verify that every target path exists and remains inside the selected execution workspace
      - worker reports must bind one git-target-path delta receipt that stays inside the same target_paths and dispatch unit
      - worker reports must materialize one patch_descriptor-compatible patch candidate receipt from the same delta evidence before the ready gate passes
      - patch candidate receipts must expose deterministic priority ranks and top-priority summaries so builder apply review stays machine-checkable
      - worker execution must stay inside repo-local or same-host-external-workspace scope and inherit the dispatch profile
      - only zero-exit, ready-reported workers count toward completed dispatch coverage, including explicitly requested optional coverage
  bind_consensus_dispatch:
    summary: >
      Bind one convocation, worker dispatch plan, and worker dispatch receipt to the same
      ConsensusBus session with builder reports, guardian gate, and blocked direct handoff evidence.
    input:
      inline_schema:
        type: object
        required:
          - convocation_session
          - dispatch_plan
          - dispatch_receipt
          - messages
          - blocked_direct_attempt
          - audit_summary
        properties:
          convocation_session:
            schema_ref: council_convocation_session
          dispatch_plan:
            schema_ref: yaoyorozu_worker_dispatch_plan
          dispatch_receipt:
            schema_ref: yaoyorozu_worker_dispatch_receipt
          messages:
            type: array
            items:
              schema_ref: consensus_message
          blocked_direct_attempt:
            type: object
            required:
              - session_id
              - status
              - enforced_policy
            properties:
              session_id:
                type: string
              status:
                type: string
                const: blocked
              enforced_policy:
                type: string
                const: consensus-bus-only
          audit_summary:
            type: object
            required:
              - session_id
              - blocked_direct_attempts
              - all_transport_bus_only
              - guardian_gate_present
              - resolve_present
              - ordered_phases
              - related_claim_ids
            properties:
              session_id:
                type: string
              blocked_direct_attempts:
                type: integer
                const: 1
              all_transport_bus_only:
                type: boolean
                const: true
              guardian_gate_present:
                type: boolean
                const: true
              resolve_present:
                type: boolean
                const: true
              ordered_phases:
                type: boolean
                const: true
              related_claim_ids:
                type: array
                items:
                  type: string
    output:
      schema_ref: yaoyorozu_consensus_dispatch_binding
    guarantees:
      - every bus message must reuse the convocation session_id and remain consensus-bus-only
      - dispatch plan, dispatch receipt, and every worker unit claim must be tracked by the audit summary
      - guardian gate and final resolve must bind the same dispatch_receipt_digest before the handoff is considered complete
      - direct builder-to-builder handoff attempts must be recorded as blocked and never silently bypass the bus
  bind_task_graph_dispatch:
    summary: >
      Collapse one coverage-complete worker dispatch into the selected proposal-profile's fixed
      three-root TaskGraph bundle strategy and bind it to the same Council session,
      ConsensusBus claim chain, guardian gate, and synthesis receipt.
    input:
      inline_schema:
        type: object
        required:
          - convocation_session
          - dispatch_plan
          - dispatch_receipt
          - consensus_binding
        properties:
          convocation_session:
            schema_ref: council_convocation_session
          dispatch_plan:
            schema_ref: yaoyorozu_worker_dispatch_plan
          dispatch_receipt:
            schema_ref: yaoyorozu_worker_dispatch_receipt
          consensus_binding:
            schema_ref: yaoyorozu_consensus_dispatch_binding
    output:
      schema_ref: yaoyorozu_task_graph_binding
    guarantees:
      - root TaskGraph bundles must stay within max_parallelism=3 and match the fixed bundle strategy selected by proposal_profile plus requested optional worker coverage, when present
      - every dispatch unit must bind exactly once to one ready root node together with its ConsensusBus report claim
      - guardian gate and final resolve digests must bind the review and synthesis nodes before the execution bundle is considered complete
      - synthesis must accept exactly one result ref per ready root node and must not bypass the Council review node
  bind_build_request_handoff:
    summary: >
      Promote one Yaoyorozu convocation, worker dispatch, ConsensusBus transcript, and TaskGraph bundle
      into an L5 build_request handoff that remains patch-generator-ready while keeping
      priority-ranked patch candidate evidence attached for builder apply review.
    input:
      inline_schema:
        type: object
        required:
          - convocation_session
          - dispatch_plan
          - dispatch_receipt
          - consensus_binding
          - task_graph_binding
        properties:
          convocation_session:
            schema_ref: council_convocation_session
          dispatch_plan:
            schema_ref: yaoyorozu_worker_dispatch_plan
          dispatch_receipt:
            schema_ref: yaoyorozu_worker_dispatch_receipt
          consensus_binding:
            schema_ref: yaoyorozu_consensus_dispatch_binding
          task_graph_binding:
            schema_ref: yaoyorozu_task_graph_binding
    output:
      schema_ref: yaoyorozu_build_request_binding
    guarantees:
      - build_request approval_context must reuse the convocation session_id and guardian gate pass from the same Council session
      - build_request allowed_write_paths and output_paths must remain within the bounded repo-local workspace_scope while staying patch-generator-ready
      - the emitted build_request must keep `evals/continuity/council_output_build_request_pipeline.yaml` plus one proposal-profile-aware Yaoyorozu eval in must_pass
      - selected patch candidates, when present, must preserve deterministic priority order and remain bound to the same dispatch receipt digests exposed to builder review
  bind_execution_chain:
    summary: >
      Extend one same-session Yaoyorozu build_request handoff into a reviewer-facing builder
      execution chain that binds build artifact, sandbox apply, live enactment, staged rollout,
      and rollback witness artifacts under the same digest family.
    input:
      inline_schema:
        type: object
        required:
          - build_request_binding
          - build_artifact
          - sandbox_apply_receipt
          - live_enactment_session
          - rollout_session
          - rollback_session
        properties:
          build_request_binding:
            schema_ref: yaoyorozu_build_request_binding
          build_artifact:
            schema_ref: build_artifact
          sandbox_apply_receipt:
            schema_ref: sandbox_apply_receipt
          live_enactment_session:
            schema_ref: builder_live_enactment_session
          rollout_session:
            schema_ref: staged_rollout_session
          rollback_session:
            schema_ref: builder_rollback_session
    output:
      schema_ref: yaoyorozu_execution_chain_binding
    guarantees:
      - every downstream artifact must reuse the same build_request.request_id and remain digest-bound to the selected build_request_binding
      - sandbox apply must stay rollback-ready and bind the same rollback_plan_ref emitted by the build_artifact
      - live enactment and rollback witness must both carry reviewer-network-attested Guardian oversight evidence before the chain is considered complete
      - reviewer-facing required_eval_refs must preserve the original build_request must_pass set while adding Yaoyorozu execution-chain plus builder live/rollback review refs
compatibility:
  stability: bootstrap
  notes:
    - The reference runtime supports the bounded `self-modify-patch-v1`, `memory-edit-v1`, `fork-request-v1`, and `inter-mind-negotiation-v1` proposal profiles.
    - Cross-workspace worker discovery and execution are bounded to same-host local workspace catalogs, profile-aware review_budget, source target-path snapshot seeding, and local Python subprocess transport.
    - ConsensusBus handoff binding is fixed to the same convocation session_id as the Council artifact.
    - TaskGraph bundle binding keeps the proposal profile's dispatch coverage within the fixed 3-root complexity ceiling, with `self-modify` grouping eval+docs, `inter-mind-negotiation` grouping schema+docs, `memory-edit` optionally grouping eval+schema, and `fork-request` optionally grouping docs+eval.
    - L5 build_request handoff binding is fixed to `L5.PatchGenerator`, `emit_build_request`, and a patch-generator-allowed scope before the same-request execution chain extends to build_artifact, sandbox apply, live enactment, and rollback witness artifacts.
    - Live process orchestration is intentionally bounded to repo-local or same-host-external-workspace subprocess workers and not remote runtimes.
