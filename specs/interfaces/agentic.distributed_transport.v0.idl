idl_version: 1
kind: service
namespace: agentic.distributed_transport.v0
service: DistributedTransportService
summary: Participant-attested remote handoff and receipt verification contract for distributed council reviews.
imports:
  distributed_participant_attestation: ../schemas/distributed_participant_attestation.schema
  distributed_transport_envelope: ../schemas/distributed_transport_envelope.schema
  distributed_transport_receipt: ../schemas/distributed_transport_receipt.schema
  distributed_transport_relay_telemetry: ../schemas/distributed_transport_relay_telemetry.schema
  distributed_transport_root_directory: ../schemas/distributed_transport_root_directory.schema
  distributed_transport_authority_plane: ../schemas/distributed_transport_authority_plane.schema
  distributed_transport_authority_cluster_discovery: ../schemas/distributed_transport_authority_cluster_discovery.schema
  distributed_transport_authority_route_target_discovery: ../schemas/distributed_transport_authority_route_target_discovery.schema
  distributed_transport_authority_churn_window: ../schemas/distributed_transport_authority_churn_window.schema
  distributed_transport_os_observer_receipt: ../schemas/distributed_transport_os_observer_receipt.schema
  distributed_transport_authority_route_trace: ../schemas/distributed_transport_authority_route_trace.schema
  distributed_transport_packet_capture_export: ../schemas/distributed_transport_packet_capture_export.schema
  distributed_transport_privileged_capture_acquisition: ../schemas/distributed_transport_privileged_capture_acquisition.schema
operations:
  issue_federation_handoff:
    summary: >
      Bind one cross-self distributed council request to a Federation transport envelope
      with self-liaison quorum and guardian channel attestation.
    input:
      inline_schema:
        type: object
        required:
          - topology_ref
          - proposal_ref
          - payload_ref
          - payload_digest
          - participant_identity_ids
        properties:
          topology_ref:
            type: string
            minLength: 1
          proposal_ref:
            type: string
            minLength: 1
          payload_ref:
            type: string
            minLength: 1
          payload_digest:
            type: string
            pattern: "^[a-f0-9]{64}$"
          participant_identity_ids:
            type: array
            minItems: 2
            items:
              type: string
              minLength: 1
    output:
      schema_ref: distributed_transport_envelope
    guarantees:
      - council_tier must equal federation
      - transport_profile must equal federation-mtls-quorum-v1
      - required_roles must bind 2 self-liaison participants and 1 guardian
      - channel_binding_ref must be envelope-unique and route_nonce-bound
  issue_heritage_handoff:
    summary: >
      Bind one interpretive distributed council request to a Heritage transport envelope
      with fixed reviewer roles and clause-bound recipient routing.
    input:
      inline_schema:
        type: object
        required:
          - topology_ref
          - proposal_ref
          - payload_ref
          - payload_digest
          - referenced_clauses
        properties:
          topology_ref:
            type: string
            minLength: 1
          proposal_ref:
            type: string
            minLength: 1
          payload_ref:
            type: string
            minLength: 1
          payload_digest:
            type: string
            pattern: "^[a-f0-9]{64}$"
          referenced_clauses:
            type: array
            minItems: 1
            items:
              type: string
              minLength: 1
    output:
      schema_ref: distributed_transport_envelope
    guarantees:
      - council_tier must equal heritage
      - transport_profile must equal heritage-attested-review-v1
      - required_roles must bind 2 cultural representatives plus legal-advisor and ethics-committee
      - recipient_endpoint must remain clause-bound and fail closed on missing clause refs
  rotate_transport_keys:
    summary: >
      Rotate one distributed transport envelope onto a new key epoch and federated trust-root set
      while preserving overlap with the previous epoch during the handoff window.
    input:
      inline_schema:
        type: object
        required:
          - envelope_ref
          - envelope_digest
          - next_key_epoch
          - trust_root_refs
          - trust_root_quorum
        properties:
          envelope_ref:
            type: string
            minLength: 1
          envelope_digest:
            type: string
            pattern: "^[a-f0-9]{64}$"
          next_key_epoch:
            type: integer
            minimum: 2
          trust_root_refs:
            type: array
            minItems: 1
            uniqueItems: true
            items:
              type: string
              minLength: 1
          trust_root_quorum:
            type: integer
            minimum: 1
    output:
      schema_ref: distributed_transport_envelope
    guarantees:
      - next_key_epoch must be greater than the current key_epoch
      - accepted_key_epochs must retain the previous epoch during overlap
      - federated root verification must require trust_root_quorum distinct roots
  probe_live_root_directory:
    summary: >
      Probe one live remote PKI root-directory endpoint and bind the reachable root quorum
      to a rotated distributed transport envelope before receipt verification.
    input:
      inline_schema:
        type: object
        required:
          - envelope_ref
          - envelope_digest
          - directory_endpoint
        properties:
          envelope_ref:
            type: string
            minLength: 1
          envelope_digest:
            type: string
            pattern: "^[a-f0-9]{64}$"
          directory_endpoint:
            type: string
            pattern: "^https?://"
          request_timeout_ms:
            type: integer
            minimum: 1
    output:
      schema_ref: distributed_transport_root_directory
    guarantees:
      - live root directory must match envelope council_tier and transport_profile
      - live root directory key_epoch must remain inside accepted_key_epochs
      - trusted_root_refs must satisfy trust_root_quorum before a rotated receipt can authenticate
      - connectivity_receipt must bind endpoint, response_digest, latency, and quorum outcome
  probe_authority_plane:
    summary: >
      Probe one bounded external key-server fleet and bind its reachable authority members
      to a rotated distributed transport envelope after live root-directory federation,
      while retaining active root coverage across draining-member churn.
    input:
      inline_schema:
        type: object
        required:
          - envelope_ref
          - envelope_digest
          - directory_ref
          - authority_endpoints
        properties:
          envelope_ref:
            type: string
            minLength: 1
          envelope_digest:
            type: string
            pattern: "^[a-f0-9]{64}$"
          directory_ref:
            type: string
            pattern: "^rootdir://"
          authority_endpoints:
            type: array
            minItems: 1
            uniqueItems: true
            items:
              type: string
              pattern: "^https?://"
          request_timeout_ms:
            type: integer
            minimum: 1
    output:
      schema_ref: distributed_transport_authority_plane
    guarantees:
      - authority plane must match the envelope council_tier and transport_profile
      - every reachable key server must advertise a key_epoch accepted by both the envelope and root directory
      - trusted_root_refs must satisfy trust_root_quorum across the reachable key-server fleet
      - every trusted_root_ref must retain at least one active key server during draining overlap
      - churn_profile must equal overlap-safe-authority-handoff-v1 when draining members remain in the fleet
      - each key server receipt must bind endpoint, response_digest, latency, and matched_root_refs
  reconcile_authority_churn:
    summary: >
      Reconcile two authority-plane snapshots into one machine-checkable churn window
      that proves overlap retention, draining-only removal, and preserved root quorum.
    input:
      inline_schema:
        type: object
        required:
          - previous_authority_plane_ref
          - previous_authority_plane_digest
          - next_authority_plane_ref
          - next_authority_plane_digest
        properties:
          previous_authority_plane_ref:
            type: string
            pattern: "^authority-plane://"
          previous_authority_plane_digest:
            type: string
            pattern: "^[a-f0-9]{64}$"
          next_authority_plane_ref:
            type: string
            pattern: "^authority-plane://"
          next_authority_plane_digest:
            type: string
            pattern: "^[a-f0-9]{64}$"
    output:
      schema_ref: distributed_transport_authority_churn_window
    guarantees:
      - authority churn must retain at least one overlapping key server whenever membership changes
      - removed key servers must have been previously marked draining
      - quorum_requirement and trusted_root_refs must remain sufficient after churn
      - churn_profile must equal bounded-key-server-churn-window-v1
  discover_remote_authority_clusters:
    summary: >
      Probe one or more live remote authority-cluster seeds, reduce their candidate route targets
      through a review-capped selection step, and emit one accepted route catalog bound to the
      current active authority-plane membership before bounded route-target discovery continues.
    input:
      inline_schema:
        type: object
        required:
          - authority_plane_ref
          - authority_plane_digest
          - seed_refs
        properties:
          authority_plane_ref:
            type: string
            pattern: "^authority-plane://"
          authority_plane_digest:
            type: string
            pattern: "^[a-f0-9]{64}$"
          seed_refs:
            type: array
            minItems: 1
            uniqueItems: true
            items:
              type: string
              pattern: "^https?://"
          review_budget:
            type: integer
            minimum: 1
          request_timeout_ms:
            type: integer
            minimum: 1
    output:
      schema_ref: distributed_transport_authority_cluster_discovery
    guarantees:
      - review_budget must cover every probed seed_ref
      - accepted discovery must cover every reachable active authority-plane member
      - accepted clusters require complete remote_host_attestation_ref coverage
      - accepted_route_catalog must preserve authority-plane server_role, authority_status, and matched_root_refs for each discovered target
  discover_authority_route_targets:
    summary: >
      Bind one bounded reviewed route catalog, or one accepted route catalog emitted from
      review-capped remote authority-cluster discovery, to the currently reachable active
      authority-plane members so non-loopback mTLS tracing is driven by a first-class discovery
      receipt rather than a raw ad hoc route_targets list.
    input:
      inline_schema:
        type: object
        required:
          - authority_plane_ref
          - authority_plane_digest
          - route_catalog
        properties:
          authority_plane_ref:
            type: string
            pattern: "^authority-plane://"
          authority_plane_digest:
            type: string
            pattern: "^[a-f0-9]{64}$"
          route_catalog:
            type: array
            minItems: 1
            uniqueItems: true
            items:
              type: object
              required:
                - key_server_ref
                - server_endpoint
                - server_name
                - remote_host_ref
                - remote_host_attestation_ref
                - authority_cluster_ref
                - remote_jurisdiction
                - remote_network_zone
              properties:
                key_server_ref:
                  type: string
                  pattern: "^keyserver://"
                server_endpoint:
                  type: string
                  pattern: "^https://"
                server_name:
                  type: string
                  minLength: 1
                remote_host_ref:
                  type: string
                  pattern: "^host://"
                remote_host_attestation_ref:
                  type: string
                  pattern: "^host-attestation://"
                authority_cluster_ref:
                  type: string
                  pattern: "^authority-cluster://"
                remote_jurisdiction:
                  type: string
                  minLength: 1
                remote_network_zone:
                  type: string
                  minLength: 1
    output:
      schema_ref: distributed_transport_authority_route_target_discovery
    guarantees:
      - discovery must cover every reachable active authority-plane member
      - every discovered target must bind server_endpoint, server_name, remote_host_ref, and remote_host_attestation_ref
      - authority_cluster_ref must remain identical across the bounded discovery set
      - discovery must retain authority-plane server_role, authority_status, and matched_root_refs for every route target
  trace_non_loopback_authority_routes:
    summary: >
      Establish actual non-loopback mTLS routes to the currently reachable authority-plane members
      and bind socket-level trace evidence, OS-native TCP observer receipts, certificate
      fingerprints, response digests, and attested remote host/cluster identity to the
      rotated distributed transport envelope.
    input:
      inline_schema:
        type: object
        required:
          - envelope_ref
          - envelope_digest
          - authority_plane_ref
          - authority_plane_digest
          - route_target_discovery_ref
          - route_target_discovery_digest
          - ca_bundle_ref
          - client_certificate_ref
        properties:
          envelope_ref:
            type: string
            pattern: "^distributed-envelope-"
          envelope_digest:
            type: string
            pattern: "^[a-f0-9]{64}$"
          authority_plane_ref:
            type: string
            pattern: "^authority-plane://"
          authority_plane_digest:
            type: string
            pattern: "^[a-f0-9]{64}$"
          route_target_discovery_ref:
            type: string
            pattern: "^authority-route-targets://"
          route_target_discovery_digest:
            type: string
            pattern: "^[a-f0-9]{64}$"
          ca_bundle_ref:
            type: string
            minLength: 1
          client_certificate_ref:
            type: string
            minLength: 1
          request_timeout_ms:
            type: integer
            minimum: 1
    output:
      schema_ref: distributed_transport_authority_route_trace
    guarantees:
      - route trace must cover every reachable authority-plane member
      - every traced route must negotiate mTLS and bind both peer and client certificate fingerprints
      - remote socket endpoints must be non-loopback before the trace can authenticate
      - every traced response digest must match the currently bound authority-plane member payload
      - socket trace must capture local/remote endpoint tuple, tls version, cipher suite, and byte counts
      - OS observer receipts must capture the same TCP tuple from at least 1 OS source such as netstat or lsof while the route is live
      - route_target_discovery must cover every active authority-plane member and remain bound to exactly 1 authority_cluster_ref
      - cross_host_verified may become true only when every traced authority-plane member binds a distinct remote_host_ref
  export_authority_route_packet_capture:
    summary: >
      Export one authenticated authority-route trace into a trace-bound PCAP artifact,
      verify it with in-process readback, and optionally bind tcpdump readback when available.
    input:
      inline_schema:
        type: object
        required:
          - trace_ref
          - trace_digest
          - authority_plane_ref
          - authority_plane_digest
        properties:
          trace_ref:
            type: string
            pattern: "^authority-route-trace://"
          trace_digest:
            type: string
            pattern: "^[a-f0-9]{64}$"
          authority_plane_ref:
            type: string
            pattern: "^authority-plane://"
          authority_plane_digest:
            type: string
            pattern: "^[a-f0-9]{64}$"
    output:
      schema_ref: distributed_transport_packet_capture_export
    guarantees:
      - packet capture export requires an authenticated authority-route trace
      - exported PCAP must contain one outbound request packet and one inbound response packet per traced authority member
      - in-process readback must recover the same TCP tuples and payload lengths recorded by the route trace
      - tcpdump readback is optional, but when available it must confirm every exported route tuple
  acquire_privileged_interface_capture:
    summary: >
      Acquire one delegated privileged live-capture lease for an authenticated authority-route trace
      by binding the resolved host interface, exact route filter, and broker-issued command preview.
    input:
      inline_schema:
        type: object
        required:
          - trace_ref
          - trace_digest
          - capture_ref
          - capture_digest
          - authority_plane_ref
          - authority_plane_digest
          - broker_command
        properties:
          trace_ref:
            type: string
            pattern: "^authority-route-trace://"
          trace_digest:
            type: string
            pattern: "^[a-f0-9]{64}$"
          capture_ref:
            type: string
            pattern: "^authority-packet-capture://"
          capture_digest:
            type: string
            pattern: "^[a-f0-9]{64}$"
          authority_plane_ref:
            type: string
            pattern: "^authority-plane://"
          authority_plane_digest:
            type: string
            pattern: "^[a-f0-9]{64}$"
          broker_command:
            type: array
            minItems: 1
            items:
              type: string
              minLength: 1
          lease_duration_s:
            type: integer
            minimum: 1
    output:
      schema_ref: distributed_transport_privileged_capture_acquisition
    guarantees:
      - privileged capture acquisition requires an authenticated authority-route trace and a verified packet-capture export
      - all traced local IPs must resolve to exactly 1 host interface before a lease can be granted
      - the capture filter must bind every traced route in both directions
      - the delegated broker must echo the resolved interface, filter digest, and full route binding set
      - the capture command preview must bind tcpdump, the resolved interface, and the exact capture filter
  record_receipt:
    summary: >
      Verify one returned remote receipt against its transport envelope, attested participant set,
      authenticated channel binding, and single-use replay guard.
    input:
      inline_schema:
        type: object
        required:
          - envelope_ref
          - envelope_digest
          - channel_binding_ref
          - route_nonce
          - result_ref
          - result_digest
          - participant_ids
        properties:
          envelope_ref:
            type: string
            minLength: 1
          envelope_digest:
            type: string
            pattern: "^[a-f0-9]{64}$"
          channel_binding_ref:
            type: string
            minLength: 1
          route_nonce:
            type: string
            minLength: 1
          result_ref:
            type: string
            minLength: 1
          result_digest:
            type: string
            pattern: "^[a-f0-9]{64}$"
          participant_ids:
            type: array
            minItems: 1
            items:
              type: string
              minLength: 1
          verified_root_refs:
            type: array
            minItems: 1
            uniqueItems: true
            items:
              type: string
              minLength: 1
          key_epoch:
            type: integer
            minimum: 1
          hop_nonce_chain:
            type: array
            minItems: 1
            items:
              type: string
              minLength: 1
    output:
      schema_ref: distributed_transport_receipt
    guarantees:
      - receipt_status must equal authenticated only when channel_authenticated, required_roles_satisfied, quorum_attested, federated_roots_verified, and key_epoch_accepted are all true
      - replay_guard_status must become blocked on any second use of the same route_nonce
      - multi_hop_replay_status must become blocked on any reused hop_nonce_chain
      - participant_bindings must retain attestation_ref and proof_ref for every accepted participant
  capture_relay_telemetry:
    summary: >
      Capture one machine-checkable relay-path telemetry snapshot for a distributed receipt
      while preserving hop order, observed latency, seen trust roots, and anti-replay state.
    input:
      inline_schema:
        type: object
        required:
          - envelope_ref
          - envelope_digest
          - receipt_ref
          - receipt_digest
          - relay_path
        properties:
          envelope_ref:
            type: string
            minLength: 1
          envelope_digest:
            type: string
            pattern: "^[a-f0-9]{64}$"
          receipt_ref:
            type: string
            minLength: 1
          receipt_digest:
            type: string
            pattern: "^[a-f0-9]{64}$"
          relay_path:
            type: array
            minItems: 1
            items:
              type: object
              required:
                - relay_id
                - relay_endpoint
                - jurisdiction
                - network_zone
                - observed_latency_ms
              properties:
                relay_id:
                  type: string
                  minLength: 1
                relay_endpoint:
                  type: string
                  minLength: 1
                jurisdiction:
                  type: string
                  minLength: 1
                network_zone:
                  type: string
                  minLength: 1
                transport_layer:
                  type: string
                  minLength: 1
                observed_latency_ms:
                  type: number
                  exclusiveMinimum: 0
                root_refs_seen:
                  type: array
                  minItems: 1
                  uniqueItems: true
                  items:
                    type: string
                    minLength: 1
                observed_at:
                  type: string
                  format: date-time
    output:
      schema_ref: distributed_transport_relay_telemetry
    guarantees:
      - hop_count must equal the length of the receipt hop_nonce_chain and must not exceed max_hops
      - anti_replay_status must mirror the receipt multi_hop_replay_status
      - replay_guard_status must mirror the receipt replay_guard_status
      - root_quorum_met must mirror the receipt federated_roots_verified result
      - final relay hop delivery_status must equal the receipt_status
events:
  distributed.transport_issued:
    payload:
      schema_ref: distributed_transport_envelope
  distributed.transport_rotated:
    payload:
      schema_ref: distributed_transport_envelope
  distributed.transport_received:
    payload:
      schema_ref: distributed_transport_receipt
  distributed.transport_telemetry_captured:
    payload:
      schema_ref: distributed_transport_relay_telemetry
  distributed.transport_authority_cluster_discovered:
    payload:
      schema_ref: distributed_transport_authority_cluster_discovery
  distributed.transport_authority_route_targets_discovered:
    payload:
      schema_ref: distributed_transport_authority_route_target_discovery
  distributed.transport_authority_route_traced:
    payload:
      schema_ref: distributed_transport_authority_route_trace
  distributed.transport_packet_capture_exported:
    payload:
      schema_ref: distributed_transport_packet_capture_export
  distributed.transport_privileged_capture_acquired:
    payload:
      schema_ref: distributed_transport_privileged_capture_acquisition
compatibility:
  stability: bootstrap
  notes:
    - This contract fixes the in-repo reference profile for participant attestation, key-epoch overlap, live root-directory federation, bounded key-server fleet binding, churn reconciliation, review-capped remote authority-cluster discovery, non-loopback mTLS authority routing, cross-host host/cluster binding, trace-bound PCAP export, delegated privileged live-capture acquisition, multi-hop anti-replay, and bounded relay telemetry.
    - Reviewed route catalogs remain supported as a curated ingress, and remote authority-cluster seeds are reduced to one accepted route catalog before route tracing proceeds.
