idl_version: 1
kind: service
namespace: agentic.distributed_transport.v0
service: DistributedTransportService
summary: Participant-attested remote handoff and receipt verification contract for distributed council reviews.
imports:
  distributed_participant_attestation: ../schemas/distributed_participant_attestation.schema
  distributed_transport_envelope: ../schemas/distributed_transport_envelope.schema
  distributed_transport_receipt: ../schemas/distributed_transport_receipt.schema
  distributed_transport_relay_telemetry: ../schemas/distributed_transport_relay_telemetry.schema
  distributed_transport_root_directory: ../schemas/distributed_transport_root_directory.schema
  distributed_transport_authority_plane: ../schemas/distributed_transport_authority_plane.schema
operations:
  issue_federation_handoff:
    summary: >
      Bind one cross-self distributed council request to a Federation transport envelope
      with self-liaison quorum and guardian channel attestation.
    input:
      inline_schema:
        type: object
        required:
          - topology_ref
          - proposal_ref
          - payload_ref
          - payload_digest
          - participant_identity_ids
        properties:
          topology_ref:
            type: string
            minLength: 1
          proposal_ref:
            type: string
            minLength: 1
          payload_ref:
            type: string
            minLength: 1
          payload_digest:
            type: string
            pattern: "^[a-f0-9]{64}$"
          participant_identity_ids:
            type: array
            minItems: 2
            items:
              type: string
              minLength: 1
    output:
      schema_ref: distributed_transport_envelope
    guarantees:
      - council_tier must equal federation
      - transport_profile must equal federation-mtls-quorum-v1
      - required_roles must bind 2 self-liaison participants and 1 guardian
      - channel_binding_ref must be envelope-unique and route_nonce-bound
  issue_heritage_handoff:
    summary: >
      Bind one interpretive distributed council request to a Heritage transport envelope
      with fixed reviewer roles and clause-bound recipient routing.
    input:
      inline_schema:
        type: object
        required:
          - topology_ref
          - proposal_ref
          - payload_ref
          - payload_digest
          - referenced_clauses
        properties:
          topology_ref:
            type: string
            minLength: 1
          proposal_ref:
            type: string
            minLength: 1
          payload_ref:
            type: string
            minLength: 1
          payload_digest:
            type: string
            pattern: "^[a-f0-9]{64}$"
          referenced_clauses:
            type: array
            minItems: 1
            items:
              type: string
              minLength: 1
    output:
      schema_ref: distributed_transport_envelope
    guarantees:
      - council_tier must equal heritage
      - transport_profile must equal heritage-attested-review-v1
      - required_roles must bind 2 cultural representatives plus legal-advisor and ethics-committee
      - recipient_endpoint must remain clause-bound and fail closed on missing clause refs
  rotate_transport_keys:
    summary: >
      Rotate one distributed transport envelope onto a new key epoch and federated trust-root set
      while preserving overlap with the previous epoch during the handoff window.
    input:
      inline_schema:
        type: object
        required:
          - envelope_ref
          - envelope_digest
          - next_key_epoch
          - trust_root_refs
          - trust_root_quorum
        properties:
          envelope_ref:
            type: string
            minLength: 1
          envelope_digest:
            type: string
            pattern: "^[a-f0-9]{64}$"
          next_key_epoch:
            type: integer
            minimum: 2
          trust_root_refs:
            type: array
            minItems: 1
            uniqueItems: true
            items:
              type: string
              minLength: 1
          trust_root_quorum:
            type: integer
            minimum: 1
    output:
      schema_ref: distributed_transport_envelope
    guarantees:
      - next_key_epoch must be greater than the current key_epoch
      - accepted_key_epochs must retain the previous epoch during overlap
      - federated root verification must require trust_root_quorum distinct roots
  probe_live_root_directory:
    summary: >
      Probe one live remote PKI root-directory endpoint and bind the reachable root quorum
      to a rotated distributed transport envelope before receipt verification.
    input:
      inline_schema:
        type: object
        required:
          - envelope_ref
          - envelope_digest
          - directory_endpoint
        properties:
          envelope_ref:
            type: string
            minLength: 1
          envelope_digest:
            type: string
            pattern: "^[a-f0-9]{64}$"
          directory_endpoint:
            type: string
            pattern: "^https?://"
          request_timeout_ms:
            type: integer
            minimum: 1
    output:
      schema_ref: distributed_transport_root_directory
    guarantees:
      - live root directory must match envelope council_tier and transport_profile
      - live root directory key_epoch must remain inside accepted_key_epochs
      - trusted_root_refs must satisfy trust_root_quorum before a rotated receipt can authenticate
      - connectivity_receipt must bind endpoint, response_digest, latency, and quorum outcome
  probe_authority_plane:
    summary: >
      Probe one bounded external key-server fleet and bind its reachable authority members
      to a rotated distributed transport envelope after live root-directory federation.
    input:
      inline_schema:
        type: object
        required:
          - envelope_ref
          - envelope_digest
          - directory_ref
          - authority_endpoints
        properties:
          envelope_ref:
            type: string
            minLength: 1
          envelope_digest:
            type: string
            pattern: "^[a-f0-9]{64}$"
          directory_ref:
            type: string
            pattern: "^rootdir://"
          authority_endpoints:
            type: array
            minItems: 1
            uniqueItems: true
            items:
              type: string
              pattern: "^https?://"
          request_timeout_ms:
            type: integer
            minimum: 1
    output:
      schema_ref: distributed_transport_authority_plane
    guarantees:
      - authority plane must match the envelope council_tier and transport_profile
      - every reachable key server must advertise a key_epoch accepted by both the envelope and root directory
      - trusted_root_refs must satisfy trust_root_quorum across the reachable key-server fleet
      - each key server receipt must bind endpoint, response_digest, latency, and matched_root_refs
  record_receipt:
    summary: >
      Verify one returned remote receipt against its transport envelope, attested participant set,
      authenticated channel binding, and single-use replay guard.
    input:
      inline_schema:
        type: object
        required:
          - envelope_ref
          - envelope_digest
          - channel_binding_ref
          - route_nonce
          - result_ref
          - result_digest
          - participant_ids
        properties:
          envelope_ref:
            type: string
            minLength: 1
          envelope_digest:
            type: string
            pattern: "^[a-f0-9]{64}$"
          channel_binding_ref:
            type: string
            minLength: 1
          route_nonce:
            type: string
            minLength: 1
          result_ref:
            type: string
            minLength: 1
          result_digest:
            type: string
            pattern: "^[a-f0-9]{64}$"
          participant_ids:
            type: array
            minItems: 1
            items:
              type: string
              minLength: 1
          verified_root_refs:
            type: array
            minItems: 1
            uniqueItems: true
            items:
              type: string
              minLength: 1
          key_epoch:
            type: integer
            minimum: 1
          hop_nonce_chain:
            type: array
            minItems: 1
            items:
              type: string
              minLength: 1
    output:
      schema_ref: distributed_transport_receipt
    guarantees:
      - receipt_status must equal authenticated only when channel_authenticated, required_roles_satisfied, quorum_attested, federated_roots_verified, and key_epoch_accepted are all true
      - replay_guard_status must become blocked on any second use of the same route_nonce
      - multi_hop_replay_status must become blocked on any reused hop_nonce_chain
      - participant_bindings must retain attestation_ref and proof_ref for every accepted participant
  capture_relay_telemetry:
    summary: >
      Capture one machine-checkable relay-path telemetry snapshot for a distributed receipt
      while preserving hop order, observed latency, seen trust roots, and anti-replay state.
    input:
      inline_schema:
        type: object
        required:
          - envelope_ref
          - envelope_digest
          - receipt_ref
          - receipt_digest
          - relay_path
        properties:
          envelope_ref:
            type: string
            minLength: 1
          envelope_digest:
            type: string
            pattern: "^[a-f0-9]{64}$"
          receipt_ref:
            type: string
            minLength: 1
          receipt_digest:
            type: string
            pattern: "^[a-f0-9]{64}$"
          relay_path:
            type: array
            minItems: 1
            items:
              type: object
              required:
                - relay_id
                - relay_endpoint
                - jurisdiction
                - network_zone
                - observed_latency_ms
              properties:
                relay_id:
                  type: string
                  minLength: 1
                relay_endpoint:
                  type: string
                  minLength: 1
                jurisdiction:
                  type: string
                  minLength: 1
                network_zone:
                  type: string
                  minLength: 1
                transport_layer:
                  type: string
                  minLength: 1
                observed_latency_ms:
                  type: number
                  exclusiveMinimum: 0
                root_refs_seen:
                  type: array
                  minItems: 1
                  uniqueItems: true
                  items:
                    type: string
                    minLength: 1
                observed_at:
                  type: string
                  format: date-time
    output:
      schema_ref: distributed_transport_relay_telemetry
    guarantees:
      - hop_count must equal the length of the receipt hop_nonce_chain and must not exceed max_hops
      - anti_replay_status must mirror the receipt multi_hop_replay_status
      - replay_guard_status must mirror the receipt replay_guard_status
      - root_quorum_met must mirror the receipt federated_roots_verified result
      - final relay hop delivery_status must equal the receipt_status
events:
  distributed.transport_issued:
    payload:
      schema_ref: distributed_transport_envelope
  distributed.transport_rotated:
    payload:
      schema_ref: distributed_transport_envelope
  distributed.transport_received:
    payload:
      schema_ref: distributed_transport_receipt
  distributed.transport_telemetry_captured:
    payload:
      schema_ref: distributed_transport_relay_telemetry
compatibility:
  stability: bootstrap
  notes:
    - This contract fixes the in-repo reference profile for participant attestation, key-epoch overlap, live root-directory federation, bounded key-server fleet binding, multi-hop anti-replay, and bounded relay telemetry.
    - Actual non-loopback mTLS authority routing, dynamic external key-server churn, and socket-level tracing remain future work.
