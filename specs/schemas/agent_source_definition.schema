$schema: "https://json-schema.org/draft/2020-12/schema"
$id: "https://omoikane.dev/specs/schemas/agent_source_definition.schema"
title: AgentSourceDefinition
description: Raw repo-local agents/*.yaml contract before Yaoyorozu registry materialization.
type: object
additionalProperties: true
required:
  - name
  - role
  - version
  - capabilities
  - trust_floor
  - substrate_requirements
  - input_schema_ref
  - output_schema_ref
  - ethics_constraints
  - prompt_or_policy_ref
  - when_to_invoke
  - when_not_to_invoke
properties:
  name:
    type: string
    minLength: 1
  role:
    type: string
    enum:
      - councilor
      - builder
      - researcher
      - guardian
  version:
    type: string
    pattern: "^[0-9]+\\.[0-9]+\\.[0-9]+$"
  capabilities:
    type: array
    minItems: 1
    items:
      type: string
      minLength: 1
  trust_floor:
    type: number
    minimum: 0
    maximum: 1
  substrate_requirements:
    type: array
    minItems: 1
    items:
      type: string
      minLength: 1
  input_schema_ref:
    type: string
    pattern: "^specs/"
  output_schema_ref:
    type: string
    pattern: "^specs/"
  research_domain_refs:
    type: array
    minItems: 1
    items:
      type: string
      pattern: "^(docs|research)/"
  evidence_policy_ref:
    type: string
    pattern: "^(agents|docs|research)/"
  ethics_constraints:
    type: array
    items:
      type: string
      minLength: 1
  prompt_or_policy_ref:
    type: string
    pattern: "^agents/"
  when_to_invoke:
    type: string
    minLength: 1
  when_not_to_invoke:
    type: string
    minLength: 1
allOf:
  - if:
      properties:
        role:
          const: researcher
      required:
        - role
    then:
      required:
        - research_domain_refs
        - evidence_policy_ref
examples:
  - name: design-architect
    role: councilor
    version: 0.1.0
    capabilities:
      - docs.read
      - docs.propose-change
    trust_floor: 0.6
    substrate_requirements:
      - any
    input_schema_ref: specs/schemas/council_input.yaml
    output_schema_ref: specs/schemas/council_output.yaml
    ethics_constraints:
      - A1-continuity
    prompt_or_policy_ref: agents/councilors/design-architect.policy.md
    when_to_invoke: design documents need cross-reference review
    when_not_to_invoke: direct typo-only edits
  - name: neuroscience-scout
    role: researcher
    version: 0.1.0
    capabilities:
      - literature.survey
    trust_floor: 0.4
    substrate_requirements:
      - any
    input_schema_ref: specs/schemas/council_input.yaml
    output_schema_ref: specs/schemas/council_output.yaml
    research_domain_refs:
      - docs/05-research-frontiers/scan-fidelity.md
    evidence_policy_ref: agents/researchers/consciousness-theorist.policy.md
    ethics_constraints: []
    prompt_or_policy_ref: agents/researchers/consciousness-theorist.policy.md
    when_to_invoke: scanning progress needs literature review
    when_not_to_invoke: design decisions
