$schema: "https://json-schema.org/draft/2020-12/schema"
$id: "https://omoikane.dev/specs/schemas/agent_source_definition.schema"
title: AgentSourceDefinition
description: Raw repo-local agents/*.yaml contract before Yaoyorozu registry materialization.
type: object
additionalProperties: true
required:
  - name
  - role
  - version
  - capabilities
  - trust_floor
  - substrate_requirements
  - input_schema_ref
  - output_schema_ref
  - ethics_constraints
  - prompt_or_policy_ref
  - when_to_invoke
  - when_not_to_invoke
properties:
  name:
    type: string
    minLength: 1
  role:
    type: string
    enum:
      - councilor
      - builder
      - researcher
      - guardian
  version:
    type: string
    pattern: "^[0-9]+\\.[0-9]+\\.[0-9]+$"
  capabilities:
    type: array
    minItems: 1
    items:
      type: string
      minLength: 1
  trust_floor:
    type: number
    minimum: 0
    maximum: 1
  substrate_requirements:
    type: array
    minItems: 1
    items:
      type: string
      minLength: 1
  input_schema_ref:
    type: string
    pattern: "^specs/"
  output_schema_ref:
    type: string
    pattern: "^specs/"
  deliberation_scope_refs:
    type: array
    minItems: 1
    items:
      type: string
      pattern: "^(docs|specs|evals|agents|meta|src|tests|research)/"
  deliberation_policy_ref:
    type: string
    pattern: "^(agents|docs|specs|evals|meta)/"
  research_domain_refs:
    type: array
    minItems: 1
    items:
      type: string
      pattern: "^(docs|research)/"
  evidence_policy_ref:
    type: string
    pattern: "^(agents|docs|research)/"
  build_surface_refs:
    type: array
    minItems: 1
    items:
      type: string
      pattern: "^(src|tests|specs|evals|docs|agents|meta|research)/"
  execution_policy_ref:
    type: string
    pattern: "^(agents|docs|specs|evals|meta)/"
  oversight_scope_refs:
    type: array
    minItems: 1
    items:
      type: string
      pattern: "^(docs|specs|evals|agents|meta)/"
  attestation_policy_ref:
    type: string
    pattern: "^(agents|docs|specs|evals|meta)/"
  ethics_constraints:
    type: array
    items:
      type: string
      minLength: 1
  prompt_or_policy_ref:
    type: string
    pattern: "^agents/"
  when_to_invoke:
    type: string
    minLength: 1
  when_not_to_invoke:
    type: string
    minLength: 1
allOf:
  - if:
      properties:
        role:
          const: councilor
      required:
        - role
    then:
      required:
        - deliberation_scope_refs
        - deliberation_policy_ref
  - if:
      properties:
        role:
          const: researcher
      required:
        - role
    then:
      required:
        - research_domain_refs
        - evidence_policy_ref
      properties:
        input_schema_ref:
          const: specs/schemas/research_evidence_request.schema
        output_schema_ref:
          const: specs/schemas/research_evidence_report.schema
  - if:
      properties:
        role:
          const: builder
      required:
        - role
    then:
      required:
        - build_surface_refs
        - execution_policy_ref
  - if:
      properties:
        role:
          const: guardian
      required:
        - role
    then:
      required:
        - oversight_scope_refs
        - attestation_policy_ref
examples:
  - name: design-architect
    role: councilor
    version: 0.1.0
    capabilities:
      - docs.read
      - docs.propose-change
    trust_floor: 0.6
    substrate_requirements:
      - any
    input_schema_ref: specs/schemas/council_input.yaml
    output_schema_ref: specs/schemas/council_output.yaml
    deliberation_scope_refs:
      - docs/01-architecture/overview.md
      - specs/catalog.yaml
    deliberation_policy_ref: agents/councilors/design-architect.policy.md
    ethics_constraints:
      - A1-continuity
    prompt_or_policy_ref: agents/councilors/design-architect.policy.md
    when_to_invoke: design documents need cross-reference review
    when_not_to_invoke: direct typo-only edits
  - name: codex-builder
    role: builder
    version: 0.1.0
    capabilities:
      - code.generate
      - code.test
    trust_floor: 0.5
    substrate_requirements:
      - classical_silicon
    input_schema_ref: specs/schemas/build_request.yaml
    output_schema_ref: specs/schemas/build_artifact.yaml
    build_surface_refs:
      - src/omoikane/
      - tests/
      - specs/
      - evals/
      - docs/
    execution_policy_ref: agents/builders/codex-builder.policy.md
    ethics_constraints:
      - A1-continuity
    prompt_or_policy_ref: agents/builders/codex-builder.policy.md
    when_to_invoke: reference runtime changes need a patch
    when_not_to_invoke: docs-only updates are sufficient
  - name: neuroscience-scout
    role: researcher
    version: 0.1.0
    capabilities:
      - literature.survey
    trust_floor: 0.4
    substrate_requirements:
      - any
    input_schema_ref: specs/schemas/research_evidence_request.schema
    output_schema_ref: specs/schemas/research_evidence_report.schema
    research_domain_refs:
      - docs/05-research-frontiers/scan-fidelity.md
    evidence_policy_ref: agents/researchers/consciousness-theorist.policy.md
    ethics_constraints: []
    prompt_or_policy_ref: agents/researchers/consciousness-theorist.policy.md
    when_to_invoke: scanning progress needs literature review
    when_not_to_invoke: design decisions
  - name: integrity-guardian
    role: guardian
    version: 0.1.0
    capabilities:
      - integrity.check
    trust_floor: 0.99
    substrate_requirements:
      - any
    input_schema_ref: specs/schemas/build_artifact.yaml
    output_schema_ref: specs/schemas/guardian_oversight_event.schema
    oversight_scope_refs:
      - docs/02-subsystems/kernel/continuity-ledger.md
      - evals/continuity/gap_report_scan_receipt.yaml
    attestation_policy_ref: agents/guardians/integrity-guardian.policy.md
    ethics_constraints:
      - ALL
    prompt_or_policy_ref: agents/guardians/integrity-guardian.policy.md
    when_to_invoke: continuity or build artifact integrity must be attested
    when_not_to_invoke: design-only deliberation
