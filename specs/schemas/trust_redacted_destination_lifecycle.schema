$schema: "https://json-schema.org/draft/2020-12/schema"
$id: "https://omoikane.dev/specs/schemas/trust_redacted_destination_lifecycle.schema"
title: TrustRedactedDestinationLifecycle
description: >
  Public redacted summary for the destination-side trust transfer lifecycle
  that preserves status transitions, timing, and digest bindings while sealing
  entry refs, verifier receipt ids, rationale text, and full recovery review
  internals.
type: object
additionalProperties: false
required:
  - kind
  - schema_version
  - lifecycle_id
  - lifecycle_ref
  - summary_profile_id
  - lifecycle_policy_id
  - current_status
  - active_sequence
  - active_entry_digest
  - latest_federation_digest
  - latest_cadence_digest
  - revocation_fail_closed_action
  - history_summaries
  - recovery_summary
  - history_summary_commitment_digest
  - sealed_lifecycle_digest
  - redaction_policy_id
  - redacted_fields
  - summary_digest
properties:
  kind:
    const: trust_redacted_destination_lifecycle
  schema_version:
    type: string
    pattern: "^[0-9]+\\.[0-9]+\\.[0-9]+$"
  lifecycle_id:
    type: string
    pattern: "^trust-destination-lifecycle-[a-f0-9]{12}$"
  lifecycle_ref:
    type: string
    minLength: 1
  summary_profile_id:
    const: bounded-trust-transfer-redacted-destination-lifecycle-v1
  lifecycle_policy_id:
    const: bounded-trust-transfer-destination-lifecycle-v1
  current_status:
    type: string
    enum:
      - current
      - revoked
  active_sequence:
    type: integer
    minimum: 0
  active_entry_digest:
    type: string
    pattern: "^[a-f0-9]{64}$"
  latest_federation_digest:
    type: string
    pattern: "^[a-f0-9]{64}$"
  latest_cadence_digest:
    type: string
    pattern: "^[a-f0-9]{64}$"
  revocation_fail_closed_action:
    const: disable-destination-trust-usage
  history_summaries:
    type: array
    minItems: 4
    items:
      type: object
      additionalProperties: false
      required:
        - sequence
        - event_type
        - status
        - recorded_at
        - valid_until
        - quorum_policy_id
        - federation_digest
        - cadence_digest
        - trust_root_quorum
        - jurisdiction_quorum
        - covered_verifier_count
        - covered_trust_root_count
        - covered_jurisdiction_count
        - covered_verifier_receipt_commitment_digest
        - destination_snapshot_digest
        - entry_digest
      properties:
        sequence:
          type: integer
          minimum: 0
        event_type:
          type: string
          enum:
            - imported
            - renewed
            - revoked
            - recovered
        status:
          type: string
          enum:
            - current
            - revoked
        recorded_at:
          type: string
          format: date-time
        valid_until:
          type: string
          format: date-time
        quorum_policy_id:
          type: string
          enum:
            - bounded-trust-transfer-fixed-verifier-pair-v1
            - bounded-trust-transfer-multi-root-recovery-v1
        federation_digest:
          type: string
          pattern: "^[a-f0-9]{64}$"
        cadence_digest:
          type: string
          pattern: "^[a-f0-9]{64}$"
        trust_root_quorum:
          type: integer
          minimum: 1
        jurisdiction_quorum:
          type: integer
          minimum: 1
        covered_verifier_count:
          type: integer
          minimum: 2
        covered_trust_root_count:
          type: integer
          minimum: 1
        covered_jurisdiction_count:
          type: integer
          minimum: 1
        covered_verifier_receipt_commitment_digest:
          type: string
          pattern: "^[a-f0-9]{64}$"
        destination_snapshot_digest:
          type: string
          pattern: "^[a-f0-9]{64}$"
        entry_digest:
          type: string
          pattern: "^[a-f0-9]{64}$"
  recovery_summary:
    $ref: "./trust_redacted_destination_recovery_summary.schema"
  history_summary_commitment_digest:
    type: string
    pattern: "^[a-f0-9]{64}$"
  sealed_lifecycle_digest:
    type: string
    pattern: "^[a-f0-9]{64}$"
  redaction_policy_id:
    const: bounded-trust-transfer-destination-lifecycle-summary-redaction-v1
  redacted_fields:
    type: array
    uniqueItems: true
    items:
      type: string
      minLength: 1
  summary_digest:
    type: string
    pattern: "^[a-f0-9]{64}$"
examples:
  - kind: trust_redacted_destination_lifecycle
    schema_version: 1.2.0
    lifecycle_id: trust-destination-lifecycle-0123456789ab
    lifecycle_ref: trust-destination-lifecycle://trust-verifier-federation-0123456789ab
    summary_profile_id: bounded-trust-transfer-redacted-destination-lifecycle-v1
    lifecycle_policy_id: bounded-trust-transfer-destination-lifecycle-v1
    current_status: current
    active_sequence: 3
    active_entry_digest: aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
    latest_federation_digest: bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb
    latest_cadence_digest: cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc
    revocation_fail_closed_action: disable-destination-trust-usage
    history_summaries:
      - sequence: 0
        event_type: imported
        status: current
        recorded_at: "2026-04-24T00:00:00Z"
        valid_until: "2026-04-24T00:15:00Z"
        federation_digest: 1111111111111111111111111111111111111111111111111111111111111111
        cadence_digest: 2222222222222222222222222222222222222222222222222222222222222222
        covered_verifier_count: 2
        covered_verifier_receipt_commitment_digest: 3333333333333333333333333333333333333333333333333333333333333333
        destination_snapshot_digest: 4444444444444444444444444444444444444444444444444444444444444444
        entry_digest: 5555555555555555555555555555555555555555555555555555555555555555
      - sequence: 1
        event_type: renewed
        status: current
        recorded_at: "2026-04-24T00:10:00Z"
        valid_until: "2026-04-24T00:25:00Z"
        federation_digest: 6666666666666666666666666666666666666666666666666666666666666666
        cadence_digest: 7777777777777777777777777777777777777777777777777777777777777777
        covered_verifier_count: 2
        covered_verifier_receipt_commitment_digest: 8888888888888888888888888888888888888888888888888888888888888888
        destination_snapshot_digest: 4444444444444444444444444444444444444444444444444444444444444444
        entry_digest: 9999999999999999999999999999999999999999999999999999999999999999
      - sequence: 2
        event_type: revoked
        status: revoked
        recorded_at: "2026-04-24T00:11:00Z"
        valid_until: "2026-04-24T00:25:00Z"
        federation_digest: 6666666666666666666666666666666666666666666666666666666666666666
        cadence_digest: 7777777777777777777777777777777777777777777777777777777777777777
        covered_verifier_count: 2
        covered_verifier_receipt_commitment_digest: 8888888888888888888888888888888888888888888888888888888888888888
        destination_snapshot_digest: 4444444444444444444444444444444444444444444444444444444444444444
        entry_digest: dddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddd
      - sequence: 3
        event_type: recovered
        status: current
        recorded_at: "2026-04-24T00:22:00Z"
        valid_until: "2026-04-24T00:35:00Z"
        federation_digest: aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
        cadence_digest: bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb
        covered_verifier_count: 2
        covered_verifier_receipt_commitment_digest: cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc
        destination_snapshot_digest: 4444444444444444444444444444444444444444444444444444444444444444
        entry_digest: 1212121212121212121212121212121212121212121212121212121212121212
    recovery_summary:
      kind: trust_redacted_destination_recovery_summary
      schema_version: 1.0.0
      summary_id: trust-recovery-summary-abcdef123456
      summary_ref: trust-redacted-recovery-summary://abcdef123456
      summary_profile_id: bounded-trust-transfer-redacted-destination-recovery-summary-v1
      bound_sequence: 3
      bound_entry_digest: 1212121212121212121212121212121212121212121212121212121212121212
      sealed_recovery_review_digest: 1313131313131313131313131313131313131313131313131313131313131313
      recovery_rationale_summary:
        reason_codes:
          - revocation-signal-cleared
          - multi-root-quorum-restored
          - cross-jurisdiction-legal-review-cleared
        summary_text: Destination trust was re-enabled after the revoked branch cleared review.
        rationale_digest: 1414141414141414141414141414141414141414141414141414141414141414
      legal_proof_summary:
        policy_refs:
          - policy://guardian-oversight/jp-13/trust-transfer-recovery/v1
          - policy://guardian-oversight/us-ca/trust-transfer-recovery/v1
          - policy://guardian-oversight/eu-de/trust-transfer-recovery/v1
        jurisdiction_bundle_refs:
          - legal://jp-13/guardian-oversight/v1
          - legal://us-ca/guardian-oversight/v1
          - legal://eu-de/guardian-oversight/v1
        liability_mode: joint
        reviewer_binding_digest: 1515151515151515151515151515151515151515151515151515151515151515
        legal_ack_commitment_digest: 1616161616161616161616161616161616161616161616161616161616161616
        legal_proof_digest: 1717171717171717171717171717171717171717171717171717171717171717
      redaction_policy_id: bounded-trust-transfer-destination-recovery-summary-redaction-v1
      redacted_fields:
        - destination_lifecycle.history[].recovery_review.review_id
        - destination_lifecycle.history[].recovery_review.review_ref
        - destination_lifecycle.history[].recovery_review.rationale
        - destination_lifecycle.history[].recovery_review.legal_ack_refs
      summary_digest: 1818181818181818181818181818181818181818181818181818181818181818
    history_summary_commitment_digest: dddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddd
    sealed_lifecycle_digest: eeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeee
    redaction_policy_id: bounded-trust-transfer-destination-lifecycle-summary-redaction-v1
    redacted_fields:
      - destination_lifecycle.active_entry_ref
      - destination_lifecycle.latest_federation_ref
      - destination_lifecycle.latest_cadence_ref
      - destination_lifecycle.history[].entry_id
      - destination_lifecycle.history[].entry_ref
      - destination_lifecycle.history[].attested_at
      - destination_lifecycle.history[].federation_ref
      - destination_lifecycle.history[].cadence_ref
      - destination_lifecycle.history[].covered_verifier_receipt_ids
      - destination_lifecycle.history[].rationale
    summary_digest: ffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffff
