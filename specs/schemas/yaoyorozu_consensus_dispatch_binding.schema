          - worker-dispatch-000000000001
        emitted_at: "2026-04-23T08:10:05Z"
        signature_ref: sig://consensus-bus/consensus-msg-000000000001
        message_digest: aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
