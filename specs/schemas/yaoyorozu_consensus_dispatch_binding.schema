      dispatch_plan_bound: true
      dispatch_receipt_coverage_complete: true
      all_transport_bus_only: true
      ordered_phases: true
      dispatch_claims_tracked: true
      worker_reports_routed: true
      guardian_gate_present: true
      resolve_present: true
      direct_handoff_blocked: true
      ok: true
