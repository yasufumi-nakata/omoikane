      session_id: council-convocation-0123456789ab
      sender_role: codex-builder
      recipient: agent://schema-builder
      attempted_intent: report
      status: blocked
      enforced_policy: consensus-bus-only
      reason: direct builder-to-builder handoff is forbidden
      blocked_at: "2026-04-23T08:11:00Z"
