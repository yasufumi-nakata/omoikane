$schema: "https://json-schema.org/draft/2020-12/schema"
$id: "https://omoikane.dev/specs/schemas/schedule_handle.schema"
title: ScheduleHandle
description: Mutable handle that tracks AscensionPlan progress and rollback history.
type: object
additionalProperties: false
required:
  - kind
  - schema_version
  - handle_id
  - plan_ref
  - identity_id
  - governance_artifacts
  - governance_artifact_digest
  - current_stage
  - status
  - history
  - opened_at
properties:
  kind:
    const: schedule_handle
  schema_version:
    type: string
    pattern: "^[0-9]+\\.[0-9]+\\.[0-9]+$"
  handle_id:
    type: string
    minLength: 8
  plan_ref:
    type: string
    minLength: 8
  identity_id:
    type: string
    minLength: 1
  governance_artifacts:
    type: object
    additionalProperties: false
    required:
      - self_consent_ref
      - ethics_attestation_ref
      - council_attestation_ref
      - legal_attestation_ref
      - witness_refs
      - artifact_bundle_ref
    properties:
      self_consent_ref:
        type: string
        pattern: "^consent://"
      ethics_attestation_ref:
        type: string
        pattern: "^ethics://"
      council_attestation_ref:
        type: string
        pattern: "^council://"
      legal_attestation_ref:
        type: string
        pattern: "^legal://"
      witness_refs:
        type: array
        minItems: 2
        items:
          type: string
          pattern: "^witness://"
      artifact_bundle_ref:
        type: string
        pattern: "^artifact://"
  governance_artifact_digest:
    type: string
    pattern: "^[a-f0-9]{64}$"
  current_stage:
    type: string
    minLength: 1
  status:
    type: string
    enum:
      - scheduled
      - advancing
      - paused
      - rolled-back
      - completed
      - cancelled
      - failed
  history:
    type: array
    minItems: 1
    items:
      type: object
      additionalProperties: false
      required:
        - sequence
        - stage_id
        - transition
        - recorded_at
        - continuity_event_ref
      properties:
        sequence:
          type: integer
          minimum: 0
        stage_id:
          type: string
          minLength: 1
        transition:
          type: string
          enum:
            - enter
            - complete
            - rollback
            - pause
            - resume
            - cancel
            - fail
        recorded_at:
          type: string
          format: date-time
        continuity_event_ref:
          type: string
          minLength: 1
        reason:
          type: string
  opened_at:
    type: string
    format: date-time
  closed_at:
    type: string
    format: date-time
examples:
  - kind: schedule_handle
    schema_version: 1.0.0
    handle_id: schedule-handle-001
    plan_ref: plan-method-a-001
    identity_id: identity://amaterasu-endpoint
    governance_artifacts:
      self_consent_ref: consent://ascension/a/3dfb1f84a223/self-consent
      ethics_attestation_ref: ethics://ascension/a/3dfb1f84a223/guardian-approval
      council_attestation_ref: council://ascension/a/3dfb1f84a223/reference-resolution
      legal_attestation_ref: legal://ascension/a/3dfb1f84a223/clinical-readiness
      witness_refs:
        - witness://ascension/a/3dfb1f84a223/clinician-primary
        - witness://ascension/a/3dfb1f84a223/guardian-observer
      artifact_bundle_ref: artifact://ascension/a/3dfb1f84a223/bundle
    governance_artifact_digest: 8c1f6de21c0d63b33047e49d4c8b58fffe414e1f5e7d0c6c69c17a2c35e5757d
    current_stage: bdb-bridge
    status: paused
    history:
      - sequence: 0
        stage_id: scan-baseline
        transition: enter
        recorded_at: "2026-04-18T18:00:00Z"
        continuity_event_ref: continuity-event-stage-001
      - sequence: 1
        stage_id: scan-baseline
        transition: complete
        recorded_at: "2026-04-18T18:30:00Z"
        continuity_event_ref: continuity-event-stage-002
      - sequence: 2
        stage_id: bdb-bridge
        transition: enter
        recorded_at: "2026-04-18T18:30:01Z"
        continuity_event_ref: continuity-event-stage-003
      - sequence: 3
        stage_id: bdb-bridge
        transition: pause
        recorded_at: "2026-04-18T18:31:00Z"
        continuity_event_ref: continuity-event-stage-004
        reason: self requested cool-off
    opened_at: "2026-04-18T18:00:00Z"
