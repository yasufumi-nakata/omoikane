$schema: "https://json-schema.org/draft/2020-12/schema"
$id: "https://omoikane.dev/specs/schemas/schedule_handle.schema"
title: ScheduleHandle
description: Mutable handle that tracks AscensionPlan progress and rollback history.
type: object
additionalProperties: false
required:
  - kind
  - schema_version
  - handle_id
  - plan_ref
  - identity_id
  - governance_artifacts
  - governance_artifact_digest
  - artifact_sync
  - verifier_roster
  - current_stage
  - status
  - history
  - opened_at
properties:
  kind:
    const: schedule_handle
  schema_version:
    type: string
    pattern: "^[0-9]+\\.[0-9]+\\.[0-9]+$"
  handle_id:
    type: string
    minLength: 8
  plan_ref:
    type: string
    minLength: 8
  identity_id:
    type: string
    minLength: 1
  governance_artifacts:
    type: object
    additionalProperties: false
    required:
      - self_consent_ref
      - ethics_attestation_ref
      - council_attestation_ref
      - legal_attestation_ref
      - witness_refs
      - artifact_bundle_ref
    properties:
      self_consent_ref:
        type: string
        pattern: "^consent://"
      ethics_attestation_ref:
        type: string
        pattern: "^ethics://"
      council_attestation_ref:
        type: string
        pattern: "^council://"
      legal_attestation_ref:
        type: string
        pattern: "^legal://"
      witness_refs:
        type: array
        minItems: 2
        items:
          type: string
          pattern: "^witness://"
      artifact_bundle_ref:
        type: string
        pattern: "^artifact://"
  governance_artifact_digest:
    type: string
    pattern: "^[a-f0-9]{64}$"
  artifact_sync:
    type: object
    additionalProperties: false
    required:
      - policy_id
      - bundle_status
      - last_checked_at
      - artifacts
    properties:
      policy_id:
        const: attestation-freshness-v1
      bundle_status:
        type: string
        enum:
          - unsynced
          - current
          - refresh-required
          - revoked
      last_checked_at:
        type:
          - string
          - "null"
        format: date-time
      artifacts:
        type: array
        minItems: 5
        maxItems: 5
        items:
          type: object
          additionalProperties: false
          required:
            - artifact_key
            - artifact_ref
            - status
            - checked_at
            - proof_digest
            - external_sync_ref
            - refresh_required
          properties:
            artifact_key:
              type: string
              enum:
                - self_consent_ref
                - ethics_attestation_ref
                - council_attestation_ref
                - legal_attestation_ref
                - artifact_bundle_ref
            artifact_ref:
              type: string
              minLength: 1
            status:
              type: string
              enum:
                - unsynced
                - current
                - stale
                - revoked
            checked_at:
              type:
                - string
                - "null"
              format: date-time
            proof_digest:
              type:
                - string
                - "null"
              pattern: "^[a-f0-9]{64}$"
            external_sync_ref:
              type:
                - string
                - "null"
              pattern: "^sync://"
            refresh_required:
              type: boolean
  verifier_roster:
    $ref: ./governance_verifier_roster.schema
  current_stage:
    type: string
    minLength: 1
  status:
    type: string
    enum:
      - scheduled
      - advancing
      - paused
      - rolled-back
      - completed
      - cancelled
      - failed
  history:
    type: array
    minItems: 1
    items:
      type: object
      additionalProperties: false
      required:
        - sequence
        - stage_id
        - transition
        - recorded_at
        - continuity_event_ref
      properties:
        sequence:
          type: integer
          minimum: 0
        stage_id:
          type: string
          minLength: 1
        transition:
          type: string
          enum:
            - enter
            - complete
            - rollback
            - pause
            - resume
            - sync
            - cancel
            - fail
        recorded_at:
          type: string
          format: date-time
        continuity_event_ref:
          type: string
          minLength: 1
        reason:
          type: string
  opened_at:
    type: string
    format: date-time
  closed_at:
    type: string
    format: date-time
examples:
  - kind: schedule_handle
    schema_version: 1.0.0
    handle_id: schedule-handle-001
    plan_ref: plan-method-a-001
    identity_id: identity://amaterasu-endpoint
    governance_artifacts:
      self_consent_ref: consent://ascension/a/3dfb1f84a223/self-consent
      ethics_attestation_ref: ethics://ascension/a/3dfb1f84a223/guardian-approval
      council_attestation_ref: council://ascension/a/3dfb1f84a223/reference-resolution
      legal_attestation_ref: legal://ascension/a/3dfb1f84a223/clinical-readiness
      witness_refs:
        - witness://ascension/a/3dfb1f84a223/clinician-primary
        - witness://ascension/a/3dfb1f84a223/guardian-observer
      artifact_bundle_ref: artifact://ascension/a/3dfb1f84a223/bundle
    governance_artifact_digest: 8c1f6de21c0d63b33047e49d4c8b58fffe414e1f5e7d0c6c69c17a2c35e5757d
    artifact_sync:
      policy_id: attestation-freshness-v1
      bundle_status: current
      last_checked_at: "2026-04-19T06:00:00Z"
      artifacts:
        - artifact_key: self_consent_ref
          artifact_ref: consent://ascension/a/3dfb1f84a223/self-consent
          status: current
          checked_at: "2026-04-19T06:00:00Z"
          proof_digest: 2fddf44f71a33284c7221ec6f60f13e109c4a405f99dc5a6f1f9956a93d3c4a9
          external_sync_ref: sync://scheduler-demo/method-a-current/self_consent_ref
          refresh_required: false
        - artifact_key: ethics_attestation_ref
          artifact_ref: ethics://ascension/a/3dfb1f84a223/guardian-approval
          status: current
          checked_at: "2026-04-19T06:00:00Z"
          proof_digest: 4fbf9e697cdba2aa61c7b9d26aa25bf2551ae3a83aaf6ebf2efbca33e2b5f3c7
          external_sync_ref: sync://scheduler-demo/method-a-current/ethics_attestation_ref
          refresh_required: false
        - artifact_key: council_attestation_ref
          artifact_ref: council://ascension/a/3dfb1f84a223/reference-resolution
          status: current
          checked_at: "2026-04-19T06:00:00Z"
          proof_digest: 649b11c36ee62af76293fa4d32f7bf24c1ab45f625276c68fb82dc3e6d7d4244
          external_sync_ref: sync://scheduler-demo/method-a-current/council_attestation_ref
          refresh_required: false
        - artifact_key: legal_attestation_ref
          artifact_ref: legal://ascension/a/3dfb1f84a223/clinical-readiness
          status: current
          checked_at: "2026-04-19T06:00:00Z"
          proof_digest: 4a67e98d76bc9782bf6431fc13d5e366228eb9cf392ed2e4c1b8b11be6eeff75
          external_sync_ref: sync://scheduler-demo/method-a-current/legal_attestation_ref
          refresh_required: false
        - artifact_key: artifact_bundle_ref
          artifact_ref: artifact://ascension/a/3dfb1f84a223/bundle
          status: current
          checked_at: "2026-04-19T06:00:00Z"
          proof_digest: 5b653bcd16fc850d9e4d7f3857549ed510d9af1f8d9cb0fd78a76eb4332ea3d4
          external_sync_ref: sync://scheduler-demo/method-a-current/artifact_bundle_ref
          refresh_required: false
    verifier_roster:
      policy_id: verifier-root-rotation-v1
      roster_ref: verifier://ascension/a/3dfb1f84a223/root-roster
      checked_at: "2026-04-19T06:00:00Z"
      active_root_id: root://scheduler-demo/method-a-current/active
      next_root_id: null
      rotation_state: stable
      accepted_roots:
        - root_id: root://scheduler-demo/method-a-current/active
          fingerprint: 1a0e7d7d2f8ee29120bce2fe3d95ce96625a0dd75b7cb2798c5b5bc3e90e6495
          status: active
      proof_digest: 90d771225219a74cfeb8439fe7e0af1c1da7b0f0c5a461f165b04ad68d39d9c0
      external_sync_ref: sync://scheduler-demo/method-a-current/verifier-roster
      dual_attestation_required: false
      dual_attested: false
    current_stage: bdb-bridge
    status: paused
    history:
      - sequence: 0
        stage_id: scan-baseline
        transition: enter
        recorded_at: "2026-04-18T18:00:00Z"
        continuity_event_ref: continuity-event-stage-001
      - sequence: 1
        stage_id: scan-baseline
        transition: complete
        recorded_at: "2026-04-18T18:30:00Z"
        continuity_event_ref: continuity-event-stage-002
      - sequence: 2
        stage_id: bdb-bridge
        transition: enter
        recorded_at: "2026-04-18T18:30:01Z"
        continuity_event_ref: continuity-event-stage-003
      - sequence: 3
        stage_id: bdb-bridge
        transition: pause
        recorded_at: "2026-04-18T18:31:00Z"
        continuity_event_ref: continuity-event-stage-004
        reason: self requested cool-off
    opened_at: "2026-04-18T18:00:00Z"
