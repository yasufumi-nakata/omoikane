    import_receipt:
      import_id: trust-import-0123456789ab
      import_ref: trust-import://design-architect
      destination_policy_id: reference-v0
      provenance_policy_id: reference-trust-provenance-v1
      threshold_digest: "cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc"
      history_digest: "dddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddd"
      eligibility_digest: "eeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeee"
      history_event_count: 0
      seed_mode: snapshot-clone-with-history
      destination_seeded: true
    validation:
      source_snapshot_digest_bound: true
      destination_snapshot_digest_bound: true
      history_preserved: true
      thresholds_preserved: true
      provenance_policy_preserved: true
      eligibility_preserved: true
      federation_quorum_attested: true
      live_remote_verifier_attested: true
      remote_verifier_receipts_bound: true
      re_attestation_cadence_bound: true
      re_attestation_current: true
      destination_seeded: true
      receipt_digest_bound: true
      ok: true
    status: imported
    receipt_digest: "9999999999999999999999999999999999999999999999999999999999999999"
