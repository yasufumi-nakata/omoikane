        verifier_refs:
          - verifier://guardian-oversight.jp/reviewer-alpha
          - verifier://guardian-oversight.jp/reviewer-beta
        trust_root_refs:
          - root://guardian-oversight.jp/reviewer-live-pki
        authority_chain_refs:
          - authority://guardian-oversight.jp/reviewer-attestation
        reviewer_binding_digest: "1212121212121212121212121212121212121212121212121212121212121212"
        federation_status: verified
        receipt_digest: "1313131313131313131313131313131313131313131313131313131313131313"
      re_attestation_cadence:
        cadence_id: trust-re-attestation-0123456789ab
        cadence_ref: trust-re-attestation://trust-verifier-federation-0123456789ab
        cadence_policy_id: bounded-trust-transfer-re-attestation-cadence-v1
        attested_at: "2026-04-24T00:00:00+00:00"
        renew_after: "2026-04-24T00:10:00+00:00"
        valid_until: "2026-04-24T00:15:00+00:00"
        grace_window_seconds: 240
        covered_verifier_receipt_ids:
