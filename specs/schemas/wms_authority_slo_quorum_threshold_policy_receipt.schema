$schema: "https://json-schema.org/draft/2020-12/schema"
$id: "https://omoikane.dev/specs/schemas/wms_authority_slo_quorum_threshold_policy_receipt.schema"
title: WMSAuthoritySLOQuorumThresholdPolicyReceipt
description: >
  Digest-only receipt proving that a WMS authority SLO probe quorum threshold
  came from a signed jurisdiction policy registry policy rather than from a
  hard-coded reviewer-side constant.
type: object
additionalProperties: false
required:
  - kind
  - schema_version
  - receipt_id
  - policy_id
  - threshold_profile
  - digest_profile
  - signature_digest_profile
  - policy_ref
  - jurisdiction_policy_registry_refs
  - jurisdiction_policy_registry_digests
  - jurisdiction_policy_registry_set_digest
  - remote_jurisdictions
  - required_authority_count
  - required_jurisdiction_count
  - signer_key_ref
  - signer_roster_profile
  - signer_roster_digest_profile
  - signer_roster_ref
  - signer_roster_digest
  - signer_roster_bound
  - signer_roster_verifier_quorum_profile
  - signer_roster_verifier_refs
  - signer_roster_verifier_response_digests
  - signer_roster_verifier_response_set_digest
  - signer_roster_verifier_quorum_bound
  - revocation_registry_profile
  - revocation_registry_digest_profile
  - revocation_registry_ref
  - revocation_registry_digest
  - revocation_registry_bound
  - policy_body_digest
  - policy_signature_digest
  - threshold_source_bound
  - signature_bound
  - threshold_authority_binding_status
  - raw_threshold_policy_payload_stored
  - raw_signer_roster_payload_stored
  - raw_revocation_registry_payload_stored
  - raw_authority_payload_stored
  - effective_at
  - digest
properties:
  kind:
    type: string
    const: wms_authority_slo_quorum_threshold_policy_receipt
  schema_version:
    type: string
    const: "1.0"
  receipt_id:
    type: string
    pattern: "^wms-slo-quorum-policy-[a-f0-9]{12}$"
  policy_id:
    type: string
    const: signed-authority-slo-quorum-threshold-policy-v1
  threshold_profile:
    type: string
    const: jurisdiction-policy-registry-slo-quorum-threshold-v1
  digest_profile:
    type: string
    const: authority-slo-quorum-threshold-policy-digest-v1
  signature_digest_profile:
    type: string
    const: authority-slo-quorum-threshold-policy-signature-digest-v1
  policy_ref:
    type: string
    minLength: 1
  jurisdiction_policy_registry_refs:
    type: array
    minItems: 2
    uniqueItems: true
    items:
      type: string
      minLength: 1
  jurisdiction_policy_registry_digests:
    type: array
    minItems: 2
    items:
      $ref: "#/$defs/sha256"
  jurisdiction_policy_registry_set_digest:
    $ref: "#/$defs/sha256"
  remote_jurisdictions:
    type: array
    minItems: 2
    uniqueItems: true
    items:
      type: string
      minLength: 2
  required_authority_count:
    type: integer
    minimum: 2
  required_jurisdiction_count:
    type: integer
    minimum: 2
  signer_key_ref:
    type: string
    minLength: 1
  signer_roster_profile:
    type: string
    const: authority-slo-quorum-threshold-signer-roster-v1
  signer_roster_digest_profile:
    type: string
    const: authority-slo-quorum-threshold-signer-roster-digest-v1
  signer_roster_ref:
    type: string
    minLength: 1
  signer_roster_digest:
    $ref: "#/$defs/sha256"
  signer_roster_bound:
    type: boolean
    const: true
  signer_roster_verifier_quorum_profile:
    type: string
    const: authority-slo-threshold-signer-roster-live-verifier-quorum-v1
  signer_roster_verifier_refs:
    type: array
    minItems: 2
    uniqueItems: true
    items:
      type: string
      minLength: 1
  signer_roster_verifier_response_digests:
    type: array
    minItems: 2
    items:
      $ref: "#/$defs/sha256"
  signer_roster_verifier_response_set_digest:
    $ref: "#/$defs/sha256"
  signer_roster_verifier_quorum_bound:
    type: boolean
    const: true
  revocation_registry_profile:
    type: string
    const: authority-slo-quorum-threshold-revocation-registry-v1
  revocation_registry_digest_profile:
    type: string
    const: authority-slo-quorum-threshold-revocation-registry-digest-v1
  revocation_registry_ref:
    type: string
    minLength: 1
  revocation_registry_digest:
    $ref: "#/$defs/sha256"
  revocation_registry_bound:
    type: boolean
    const: true
  policy_body_digest:
    $ref: "#/$defs/sha256"
  policy_signature_digest:
    $ref: "#/$defs/sha256"
  threshold_source_bound:
    type: boolean
    const: true
  signature_bound:
    type: boolean
    const: true
  threshold_authority_binding_status:
    type: string
    const: verified
  raw_threshold_policy_payload_stored:
    type: boolean
    const: false
  raw_signer_roster_payload_stored:
    type: boolean
    const: false
  raw_revocation_registry_payload_stored:
    type: boolean
    const: false
  raw_authority_payload_stored:
    type: boolean
    const: false
  effective_at:
    type: string
    minLength: 1
  digest:
    $ref: "#/$defs/sha256"
$defs:
  sha256:
    type: string
    pattern: "^[0-9a-f]{64}$"
