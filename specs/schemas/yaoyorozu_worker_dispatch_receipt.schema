$schema: "https://json-schema.org/draft/2020-12/schema"
$id: "https://omoikane.dev/specs/schemas/yaoyorozu_worker_dispatch_receipt.schema"
title: YaoyorozuWorkerDispatchReceipt
description: Process-bound receipt for one repo-local Yaoyorozu worker dispatch plan.
type: object
additionalProperties: false
required:
  - kind
  - schema_version
  - receipt_id
  - executed_at
  - receipt_digest
  - dispatch_plan_ref
  - dispatch_plan_digest
  - dispatch_profile
  - execution_profile
  - workspace_root
  - results
  - execution_summary
  - validation
properties:
  kind:
    const: yaoyorozu_worker_dispatch_receipt
  schema_version:
    const: 1.0.0
  receipt_id:
    type: string
    pattern: "^yaoyorozu-dispatch-receipt-[a-f0-9]{12}$"
  executed_at:
    type: string
    format: date-time
  receipt_digest:
    type: string
    pattern: "^[a-f0-9]{64}$"
  dispatch_plan_ref:
    type: string
    pattern: "^dispatch://"
  dispatch_plan_digest:
    type: string
    pattern: "^[a-f0-9]{64}$"
  dispatch_profile:
    const: repo-local-subprocess-worker-dispatch-v1
  execution_profile:
    const: repo-local-subprocess-worker-execution-v1
  workspace_root:
    type: string
    minLength: 1
  results:
    type: array
    minItems: 4
    items:
      type: object
      additionalProperties: false
      required:
        - unit_id
        - launch_index
        - role_id
        - coverage_area
        - selected_agent_id
        - command_digest
        - process_id
        - process_status
        - exit_code
        - reported_status
        - stdout_digest
        - stderr_digest
        - report_digest
        - report_binding_ok
        - delta_receipt_ok
        - target_paths_ready
        - report
      properties:
        unit_id:
          type: string
          pattern: "^worker-dispatch-[a-f0-9]{12}$"
        launch_index:
          type: integer
          minimum: 1
        role_id:
          type: string
          minLength: 1
        coverage_area:
          type: string
          enum:
            - runtime
            - schema
            - eval
            - docs
        selected_agent_id:
          type: string
          minLength: 1
        command_digest:
          type: string
          pattern: "^[a-f0-9]{64}$"
        process_id:
          type: integer
          minimum: 1
        process_status:
          type: string
          enum:
            - completed
            - failed
        exit_code:
          type: integer
          minimum: 0
        reported_status:
          const: ready
        stdout_digest:
          type: string
          pattern: "^[a-f0-9]{64}$"
        stderr_digest:
          type: string
          pattern: "^[a-f0-9]{64}$"
        report_digest:
          type: string
          pattern: "^[a-f0-9]{64}$"
        report_binding_ok:
          const: true
        delta_receipt_ok:
          const: true
        target_paths_ready:
          const: true
        report:
          type: object
          additionalProperties: false
          required:
            - kind
            - report_profile
            - agent_id
            - role_id
            - coverage_area
            - dispatch_profile
            - workspace_scope
            - dispatch_plan_ref
            - dispatch_unit_ref
            - source_ref
            - target_paths
            - workspace_root
            - workspace_root_digest
            - invocation_digest
            - target_path_observations
            - workspace_delta_receipt
            - coverage_evidence
            - status
          properties:
            kind:
              const: yaoyorozu_local_worker_report
            report_profile:
              const: repo-local-path-bound-worker-report-v2
            agent_id:
              type: string
              minLength: 1
            role_id:
              type: string
              minLength: 1
            coverage_area:
              type: string
              enum:
                - runtime
                - schema
                - eval
                - docs
            dispatch_profile:
              const: repo-local-subprocess-worker-dispatch-v1
            workspace_scope:
              const: repo-local
            dispatch_plan_ref:
              type: string
              pattern: "^dispatch://"
            dispatch_unit_ref:
              type: string
              pattern: "^worker-dispatch-[a-f0-9]{12}$"
            source_ref:
              type: string
              minLength: 1
            target_paths:
              type: array
              minItems: 1
              items:
                type: string
                minLength: 1
            workspace_root:
              type: string
              minLength: 1
            workspace_root_digest:
              type: string
              pattern: "^[a-f0-9]{64}$"
            invocation_digest:
              type: string
              pattern: "^[a-f0-9]{64}$"
            target_path_observations:
              type: array
              minItems: 1
              items:
                type: object
                additionalProperties: false
                required:
                  - target_path
                  - resolved_path
                  - exists
                  - path_kind
                  - within_workspace
                  - entry_count
                  - sample_entries
                  - observation_digest
                properties:
                  target_path:
                    type: string
                    minLength: 1
                  resolved_path:
                    type: string
                    minLength: 1
                  exists:
                    const: true
                  path_kind:
                    type: string
                    enum:
                      - directory
                      - file
                  within_workspace:
                    const: true
                  entry_count:
                    type: integer
                    minimum: 0
                  sample_entries:
                    type: array
                    items:
                      type: string
                      minLength: 1
                  observation_digest:
                    type: string
                    pattern: "^[a-f0-9]{64}$"
            workspace_delta_receipt:
              $ref: "yaoyorozu_worker_workspace_delta_receipt.schema"
            coverage_evidence:
              type: object
              additionalProperties: false
              required:
                - expected_target_count
                - observed_target_count
                - existing_target_count
                - all_targets_exist
                - all_targets_within_workspace
                - delta_receipt_ref
                - delta_status
                - changed_path_count
                - delta_scan_profile
                - ready_gate
              properties:
                expected_target_count:
                  type: integer
                  minimum: 1
                observed_target_count:
                  type: integer
                  minimum: 1
                existing_target_count:
                  type: integer
                  minimum: 1
                all_targets_exist:
                  const: true
                all_targets_within_workspace:
                  const: true
                delta_receipt_ref:
                  type: string
                  pattern: "^worker-delta://"
                delta_status:
                  type: string
                  enum:
                    - clean
                    - delta-detected
                changed_path_count:
                  type: integer
                  minimum: 0
                delta_scan_profile:
                  const: git-target-path-delta-v1
                ready_gate:
                  const: path-bound-target-delta-scan-v2
            status:
              const: ready
  execution_summary:
    type: object
    additionalProperties: false
    required:
      - launched_process_count
      - completed_process_count
      - successful_process_count
      - failed_role_ids
      - coverage_areas
      - target_ready_count
      - delta_bound_count
      - ready_gate_profile
      - delta_scan_profile
    properties:
      launched_process_count:
        type: integer
        minimum: 1
      completed_process_count:
        type: integer
        minimum: 0
      successful_process_count:
        type: integer
        minimum: 0
      failed_role_ids:
        type: array
        items:
          type: string
          minLength: 1
      coverage_areas:
        type: array
        items:
          type: string
          enum:
            - runtime
            - schema
            - eval
            - docs
      target_ready_count:
        type: integer
        minimum: 0
      delta_bound_count:
        type: integer
        minimum: 0
      ready_gate_profile:
        const: path-bound-target-delta-scan-v2
      delta_scan_profile:
        const: git-target-path-delta-v1
  validation:
    type: object
    additionalProperties: false
    required:
      - command_digests_match
      - all_processes_exited_zero
      - all_reports_ready
      - coverage_complete
      - all_reports_bound_to_dispatch
      - all_delta_receipts_bound
      - all_target_paths_ready
      - ok
    properties:
      command_digests_match:
        const: true
      all_processes_exited_zero:
        const: true
      all_reports_ready:
        const: true
      coverage_complete:
        const: true
      all_reports_bound_to_dispatch:
        const: true
      all_delta_receipts_bound:
        const: true
      all_target_paths_ready:
        const: true
      ok:
        const: true
examples:
  - kind: yaoyorozu_worker_dispatch_receipt
    schema_version: 1.0.0
    receipt_id: yaoyorozu-dispatch-receipt-0123456789ab
    executed_at: "2026-04-23T06:21:00Z"
    receipt_digest: 0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
    dispatch_plan_ref: dispatch://yaoyorozu-dispatch-0123456789ab
    dispatch_plan_digest: 0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
    dispatch_profile: repo-local-subprocess-worker-dispatch-v1
    execution_profile: repo-local-subprocess-worker-execution-v1
    workspace_root: /Users/example/omoikane
    results:
      - unit_id: worker-dispatch-0123456789ab
        launch_index: 1
        role_id: builder-runtime
        coverage_area: runtime
        selected_agent_id: codex-builder
        command_digest: 0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
        process_id: 43210
        process_status: completed
        exit_code: 0
        reported_status: ready
        stdout_digest: 0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
        stderr_digest: e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855
        report_digest: 0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
        report_binding_ok: true
        delta_receipt_ok: true
        target_paths_ready: true
        report:
          kind: yaoyorozu_local_worker_report
          report_profile: repo-local-path-bound-worker-report-v2
          agent_id: codex-builder
          role_id: builder-runtime
          coverage_area: runtime
          dispatch_profile: repo-local-subprocess-worker-dispatch-v1
          workspace_scope: repo-local
          dispatch_plan_ref: dispatch://yaoyorozu-dispatch-0123456789ab
          dispatch_unit_ref: worker-dispatch-0123456789ab
          source_ref: agents/builders/codex-builder.yaml
          target_paths:
            - src/omoikane/
            - tests/unit/
            - tests/integration/
          workspace_root: /Users/example/omoikane
          workspace_root_digest: 0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
          invocation_digest: 0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
          target_path_observations:
            - target_path: src/omoikane/
              resolved_path: /Users/example/omoikane/src/omoikane
              exists: true
              path_kind: directory
              within_workspace: true
              entry_count: 8
              sample_entries: [agentic, cognitive, kernel]
              observation_digest: 0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
          workspace_delta_receipt:
            kind: yaoyorozu_worker_workspace_delta_receipt
            schema_version: 1.0.0
            receipt_id: yaoyorozu-worker-delta-0123456789ab
            receipt_ref: worker-delta://yaoyorozu-worker-delta-0123456789ab
            profile_id: git-target-path-delta-v1
            workspace_root: /Users/example/omoikane
            workspace_root_digest: 0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
            dispatch_plan_ref: dispatch://yaoyorozu-dispatch-0123456789ab
            dispatch_unit_ref: worker-dispatch-0123456789ab
            target_paths:
              - src/omoikane/
              - tests/unit/
              - tests/integration/
            scanned_at: "2026-04-23T07:05:00Z"
            head_commit: 0123456789abcdef0123456789abcdef01234567
            status: delta-detected
            changed_path_count: 1
            entries:
              - path: src/omoikane/agentic/local_worker_stub.py
                path_kind: file
                working_tree_state: modified
                change_status: modified
                within_workspace: true
                within_target_paths: true
                baseline_present: true
                current_present: true
                baseline_digest: 0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
                current_digest: abcdef0123456789abcdef0123456789abcdef0123456789abcdef0123456789
                baseline_bytes: 2048
                current_bytes: 2432
                entry_digest: 9999999999999999999999999999999999999999999999999999999999999999
            command_receipts:
              - command_label: git-rev-parse-head
                command: git -C /Users/example/omoikane rev-parse HEAD
                exit_code: 0
                status: pass
                stdout_excerpt: 0123456789abcdef0123456789abcdef01234567
                stderr_excerpt: ""
              - command_label: git-status-short
                command: git -C /Users/example/omoikane status --short --untracked-files=all -- src/omoikane/ tests/unit/ tests/integration/
                exit_code: 0
                status: pass
                stdout_excerpt: " M src/omoikane/agentic/local_worker_stub.py"
                stderr_excerpt: ""
            receipt_digest: abcdefabcdefabcdefabcdefabcdefabcdefabcdefabcdefabcdefabcdefabcd
          coverage_evidence:
            expected_target_count: 3
            observed_target_count: 3
            existing_target_count: 3
            all_targets_exist: true
            all_targets_within_workspace: true
            delta_receipt_ref: worker-delta://yaoyorozu-worker-delta-0123456789ab
            delta_status: delta-detected
            changed_path_count: 1
            delta_scan_profile: git-target-path-delta-v1
            ready_gate: path-bound-target-delta-scan-v2
          status: ready
    execution_summary:
      launched_process_count: 4
      completed_process_count: 4
      successful_process_count: 4
      failed_role_ids: []
      coverage_areas: [docs, eval, runtime, schema]
      target_ready_count: 4
      delta_bound_count: 4
      ready_gate_profile: path-bound-target-delta-scan-v2
      delta_scan_profile: git-target-path-delta-v1
    validation:
      command_digests_match: true
      all_processes_exited_zero: true
      all_reports_ready: true
      coverage_complete: true
      all_reports_bound_to_dispatch: true
      all_delta_receipts_bound: true
      all_target_paths_ready: true
      ok: true
