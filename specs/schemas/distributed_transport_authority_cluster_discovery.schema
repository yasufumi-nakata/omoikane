        proof_digest: 9ab9d997dd8d4903565dbe306dbec04e302b79690d909f11bfd5e34e5a6b5fd3
    accepted_cluster_ref: authority-cluster://federation/review-window
    accepted_route_catalog_ref: authority-route-catalog://federation/ab12cd34ef56ab78
    accepted_route_catalog_digest: 62998bfeb0877b7666e7f78dbe3d136e0115d9b51f705fb154afb76eea714f4c
    accepted_route_catalog:
      - key_server_ref: keyserver://federation/notary-a
        server_role: quorum-notary
        authority_status: active
        server_endpoint: https://198.51.100.10:4443/authority-route-1
        server_name: authority.local
        remote_host_ref: host://federation/authority-edge-a
        remote_host_attestation_ref: host-attestation://federation/authority-edge-a/2026-04-22
