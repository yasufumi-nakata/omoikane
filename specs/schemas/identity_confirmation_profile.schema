$schema: "https://json-schema.org/draft/2020-12/schema"
$id: "https://omoikane.dev/specs/schemas/identity_confirmation_profile.schema"
title: IdentityConfirmationProfile
description: Digest-bound multidimensional identity confirmation profile for the Ascending to Active transition.
type: object
additionalProperties: false
required:
  - confirmation_id
  - confirmed_at
  - profile_id
  - identity_id
  - lineage_id
  - transition
  - consent_ref
  - scheduler_stage_ref
  - required_dimensions
  - dimensions
  - aggregate_score
  - aggregate_threshold
  - self_report
  - third_party_witness_receipts
  - witness_quorum
  - witness_registry_binding
  - self_report_witness_consistency
  - result
  - active_transition_allowed
  - failure_action
  - failure_reasons
  - confirmation_digest
properties:
  confirmation_id:
    type: string
    pattern: "^identity-confirmation-[0-9a-f]{12}$"
  confirmed_at:
    type: string
    format: date-time
  profile_id:
    type: string
    const: multidimensional-identity-confirmation-v1
  identity_id:
    type: string
    minLength: 1
  lineage_id:
    type: string
    minLength: 1
  transition:
    type: string
    const: ascending-to-active
  consent_ref:
    type: string
    minLength: 1
  scheduler_stage_ref:
    type: string
    minLength: 1
  required_dimensions:
    type: array
    minItems: 4
    maxItems: 4
    uniqueItems: true
    items:
      type: string
      enum:
        - episodic_recall
        - self_model_alignment
        - subjective_self_report
        - third_party_witness_alignment
  dimensions:
    type: array
    minItems: 4
    maxItems: 4
    items:
      type: object
      additionalProperties: false
      required:
        - dimension_id
        - source_ref
        - score
        - threshold
        - status
        - evidence_digest
      properties:
        dimension_id:
          type: string
          enum:
            - episodic_recall
            - self_model_alignment
            - subjective_self_report
            - third_party_witness_alignment
        source_ref:
          type: string
          minLength: 1
        score:
          type: number
          minimum: 0
          maximum: 1
        threshold:
          type: number
          minimum: 0
          maximum: 1
        status:
          type: string
          enum: [pass, fail]
        evidence_digest:
          type: string
          pattern: "^[0-9a-f]{64}$"
  aggregate_score:
    type: number
    minimum: 0
    maximum: 1
  aggregate_threshold:
    type: number
    const: 0.85
  self_report:
    type: object
    additionalProperties: false
    required:
      - report_ref
      - statement_digest
      - continuity_score
      - threshold
      - status
      - evidence_digest
    properties:
      report_ref:
        type: string
        minLength: 1
      statement_digest:
        type: string
        pattern: "^[0-9a-f]{64}$"
      continuity_score:
        type: number
        minimum: 0
        maximum: 1
      threshold:
        type: number
        const: 0.85
      status:
        type: string
        enum: [pass, fail]
      evidence_digest:
        type: string
        pattern: "^[0-9a-f]{64}$"
  third_party_witness_receipts:
    type: array
    minItems: 1
    items:
      type: object
      additionalProperties: false
      required:
        - witness_id
        - witness_role
        - observation_ref
        - registry_entry_ref
        - registry_entry_digest
        - verifier_key_ref
        - revocation_ref
        - registry_status
        - revocation_status
        - alignment_score
        - threshold
        - status
        - evidence_digest
      properties:
        witness_id:
          type: string
          minLength: 1
        witness_role:
          type: string
          minLength: 1
        observation_ref:
          type: string
          minLength: 1
        registry_entry_ref:
          type: string
          minLength: 1
        registry_entry_digest:
          type: string
          pattern: "^[0-9a-f]{64}$"
        verifier_key_ref:
          type: string
          minLength: 1
        revocation_ref:
          type: string
          minLength: 1
        registry_status:
          type: string
          enum: [current, stale, unknown]
        revocation_status:
          type: string
          enum: [not-revoked, revoked, unknown]
        alignment_score:
          type: number
          minimum: 0
          maximum: 1
        threshold:
          type: number
          const: 0.8
        status:
          type: string
          enum: [pass, fail]
        evidence_digest:
          type: string
          pattern: "^[0-9a-f]{64}$"
  witness_quorum:
    type: object
    additionalProperties: false
    required:
      - required_count
      - accepted_count
      - required_roles
      - accepted_roles
      - status
    properties:
      required_count:
        type: integer
        const: 2
      accepted_count:
        type: integer
        minimum: 0
      required_roles:
        type: array
        minItems: 2
        maxItems: 2
        uniqueItems: true
        items:
          type: string
          enum: [clinician, guardian]
      accepted_roles:
        type: array
        uniqueItems: true
        items:
          type: string
          minLength: 1
      status:
        type: string
        enum: [met, missing]
  witness_registry_binding:
    type: object
    additionalProperties: false
    required:
      - policy_id
      - registry_profile
      - continuity_subject_ref
      - continuity_subject_digest
      - registry_ref
      - registry_snapshot_digest
      - required_witness_roles
      - accepted_witness_roles
      - accepted_witness_registry_digest_set
      - accepted_witness_key_refs
      - accepted_witness_revocation_refs
      - witness_registry_status
      - witness_revocation_status
      - role_binding_status
      - revocation_verifier_policy_id
      - revocation_verifier_profile
      - revocation_verifier_receipts
      - revocation_verifier_response_digest_set
      - revocation_verifier_response_set_digest
      - revocation_verifier_jurisdictions
      - revocation_verifier_quorum_threshold
      - revocation_verifier_quorum_status
      - revocation_verifier_quorum_digest
      - raw_revocation_verifier_payload_stored
      - raw_registry_payload_stored
      - status
      - registry_binding_digest
    properties:
      policy_id:
        type: string
        const: identity-witness-registry-binding-v1
      registry_profile:
        type: string
        const: role-roster-revocation-bound-v1
      continuity_subject_ref:
        type: string
        pattern: "^identity://.+/ascending-to-active$"
      continuity_subject_digest:
        type: string
        pattern: "^[0-9a-f]{64}$"
      registry_ref:
        type: string
        minLength: 1
      registry_snapshot_digest:
        type: string
        pattern: "^[0-9a-f]{64}$"
      required_witness_roles:
        type: array
        minItems: 2
        maxItems: 2
        uniqueItems: true
        items:
          type: string
          enum: [clinician, guardian]
      accepted_witness_roles:
        type: array
        uniqueItems: true
        items:
          type: string
          minLength: 1
      accepted_witness_registry_digest_set:
        type: array
        uniqueItems: true
        items:
          type: string
          pattern: "^[0-9a-f]{64}$"
      accepted_witness_key_refs:
        type: array
        uniqueItems: true
        items:
          type: string
          minLength: 1
      accepted_witness_revocation_refs:
        type: array
        uniqueItems: true
        items:
          type: string
          minLength: 1
      witness_registry_status:
        type: string
        enum: [current, stale-or-missing]
      witness_revocation_status:
        type: string
        enum: [not-revoked, revoked-or-unknown]
      role_binding_status:
        type: string
        enum: [bound, missing]
      revocation_verifier_policy_id:
        type: string
        const: identity-witness-revocation-live-verifier-quorum-v1
      revocation_verifier_profile:
        type: string
        const: dual-jurisdiction-revocation-live-verifier-v1
      revocation_verifier_receipts:
        type: array
        items:
          type: object
          additionalProperties: false
          required:
            - verifier_ref
            - jurisdiction
            - response_ref
            - registry_ref
            - registry_snapshot_digest
            - covered_revocation_refs
            - response_status
            - checked_at
            - freshness_window_seconds
            - freshness_status
            - raw_verifier_payload_stored
            - response_digest
          properties:
            verifier_ref:
              type: string
              minLength: 1
            jurisdiction:
              type: string
              enum: [JP-13, US-CA]
            response_ref:
              type: string
              minLength: 1
            registry_ref:
              type: string
              minLength: 1
            registry_snapshot_digest:
              type: string
              pattern: "^[0-9a-f]{64}$"
            covered_revocation_refs:
              type: array
              uniqueItems: true
              items:
                type: string
                minLength: 1
            response_status:
              type: string
              enum: [not-revoked, revoked, unknown]
            checked_at:
              type: string
              format: date-time
            freshness_window_seconds:
              type: integer
              minimum: 1
            freshness_status:
              type: string
              enum: [fresh, stale]
            raw_verifier_payload_stored:
              type: boolean
              const: false
            response_digest:
              type: string
              pattern: "^[0-9a-f]{64}$"
      revocation_verifier_response_digest_set:
        type: array
        uniqueItems: true
        items:
          type: string
          pattern: "^[0-9a-f]{64}$"
      revocation_verifier_response_set_digest:
        type: string
        pattern: "^[0-9a-f]{64}$"
      revocation_verifier_jurisdictions:
        type: array
        uniqueItems: true
        items:
          type: string
          enum: [JP-13, US-CA]
      revocation_verifier_quorum_threshold:
        type: integer
        const: 2
      revocation_verifier_quorum_status:
        type: string
        enum: [complete, incomplete]
      revocation_verifier_quorum_digest:
        type: string
        pattern: "^[0-9a-f]{64}$"
      raw_revocation_verifier_payload_stored:
        type: boolean
        const: false
      raw_registry_payload_stored:
        type: boolean
        const: false
      status:
        type: string
        enum: [bound, unbound]
      registry_binding_digest:
        type: string
        pattern: "^[0-9a-f]{64}$"
  self_report_witness_consistency:
    type: object
    additionalProperties: false
    required:
      - policy_id
      - consistency_profile
      - continuity_subject_ref
      - continuity_subject_digest
      - self_report_ref
      - self_report_evidence_digest
      - accepted_witness_evidence_digest_set
      - accepted_witness_roles
      - required_witness_roles
      - self_report_score
      - accepted_witness_mean_score
      - max_score_delta
      - observed_score_delta
      - score_consistency_status
      - role_binding_status
      - status
      - consistency_digest
    properties:
      policy_id:
        type: string
        const: identity-self-report-witness-consistency-v1
      consistency_profile:
        type: string
        const: score-delta-and-role-bound-v1
      continuity_subject_ref:
        type: string
        pattern: "^identity://.+/ascending-to-active$"
      continuity_subject_digest:
        type: string
        pattern: "^[0-9a-f]{64}$"
      self_report_ref:
        type: string
        minLength: 1
      self_report_evidence_digest:
        type: string
        pattern: "^[0-9a-f]{64}$"
      accepted_witness_evidence_digest_set:
        type: array
        uniqueItems: true
        items:
          type: string
          pattern: "^[0-9a-f]{64}$"
      accepted_witness_roles:
        type: array
        uniqueItems: true
        items:
          type: string
          minLength: 1
      required_witness_roles:
        type: array
        minItems: 2
        maxItems: 2
        uniqueItems: true
        items:
          type: string
          enum: [clinician, guardian]
      self_report_score:
        type: number
        minimum: 0
        maximum: 1
      accepted_witness_mean_score:
        type: number
        minimum: 0
        maximum: 1
      max_score_delta:
        type: number
        const: 0.12
      observed_score_delta:
        type: number
        minimum: 0
        maximum: 1
      score_consistency_status:
        type: string
        enum: [consistent, divergent]
      role_binding_status:
        type: string
        enum: [bound, missing]
      status:
        type: string
        enum: [bound, unbound]
      consistency_digest:
        type: string
        pattern: "^[0-9a-f]{64}$"
  result:
    type: string
    enum: [passed, failed]
  active_transition_allowed:
    type: boolean
  failure_action:
    type: string
    enum: [none, failed-ascension-or-repeat-ascending]
  failure_reasons:
    type: array
    items:
      type: string
      enum:
        - dimension-threshold-not-met
        - subjective-self-report-not-bound
        - third-party-witness-quorum-not-met
        - self-report-witness-consistency-not-bound
        - witness-registry-binding-not-bound
        - witness-revocation-verifier-quorum-not-bound
        - aggregate-threshold-not-met
  confirmation_digest:
    type: string
    pattern: "^[0-9a-f]{64}$"
examples:
  - confirmation_id: identity-confirmation-123456789abc
    confirmed_at: "2026-04-24T12:00:00+00:00"
    profile_id: multidimensional-identity-confirmation-v1
    identity_id: id-0001
    lineage_id: id-0001
    transition: ascending-to-active
    consent_ref: consent://identity-confirmation-demo/v1
    scheduler_stage_ref: scheduler://method-a/identity-confirmation
    required_dimensions:
      - episodic_recall
      - self_model_alignment
      - subjective_self_report
      - third_party_witness_alignment
    dimensions:
      - dimension_id: episodic_recall
        source_ref: episodic://identity-confirmation-demo/recall-window
        score: 0.93
        threshold: 0.85
        status: pass
        evidence_digest: "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"
      - dimension_id: self_model_alignment
        source_ref: self-model://identity-confirmation-demo/stable-snapshot
        score: 0.89
        threshold: 0.8
        status: pass
        evidence_digest: "bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb"
      - dimension_id: subjective_self_report
        source_ref: self-report://identity-confirmation-demo/v1
        score: 0.92
        threshold: 0.85
        status: pass
        evidence_digest: "cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc"
      - dimension_id: third_party_witness_alignment
        source_ref: witness-quorum://identity-confirmation
        score: 0.89
        threshold: 0.8
        status: pass
        evidence_digest: "dddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddd"
    aggregate_score: 0.908
    aggregate_threshold: 0.85
    self_report:
      report_ref: self-report://identity-confirmation-demo/v1
      statement_digest: "cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc"
      continuity_score: 0.92
      threshold: 0.85
      status: pass
      evidence_digest: "cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc"
    third_party_witness_receipts:
      - witness_id: witness://identity-confirmation/clinician-primary
        witness_role: clinician
        observation_ref: observation://identity-confirmation/episodic-recall
        registry_entry_ref: identity-witness-registry://entry/clinician-primary
        registry_entry_digest: "1212121212121212121212121212121212121212121212121212121212121212"
        verifier_key_ref: identity-witness-key://clinician-primary
        revocation_ref: identity-witness-revocation://clinician-primary
        registry_status: current
        revocation_status: not-revoked
        alignment_score: 0.88
        threshold: 0.8
        status: pass
        evidence_digest: "eeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeee"
      - witness_id: witness://identity-confirmation/guardian-observer
        witness_role: guardian
        observation_ref: observation://identity-confirmation/self-model-check
        registry_entry_ref: identity-witness-registry://entry/guardian-observer
        registry_entry_digest: "3434343434343434343434343434343434343434343434343434343434343434"
        verifier_key_ref: identity-witness-key://guardian-observer
        revocation_ref: identity-witness-revocation://guardian-observer
        registry_status: current
        revocation_status: not-revoked
        alignment_score: 0.9
        threshold: 0.8
        status: pass
        evidence_digest: "ffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffff"
    witness_quorum:
      required_count: 2
      accepted_count: 2
      required_roles: [clinician, guardian]
      accepted_roles: [clinician, guardian]
      status: met
    witness_registry_binding:
      policy_id: identity-witness-registry-binding-v1
      registry_profile: role-roster-revocation-bound-v1
      continuity_subject_ref: identity://id-0001/ascending-to-active
      continuity_subject_digest: "9999999999999999999999999999999999999999999999999999999999999999"
      registry_ref: identity-witness-registry://reference-runtime/current
      registry_snapshot_digest: "7878787878787878787878787878787878787878787878787878787878787878"
      required_witness_roles: [clinician, guardian]
      accepted_witness_roles: [clinician, guardian]
      accepted_witness_registry_digest_set:
        - "1212121212121212121212121212121212121212121212121212121212121212"
        - "3434343434343434343434343434343434343434343434343434343434343434"
      accepted_witness_key_refs:
        - identity-witness-key://clinician-primary
        - identity-witness-key://guardian-observer
      accepted_witness_revocation_refs:
        - identity-witness-revocation://clinician-primary
        - identity-witness-revocation://guardian-observer
      witness_registry_status: current
      witness_revocation_status: not-revoked
      role_binding_status: bound
      revocation_verifier_policy_id: identity-witness-revocation-live-verifier-quorum-v1
      revocation_verifier_profile: dual-jurisdiction-revocation-live-verifier-v1
      revocation_verifier_receipts:
        - verifier_ref: identity-witness-revocation-verifier://jp-13/reference-runtime
          jurisdiction: JP-13
          response_ref: identity-witness-revocation-verifier-response://jp13
          registry_ref: identity-witness-registry://reference-runtime/current
          registry_snapshot_digest: "7878787878787878787878787878787878787878787878787878787878787878"
          covered_revocation_refs:
            - identity-witness-revocation://clinician-primary
            - identity-witness-revocation://guardian-observer
          response_status: not-revoked
          checked_at: "2026-04-24T12:00:00+00:00"
          freshness_window_seconds: 3600
          freshness_status: fresh
          raw_verifier_payload_stored: false
          response_digest: "5757575757575757575757575757575757575757575757575757575757575757"
        - verifier_ref: identity-witness-revocation-verifier://us-ca/reference-runtime
          jurisdiction: US-CA
          response_ref: identity-witness-revocation-verifier-response://usca
          registry_ref: identity-witness-registry://reference-runtime/current
          registry_snapshot_digest: "7878787878787878787878787878787878787878787878787878787878787878"
          covered_revocation_refs:
            - identity-witness-revocation://clinician-primary
            - identity-witness-revocation://guardian-observer
          response_status: not-revoked
          checked_at: "2026-04-24T12:00:00+00:00"
          freshness_window_seconds: 3600
          freshness_status: fresh
          raw_verifier_payload_stored: false
          response_digest: "5858585858585858585858585858585858585858585858585858585858585858"
      revocation_verifier_response_digest_set:
        - "5757575757575757575757575757575757575757575757575757575757575757"
        - "5858585858585858585858585858585858585858585858585858585858585858"
      revocation_verifier_response_set_digest: "5959595959595959595959595959595959595959595959595959595959595959"
      revocation_verifier_jurisdictions: [JP-13, US-CA]
      revocation_verifier_quorum_threshold: 2
      revocation_verifier_quorum_status: complete
      revocation_verifier_quorum_digest: "6060606060606060606060606060606060606060606060606060606060606060"
      raw_revocation_verifier_payload_stored: false
      raw_registry_payload_stored: false
      status: bound
      registry_binding_digest: "8989898989898989898989898989898989898989898989898989898989898989"
    self_report_witness_consistency:
      policy_id: identity-self-report-witness-consistency-v1
      consistency_profile: score-delta-and-role-bound-v1
      continuity_subject_ref: identity://id-0001/ascending-to-active
      continuity_subject_digest: "9999999999999999999999999999999999999999999999999999999999999999"
      self_report_ref: self-report://identity-confirmation-demo/v1
      self_report_evidence_digest: "cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc"
      accepted_witness_evidence_digest_set:
        - "eeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeee"
        - "ffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffff"
      accepted_witness_roles: [clinician, guardian]
      required_witness_roles: [clinician, guardian]
      self_report_score: 0.92
      accepted_witness_mean_score: 0.89
      max_score_delta: 0.12
      observed_score_delta: 0.03
      score_consistency_status: consistent
      role_binding_status: bound
      status: bound
      consistency_digest: "9999999999999999999999999999999999999999999999999999999999999999"
    result: passed
    active_transition_allowed: true
    failure_action: none
    failure_reasons: []
    confirmation_digest: "1111111111111111111111111111111111111111111111111111111111111111"
