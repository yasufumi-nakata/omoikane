$schema: "https://json-schema.org/draft/2020-12/schema"
$id: "https://omoikane.dev/specs/schemas/ascension_plan.schema"
title: AscensionPlan
description: Multi-stage plan to migrate an identity into Active state using one fixed reference blueprint per method.
type: object
additionalProperties: false
required:
  - kind
  - schema_version
  - plan_id
  - identity_id
  - method
  - stages
  - ethics_attestation_required
  - council_attestation_required
  - governance_artifacts
  - governance_artifact_digest
properties:
  kind:
    const: ascension_plan
  schema_version:
    type: string
    pattern: "^[0-9]+\\.[0-9]+\\.[0-9]+$"
  plan_id:
    type: string
    minLength: 8
  identity_id:
    type: string
    minLength: 1
  method:
    type: string
    enum:
      - A
      - B
      - C
  stages:
    type: array
    minItems: 1
    maxItems: 12
    items:
      type: object
      additionalProperties: false
      required:
        - stage_id
        - precondition
        - timeout_ms
      properties:
        stage_id:
          type: string
          minLength: 1
        precondition:
          type: string
          minLength: 1
        timeout_ms:
          type: integer
          minimum: 1
        rollback_to:
          type:
            - string
            - "null"
  ethics_attestation_required:
    type: boolean
  council_attestation_required:
    type: boolean
  governance_artifacts:
    type: object
    additionalProperties: false
    required:
      - self_consent_ref
      - ethics_attestation_ref
      - council_attestation_ref
      - legal_attestation_ref
      - witness_refs
      - artifact_bundle_ref
    properties:
      self_consent_ref:
        type: string
        pattern: "^consent://"
      ethics_attestation_ref:
        type: string
        pattern: "^ethics://"
      council_attestation_ref:
        type: string
        pattern: "^council://"
      legal_attestation_ref:
        type: string
        pattern: "^legal://"
      witness_refs:
        type: array
        minItems: 2
        items:
          type: string
          pattern: "^witness://"
      artifact_bundle_ref:
        type: string
        pattern: "^artifact://"
  governance_artifact_digest:
    type: string
    pattern: "^[a-f0-9]{64}$"
allOf:
  - if:
      properties:
        method:
          const: A
    then:
      properties:
        stages:
          minItems: 4
          maxItems: 4
  - if:
      properties:
        method:
          const: B
    then:
      properties:
        stages:
          minItems: 4
          maxItems: 4
  - if:
      properties:
        method:
          const: C
    then:
      properties:
        stages:
          minItems: 3
          maxItems: 3
examples:
  - kind: ascension_plan
    schema_version: 1.0.0
    plan_id: plan-method-a-001
    identity_id: identity://amaterasu-endpoint
    method: A
    stages:
      - stage_id: scan-baseline
        precondition: pre-upload-consent
        timeout_ms: 7776000000
        rollback_to: null
      - stage_id: bdb-bridge
        precondition: scan-baseline:done
        timeout_ms: 600000
        rollback_to: scan-baseline
      - stage_id: identity-confirmation
        precondition: bdb-bridge:done
        timeout_ms: 1800000
        rollback_to: bdb-bridge
      - stage_id: active-handoff
        precondition: identity-confirmation:passed
        timeout_ms: 300000
        rollback_to: bdb-bridge
    ethics_attestation_required: true
    council_attestation_required: true
    governance_artifacts:
      self_consent_ref: consent://ascension/a/3dfb1f84a223/self-consent
      ethics_attestation_ref: ethics://ascension/a/3dfb1f84a223/guardian-approval
      council_attestation_ref: council://ascension/a/3dfb1f84a223/reference-resolution
      legal_attestation_ref: legal://ascension/a/3dfb1f84a223/clinical-readiness
      witness_refs:
        - witness://ascension/a/3dfb1f84a223/clinician-primary
        - witness://ascension/a/3dfb1f84a223/guardian-observer
      artifact_bundle_ref: artifact://ascension/a/3dfb1f84a223/bundle
    governance_artifact_digest: 8c1f6de21c0d63b33047e49d4c8b58fffe414e1f5e7d0c6c69c17a2c35e5757d
  - kind: ascension_plan
    schema_version: 1.0.0
    plan_id: plan-method-b-001
    identity_id: identity://parallel-sandbox
    method: B
    stages:
      - stage_id: shadow-sync
        precondition: pre-upload-consent
        timeout_ms: 2592000000
        rollback_to: null
      - stage_id: dual-channel-review
        precondition: shadow-sync:stable
        timeout_ms: 86400000
        rollback_to: shadow-sync
      - stage_id: authority-handoff
        precondition: dual-channel-review:attested
        timeout_ms: 600000
        rollback_to: dual-channel-review
      - stage_id: bio-retirement
        precondition: authority-handoff:confirmed
        timeout_ms: 604800000
        rollback_to: null
    ethics_attestation_required: true
    council_attestation_required: true
    governance_artifacts:
      self_consent_ref: consent://ascension/b/6d751f42d807/self-consent
      ethics_attestation_ref: ethics://ascension/b/6d751f42d807/guardian-approval
      council_attestation_ref: council://ascension/b/6d751f42d807/reference-resolution
      legal_attestation_ref: legal://ascension/b/6d751f42d807/clinical-readiness
      witness_refs:
        - witness://ascension/b/6d751f42d807/clinician-primary
        - witness://ascension/b/6d751f42d807/guardian-observer
      artifact_bundle_ref: artifact://ascension/b/6d751f42d807/bundle
    governance_artifact_digest: 3464077ceb049c9fd405ff55fd93ecfca39896e66f232844ef87cbe126086bf6
  - kind: ascension_plan
    schema_version: 1.0.0
    plan_id: plan-method-c-001
    identity_id: identity://destructive-scan-sandbox
    method: C
    stages:
      - stage_id: consent-lock
        precondition: pre-upload-consent+human-review
        timeout_ms: 604800000
        rollback_to: null
      - stage_id: scan-commit
        precondition: consent-lock:confirmed
        timeout_ms: 300000
        rollback_to: null
      - stage_id: activation-review
        precondition: scan-commit:completed
        timeout_ms: 1800000
        rollback_to: null
    ethics_attestation_required: true
    council_attestation_required: true
    governance_artifacts:
      self_consent_ref: consent://ascension/c/8379532e28cc/self-consent
      ethics_attestation_ref: ethics://ascension/c/8379532e28cc/guardian-approval
      council_attestation_ref: council://ascension/c/8379532e28cc/reference-resolution
      legal_attestation_ref: legal://ascension/c/8379532e28cc/clinical-readiness
      witness_refs:
        - witness://ascension/c/8379532e28cc/clinician-primary
        - witness://ascension/c/8379532e28cc/guardian-observer
      artifact_bundle_ref: artifact://ascension/c/8379532e28cc/bundle
    governance_artifact_digest: 00b22d86d10cdca85e841ec87c3463b817f8f05ded97f44a99b170dbe8893564
