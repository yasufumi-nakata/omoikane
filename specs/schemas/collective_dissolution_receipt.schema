$schema: "https://json-schema.org/draft/2020-12/schema"
$id: "https://omoikane.dev/specs/schemas/collective_dissolution_receipt.schema"
title: CollectiveDissolutionReceipt
description: >
  First-class dissolution receipt proving that a bounded collective identity ended
  after every member reclaimed independent subjectivity.
type: object
additionalProperties: false
required:
  - schema_version
  - collective_id
  - recorded_at
  - requested_by
  - status
  - member_confirmations
  - reason
  - member_recovery_required
  - member_recovery_binding_profile
  - member_recovery_proofs
  - member_recovery_confirmation_digest_set
  - member_recovery_binding_digest
  - raw_identity_confirmation_profiles_stored
  - audit_event_ref
properties:
  schema_version:
    const: "1.0"
  collective_id:
    type: string
    minLength: 8
  recorded_at:
    type: string
    format: date-time
  requested_by:
    type: string
    minLength: 1
  status:
    type: string
    const: dissolved
  member_confirmations:
    type: object
    minProperties: 2
    additionalProperties:
      type: boolean
      const: true
  reason:
    type: string
    minLength: 1
  member_recovery_required:
    type: boolean
    const: true
  member_recovery_binding_profile:
    type: string
    const: collective-dissolution-identity-confirmation-binding-v1
  member_recovery_proofs:
    type: object
    minProperties: 2
    additionalProperties:
      type: object
      additionalProperties: false
      required:
        - member_id
        - identity_confirmation_ref
        - identity_confirmation_profile_id
        - identity_confirmation_digest
        - active_transition_allowed
        - result
        - required_dimensions
        - witness_quorum_status
        - self_report_witness_consistency_status
        - self_report_witness_consistency_digest
        - recovery_status
        - raw_profile_stored
      properties:
        member_id:
          type: string
          minLength: 1
        identity_confirmation_ref:
          type: string
          minLength: 1
        identity_confirmation_profile_id:
          type: string
          const: multidimensional-identity-confirmation-v1
        identity_confirmation_digest:
          type: string
          pattern: "^[0-9a-f]{64}$"
        active_transition_allowed:
          type: boolean
          const: true
        result:
          type: string
          const: passed
        required_dimensions:
          type: array
          minItems: 4
          maxItems: 4
          uniqueItems: true
          items:
            type: string
            enum:
              - episodic_recall
              - self_model_alignment
              - subjective_self_report
              - third_party_witness_alignment
        witness_quorum_status:
          type: string
          const: met
        self_report_witness_consistency_status:
          type: string
          const: bound
        self_report_witness_consistency_digest:
          type: string
          pattern: "^[0-9a-f]{64}$"
        recovery_status:
          type: string
          const: confirmed
        raw_profile_stored:
          type: boolean
          const: false
  member_recovery_confirmation_digest_set:
    type: array
    minItems: 2
    items:
      type: string
      pattern: "^[0-9a-f]{64}$"
  member_recovery_binding_digest:
    type: string
    pattern: "^[0-9a-f]{64}$"
  raw_identity_confirmation_profiles_stored:
    type: boolean
    const: false
  audit_event_ref:
    type: string
    minLength: 1
examples:
  - schema_version: "1.0"
    collective_id: identity://collective-meridian
    recorded_at: "2026-04-26T00:00:00Z"
    requested_by: identity://origin
    status: dissolved
    member_confirmations:
      identity://origin: true
      identity://peer: true
    reason: bounded merge ended and both members recovered independent subjectivity
    member_recovery_required: true
    member_recovery_binding_profile: collective-dissolution-identity-confirmation-binding-v1
    member_recovery_proofs:
      identity://origin:
        member_id: identity://origin
        identity_confirmation_ref: identity-confirmation://identity-confirmation-aaaaaaaaaaaa
        identity_confirmation_profile_id: multidimensional-identity-confirmation-v1
        identity_confirmation_digest: "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"
        active_transition_allowed: true
        result: passed
        required_dimensions:
          - episodic_recall
          - self_model_alignment
          - subjective_self_report
          - third_party_witness_alignment
        witness_quorum_status: met
        self_report_witness_consistency_status: bound
        self_report_witness_consistency_digest: "bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb"
        recovery_status: confirmed
        raw_profile_stored: false
      identity://peer:
        member_id: identity://peer
        identity_confirmation_ref: identity-confirmation://identity-confirmation-cccccccccccc
        identity_confirmation_profile_id: multidimensional-identity-confirmation-v1
        identity_confirmation_digest: "cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc"
        active_transition_allowed: true
        result: passed
        required_dimensions:
          - episodic_recall
          - self_model_alignment
          - subjective_self_report
          - third_party_witness_alignment
        witness_quorum_status: met
        self_report_witness_consistency_status: bound
        self_report_witness_consistency_digest: "dddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddd"
        recovery_status: confirmed
        raw_profile_stored: false
    member_recovery_confirmation_digest_set:
      - "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"
      - "cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc"
    member_recovery_binding_digest: "eeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeee"
    raw_identity_confirmation_profiles_stored: false
    audit_event_ref: ledger://collective-dissolution/collective-dissolution-0123456789ab
