$schema: "https://json-schema.org/draft/2020-12/schema"
$id: "https://omoikane.dev/specs/schemas/trust_redacted_verifier_federation.schema"
title: TrustRedactedVerifierFederation
description: >
  Public redacted verifier federation summary that exposes verifier identity,
  freshness timing, and commitment digests while sealing the underlying live
  receipt payloads.
type: object
additionalProperties: false
required:
  - kind
  - schema_version
  - federation_id
  - federation_ref
  - summary_profile_id
  - federation_policy_id
  - network_profile_id
  - quorum_policy_id
  - human_reviewer_ref
  - required_verifier_count
  - received_verifier_count
  - verifier_receipt_summaries
  - verifier_refs
  - trust_root_refs
  - jurisdictions
  - trust_root_quorum
  - jurisdiction_quorum
  - authority_chain_refs
  - reviewer_binding_digest
  - verifier_receipt_commitment_digest
  - sealed_federation_digest
  - redaction_policy_id
  - redacted_fields
  - federation_status
  - receipt_digest
properties:
  kind:
    const: trust_redacted_verifier_federation
  schema_version:
    type: string
    pattern: "^[0-9]+\\.[0-9]+\\.[0-9]+$"
  federation_id:
    type: string
    pattern: "^trust-verifier-federation-[a-f0-9]{12}$"
  federation_ref:
    type: string
    minLength: 1
  summary_profile_id:
    const: bounded-trust-transfer-redacted-verifier-federation-v1
  federation_policy_id:
    const: bounded-live-trust-transfer-verifier-federation-v1
  network_profile_id:
    const: guardian-reviewer-remote-attestation-v1
  quorum_policy_id:
    type: string
    enum:
      - bounded-trust-transfer-fixed-verifier-pair-v1
      - bounded-trust-transfer-multi-root-recovery-v1
  human_reviewer_ref:
    type: string
    minLength: 1
  required_verifier_count:
    type: integer
    minimum: 2
  received_verifier_count:
    type: integer
    minimum: 0
  verifier_receipt_summaries:
    type: array
    minItems: 2
    items:
      $ref: "./trust_redacted_verifier_receipt_summary.schema"
  verifier_refs:
    type: array
    minItems: 2
    uniqueItems: true
    items:
      type: string
      minLength: 1
  trust_root_refs:
    type: array
    minItems: 1
    uniqueItems: true
    items:
      type: string
      minLength: 1
  jurisdictions:
    type: array
    minItems: 1
    uniqueItems: true
    items:
      type: string
      minLength: 1
  trust_root_quorum:
    type: integer
    minimum: 1
  jurisdiction_quorum:
    type: integer
    minimum: 1
  authority_chain_refs:
    type: array
    minItems: 1
    uniqueItems: true
    items:
      type: string
      minLength: 1
  reviewer_binding_digest:
    type: string
    pattern: "^[a-f0-9]{64}$"
  verifier_receipt_commitment_digest:
    type: string
    pattern: "^[a-f0-9]{64}$"
  sealed_federation_digest:
    type: string
    pattern: "^[a-f0-9]{64}$"
  redaction_policy_id:
    const: bounded-trust-transfer-verifier-summary-redaction-v1
  redacted_fields:
    type: array
    uniqueItems: true
    items:
      type: string
      minLength: 1
  federation_status:
    const: verified
  receipt_digest:
    type: string
    pattern: "^[a-f0-9]{64}$"
examples:
  - kind: trust_redacted_verifier_federation
    schema_version: 1.0.0
    federation_id: trust-verifier-federation-0123456789ab
    federation_ref: trust-verifier-federation://4c38ec8f5f8a
    summary_profile_id: bounded-trust-transfer-redacted-verifier-federation-v1
    federation_policy_id: bounded-live-trust-transfer-verifier-federation-v1
    network_profile_id: guardian-reviewer-remote-attestation-v1
    human_reviewer_ref: human://yasufumi
    required_verifier_count: 2
    received_verifier_count: 2
    verifier_receipt_summaries:
      - kind: trust_redacted_verifier_receipt_summary
        schema_version: 1.0.0
        summary_id: trust-verifier-summary-0123456789ab
        summary_ref: trust-redacted-verifier-receipt://4c38ec8f5f8a
        summary_profile_id: bounded-trust-transfer-redacted-verifier-receipt-summary-v1
        receipt_id: verifier-network-receipt-aaaaaaaaaaaa
        verifier_endpoint: verifier://guardian-oversight.jp
        verifier_ref: verifier://guardian-oversight.jp/reviewer-alpha
        jurisdiction: JP-13
        network_profile_id: guardian-reviewer-remote-attestation-v1
        authority_chain_ref: authority://guardian-oversight.jp/reviewer-attestation
        trust_root_ref: root://guardian-oversight.jp/reviewer-live-pki
        freshness_window_seconds: 900
        observed_latency_ms: 48.6
        recorded_at: "2026-04-24T00:10:00Z"
        receipt_status: verified
        transport_exchange_digest: 5600b1c59519cd93f529a24cd90ded53a6ea2e787c1d460fa5b3ffd460c75fc3
        sealed_receipt_digest: 9524158fbd8e6ded8d0c7b0b932bffbfe53c883b0ee00f735f02cc7c73cf11ba
        redaction_policy_id: bounded-trust-transfer-verifier-summary-redaction-v1
        redacted_fields:
          - verifier_receipts[].reviewer_id
          - verifier_receipts[].challenge_ref
          - verifier_receipts[].challenge_digest
          - verifier_receipts[].trust_root_digest
          - verifier_receipts[].transport_exchange.exchange_id
          - verifier_receipts[].transport_exchange.challenge_ref
          - verifier_receipts[].transport_exchange.challenge_digest
          - verifier_receipts[].transport_exchange.request_payload_kind
          - verifier_receipts[].transport_exchange.request_payload_ref
          - verifier_receipts[].transport_exchange.request_payload_digest
          - verifier_receipts[].transport_exchange.request_size_bytes
          - verifier_receipts[].transport_exchange.response_payload_kind
          - verifier_receipts[].transport_exchange.response_payload_ref
          - verifier_receipts[].transport_exchange.response_payload_digest
          - verifier_receipts[].transport_exchange.response_size_bytes
          - verifier_receipts[].transport_exchange.recorded_at
        summary_digest: aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
      - kind: trust_redacted_verifier_receipt_summary
        schema_version: 1.0.0
        summary_id: trust-verifier-summary-bbbbbbbbbbbb
        summary_ref: trust-redacted-verifier-receipt://2c4cc0d4f4b0
        summary_profile_id: bounded-trust-transfer-redacted-verifier-receipt-summary-v1
        receipt_id: verifier-network-receipt-bbbbbbbbbbbb
        verifier_endpoint: verifier://guardian-oversight.jp
        verifier_ref: verifier://guardian-oversight.jp/reviewer-beta
        jurisdiction: JP-13
        network_profile_id: guardian-reviewer-remote-attestation-v1
        authority_chain_ref: authority://guardian-oversight.jp/reviewer-attestation
        trust_root_ref: root://guardian-oversight.jp/reviewer-live-pki
        freshness_window_seconds: 900
        observed_latency_ms: 49.2
        recorded_at: "2026-04-24T00:10:00Z"
        receipt_status: verified
        transport_exchange_digest: 4600b1c59519cd93f529a24cd90ded53a6ea2e787c1d460fa5b3ffd460c75fc3
        sealed_receipt_digest: 8524158fbd8e6ded8d0c7b0b932bffbfe53c883b0ee00f735f02cc7c73cf11ba
        redaction_policy_id: bounded-trust-transfer-verifier-summary-redaction-v1
        redacted_fields:
          - verifier_receipts[].reviewer_id
          - verifier_receipts[].challenge_ref
          - verifier_receipts[].challenge_digest
          - verifier_receipts[].trust_root_digest
          - verifier_receipts[].transport_exchange.exchange_id
          - verifier_receipts[].transport_exchange.challenge_ref
          - verifier_receipts[].transport_exchange.challenge_digest
          - verifier_receipts[].transport_exchange.request_payload_kind
          - verifier_receipts[].transport_exchange.request_payload_ref
          - verifier_receipts[].transport_exchange.request_payload_digest
          - verifier_receipts[].transport_exchange.request_size_bytes
          - verifier_receipts[].transport_exchange.response_payload_kind
          - verifier_receipts[].transport_exchange.response_payload_ref
          - verifier_receipts[].transport_exchange.response_payload_digest
          - verifier_receipts[].transport_exchange.response_size_bytes
          - verifier_receipts[].transport_exchange.recorded_at
        summary_digest: bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb
    verifier_refs:
      - verifier://guardian-oversight.jp/reviewer-alpha
      - verifier://guardian-oversight.jp/reviewer-beta
    trust_root_refs:
      - root://guardian-oversight.jp/reviewer-live-pki
    authority_chain_refs:
      - authority://guardian-oversight.jp/reviewer-attestation
    reviewer_binding_digest: cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc
    verifier_receipt_commitment_digest: dddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddd
    sealed_federation_digest: eeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeee
    redaction_policy_id: bounded-trust-transfer-verifier-summary-redaction-v1
    redacted_fields:
      - verifier_receipts[].reviewer_id
      - verifier_receipts[].challenge_ref
      - verifier_receipts[].challenge_digest
      - verifier_receipts[].trust_root_digest
      - verifier_receipts[].transport_exchange.exchange_id
      - verifier_receipts[].transport_exchange.challenge_ref
      - verifier_receipts[].transport_exchange.challenge_digest
      - verifier_receipts[].transport_exchange.request_payload_kind
      - verifier_receipts[].transport_exchange.request_payload_ref
      - verifier_receipts[].transport_exchange.request_payload_digest
      - verifier_receipts[].transport_exchange.request_size_bytes
      - verifier_receipts[].transport_exchange.response_payload_kind
      - verifier_receipts[].transport_exchange.response_payload_ref
      - verifier_receipts[].transport_exchange.response_payload_digest
      - verifier_receipts[].transport_exchange.response_size_bytes
      - verifier_receipts[].transport_exchange.recorded_at
    federation_status: verified
    receipt_digest: ffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffff
