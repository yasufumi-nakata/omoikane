        substrate_cluster_ref: substrate-cluster://reference-broker-fabric
        host_binding_digest: "00112233445566778899aabbccddeeff00112233445566778899aabbccddeeff"
        observed_at: "2026-04-21T12:00:00Z"
      - sequence: 2
        source_attestation_id: attest-0123456789ab
        shadow_allocation_id: alloc-bbbbbbbbbbbb
