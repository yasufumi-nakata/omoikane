        type: string
        minLength: 1
      source_manifest_digest:
        type: string
        pattern: "^[0-9a-f]{64}$"
      key_loss_signal_ref:
        type: string
        minLength: 1
      previous_key_epoch:
        type: integer
        minimum: 1
      successor_key_epoch:
        type: integer
        minimum: 2
      recovery_window_seconds:
        type: integer
        const: 86400
      recovery_threshold:
        type: integer
        const: 3
      share_count:
        type: integer
        const: 5
      required_guardian_attestations:
        type: integer
        const: 2
      accepted_share_refs:
        type: array
        minItems: 3
        uniqueItems: true
        items:
          type: string
          minLength: 1
      share_commitments:
        type: array
        minItems: 5
        maxItems: 5
        items:
          $ref: "#/$defs/key_share_commitment"
      guardian_attestations:
        type: array
        minItems: 2
        items:
          $ref: "#/$defs/key_succession_guardian_attestation"
      successor_key_ref:
        type: string
        minLength: 1
      successor_key_digest:
        type: string
        pattern: "^[0-9a-f]{64}$"
      rotation_ledger_ref:
