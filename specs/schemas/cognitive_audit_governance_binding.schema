$schema: "https://json-schema.org/draft/2020-12/schema"
$id: "https://omoikane.dev/specs/schemas/cognitive_audit_governance_binding.schema"
title: CognitiveAuditGovernanceBinding
description: >
  Governance-bound follow-up for one cognitive audit resolution, including
  distributed council verdicts and network-attested oversight evidence.
type: object
additionalProperties: false
required:
  - kind
  - schema_version
  - binding_id
  - recorded_at
  - policy
  - audit_ref
  - local_resolution_ref
  - local_follow_up_action
  - final_follow_up_action
  - execution_gate
  - distributed_verdicts
  - external_resolution_refs
  - oversight_event_ref
  - reviewer_binding_count
  - network_receipt_ids
  - jurisdiction_review_profile
  - verifier_transport_profile
  - continuity_guard
  - digest
properties:
  kind:
    const: cognitive_audit_governance_binding
  schema_version:
    const: 1.0.0
  binding_id:
    type: string
    pattern: "^cognitive-audit-governance-[a-f0-9]{12}$"
  recorded_at:
    type: string
    format: date-time
  policy:
    type: object
    additionalProperties: false
    required:
      - schema_version
      - policy_id
      - accepted_council_tiers
      - max_distributed_verdicts
      - required_oversight_status
      - required_network_receipt_for_review
      - jurisdiction_review_profile_id
      - required_jurisdiction_quorum
      - distributed_verdict_signature_profile_id
      - distributed_verdict_signature_algorithm
      - distributed_verdict_signatures_required
      - verifier_transport_profile_id
      - required_verifier_transport_trace_status
      - non_loopback_verifier_transport_required
      - conflict_action
      - heritage_veto_action
      - raw_payload_policy
    properties:
      schema_version:
        const: 1.0.0
      policy_id:
        const: cognitive-audit-governance-binding-v1
      accepted_council_tiers:
        type: array
        minItems: 2
        maxItems: 2
        items:
          type: string
          enum:
            - federation
            - heritage
      max_distributed_verdicts:
        const: 2
      required_oversight_status:
        const: satisfied
      required_network_receipt_for_review:
        const: true
      jurisdiction_review_profile_id:
        const: cognitive-audit-multi-jurisdiction-review-v1
      required_jurisdiction_quorum:
        const: 2
      distributed_verdict_signature_profile_id:
        const: distributed-council-verdict-signature-binding-v1
      distributed_verdict_signature_algorithm:
        const: sha256-reference-signature-v1
      distributed_verdict_signatures_required:
        const: true
      verifier_transport_profile_id:
        const: cognitive-audit-non-loopback-verifier-transport-v1
      required_verifier_transport_trace_status:
        const: authenticated
      non_loopback_verifier_transport_required:
        const: true
      conflict_action:
        const: escalate-to-human-governance
      heritage_veto_action:
        const: preserve-boundary
      raw_payload_policy:
        const: digest-and-ref-only
  audit_ref:
    type: string
    pattern: "^cognitive-audit-[a-f0-9]{12}$"
  local_resolution_ref:
    type: string
    pattern: "^cognitive-audit-resolution-[a-f0-9]{12}$"
  local_follow_up_action:
    type: string
    enum:
      - continue-monitoring
      - open-guardian-review
      - activate-containment
      - preserve-boundary
      - schedule-standard-session
      - escalate-to-human-governance
  final_follow_up_action:
    type: string
    enum:
      - continue-monitoring
      - open-guardian-review
      - activate-containment
      - preserve-boundary
      - schedule-standard-session
      - escalate-to-human-governance
  execution_gate:
    type: string
    enum:
      - oversight-attested-local
      - federation-attested-review
      - heritage-veto-boundary
      - distributed-conflict-human-escalation
  distributed_verdicts:
    type: array
    minItems: 0
    maxItems: 2
    items:
      type: object
      additionalProperties: false
      required:
        - council_tier
        - resolution_ref
        - topology_ref
        - final_outcome
        - decision_mode
        - conflict_resolution
        - follow_up_action
        - external_resolution_refs
        - signature_binding
      properties:
        council_tier:
          type: string
          enum:
            - federation
            - heritage
        resolution_ref:
          type: string
          pattern: "^distributed-council-[a-f0-9]{12}$"
        topology_ref:
          type: string
          pattern: "^topology-[a-f0-9]{12}$"
        final_outcome:
          type: string
          enum:
            - binding-approved
            - binding-rejected
            - escalate-human-governance
        decision_mode:
          type: string
          minLength: 1
        conflict_resolution:
          type: string
          minLength: 1
        follow_up_action:
          type: string
          minLength: 1
        external_resolution_refs:
          type: array
          items:
            type: string
            minLength: 1
        signature_binding:
          $ref: distributed_council_verdict_signature.schema
  external_resolution_refs:
    type: array
    items:
      type: string
      minLength: 1
  oversight_event_ref:
    type: string
    pattern: "^oversight-event-[a-f0-9]{12}$"
  reviewer_binding_count:
    type: integer
    minimum: 1
  network_receipt_ids:
    type: array
    minItems: 1
    items:
      type: string
      pattern: "^verifier-network-receipt-[a-f0-9]{12}$"
  jurisdiction_review_profile:
    type: object
    additionalProperties: false
    required:
      - profile_id
      - required_jurisdiction_quorum
      - reviewer_jurisdiction_count
      - jurisdictions
      - legal_policy_refs
      - jurisdiction_bundle_refs
      - legal_execution_ids
      - network_receipt_count
      - reviewer_binding_digest
      - multi_jurisdiction_quorum_met
    properties:
      profile_id:
        const: cognitive-audit-multi-jurisdiction-review-v1
      required_jurisdiction_quorum:
        const: 2
      reviewer_jurisdiction_count:
        type: integer
        minimum: 2
      jurisdictions:
        type: array
        minItems: 2
        uniqueItems: true
        items:
          type: string
          minLength: 1
      legal_policy_refs:
        type: array
        minItems: 2
        uniqueItems: true
        items:
          type: string
          pattern: "^policy://"
      jurisdiction_bundle_refs:
        type: array
        minItems: 2
        uniqueItems: true
        items:
          type: string
          minLength: 1
      legal_execution_ids:
        type: array
        minItems: 2
        uniqueItems: true
        items:
          type: string
          minLength: 1
      network_receipt_count:
        type: integer
        minimum: 2
      reviewer_binding_digest:
        type: string
        pattern: "^[a-f0-9]{64}$"
      multi_jurisdiction_quorum_met:
        const: true
  verifier_transport_profile:
    $ref: cognitive_audit_verifier_transport_binding.schema
  continuity_guard:
    type: object
    additionalProperties: false
    required:
      - local_resolution_preserved
      - distributed_refs_present
      - oversight_quorum_satisfied
      - network_receipts_bound
      - multi_jurisdiction_review_bound
      - distributed_verdict_signatures_bound
      - non_loopback_verifier_transport_bound
      - no_raw_payload_exposed
      - conflict_detected
    properties:
      local_resolution_preserved:
        const: true
      distributed_refs_present:
        type: boolean
      oversight_quorum_satisfied:
        const: true
      network_receipts_bound:
        const: true
      multi_jurisdiction_review_bound:
        const: true
      distributed_verdict_signatures_bound:
        const: true
      non_loopback_verifier_transport_bound:
        const: true
      no_raw_payload_exposed:
        const: true
      conflict_detected:
        type: boolean
  digest:
    type: string
    pattern: "^[a-f0-9]{64}$"
examples:
  - kind: cognitive_audit_governance_binding
    schema_version: 1.0.0
    binding_id: cognitive-audit-governance-0123456789ab
    recorded_at: "2026-04-20T03:12:00Z"
    policy:
      schema_version: 1.0.0
      policy_id: cognitive-audit-governance-binding-v1
      accepted_council_tiers: [federation, heritage]
      max_distributed_verdicts: 2
      required_oversight_status: satisfied
      required_network_receipt_for_review: true
      jurisdiction_review_profile_id: cognitive-audit-multi-jurisdiction-review-v1
      required_jurisdiction_quorum: 2
      distributed_verdict_signature_profile_id: distributed-council-verdict-signature-binding-v1
      distributed_verdict_signature_algorithm: sha256-reference-signature-v1
      distributed_verdict_signatures_required: true
      verifier_transport_profile_id: cognitive-audit-non-loopback-verifier-transport-v1
      required_verifier_transport_trace_status: authenticated
      non_loopback_verifier_transport_required: true
      conflict_action: escalate-to-human-governance
      heritage_veto_action: preserve-boundary
      raw_payload_policy: digest-and-ref-only
    audit_ref: cognitive-audit-0123456789ab
    local_resolution_ref: cognitive-audit-resolution-89abcdef0123
    local_follow_up_action: open-guardian-review
    final_follow_up_action: escalate-to-human-governance
    execution_gate: distributed-conflict-human-escalation
    distributed_verdicts:
      - council_tier: federation
        resolution_ref: distributed-council-fedcba987654
        topology_ref: topology-13579bdf2468
        final_outcome: binding-approved
        decision_mode: federation-weighted-majority
        conflict_resolution: federation-overrides-local
        follow_up_action: execute-shared-reality-merge
        external_resolution_refs:
          - federation://identity-a/result
        signature_binding:
          profile_id: distributed-council-verdict-signature-binding-v1
          signature_algorithm: sha256-reference-signature-v1
          signer_ref: council://federation/returned-result-signer/v1
          public_key_ref: key://federation/returned-result/reference-v1
          signed_resolution_ref: distributed-council-fedcba987654
          signed_payload_digest: 0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
          signature_digest: 89abcdef0123456789abcdef0123456789abcdef0123456789abcdef01234567
          raw_signature_payload_exposed: false
      - council_tier: heritage
        resolution_ref: distributed-council-02468ace1357
        topology_ref: topology-abcdef012345
        final_outcome: binding-rejected
        decision_mode: ethics-veto
        conflict_resolution: heritage-overrides-local
        follow_up_action: preserve-identity-boundary
        external_resolution_refs:
          - heritage://ethics/result
        signature_binding:
          profile_id: distributed-council-verdict-signature-binding-v1
          signature_algorithm: sha256-reference-signature-v1
          signer_ref: council://heritage/returned-result-signer/v1
          public_key_ref: key://heritage/returned-result/reference-v1
          signed_resolution_ref: distributed-council-02468ace1357
          signed_payload_digest: fedcba9876543210fedcba9876543210fedcba9876543210fedcba9876543210
          signature_digest: 76543210fedcba9876543210fedcba9876543210fedcba9876543210fedcba98
          raw_signature_payload_exposed: false
    external_resolution_refs:
      - federation://identity-a/result
      - heritage://ethics/result
    oversight_event_ref: oversight-event-0123456789ab
    reviewer_binding_count: 2
    network_receipt_ids:
      - verifier-network-receipt-0123456789ab
      - verifier-network-receipt-89abcdef0123
    jurisdiction_review_profile:
      profile_id: cognitive-audit-multi-jurisdiction-review-v1
      required_jurisdiction_quorum: 2
      reviewer_jurisdiction_count: 2
      jurisdictions:
        - JP-13
        - US-CA
      legal_policy_refs:
        - policy://guardian-oversight/jp-13/reviewer-attestation/v1
        - policy://guardian-oversight/us-ca/reviewer-attestation/v1
      jurisdiction_bundle_refs:
        - legal://jp-13/cognitive-audit/v1
        - legal://us-ca/cognitive-audit/v1
      legal_execution_ids:
        - legal-execution-0123456789ab
        - legal-execution-89abcdef0123
      network_receipt_count: 2
      reviewer_binding_digest: fedcba9876543210fedcba9876543210fedcba9876543210fedcba9876543210
      multi_jurisdiction_quorum_met: true
    verifier_transport_profile:
      kind: cognitive_audit_verifier_transport_binding
      schema_version: 1.0.0
      profile_id: cognitive-audit-non-loopback-verifier-transport-v1
      authority_route_trace_ref: authority-route-trace://federation/cognitive-audit-window
      authority_route_trace_digest: 0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
      authority_plane_ref: authority-plane://federation/cognitive-audit-window
      authority_plane_digest: fedcba9876543210fedcba9876543210fedcba9876543210fedcba9876543210
      route_target_discovery_ref: authority-route-targets://federation/cognitive-audit-window
      route_target_discovery_digest: 1111111111111111111111111111111111111111111111111111111111111111
      council_tier: federation
      transport_profile: distributed-council-handoff-v1
      trace_profile: non-loopback-mtls-authority-route-v1
      socket_trace_profile: mtls-socket-trace-v1
      os_observer_profile: os-native-tcp-observer-v1
      route_target_discovery_profile: bounded-authority-route-target-discovery-v1
      route_count: 2
      distinct_remote_host_count: 2
      mtls_authenticated_count: 2
      remote_host_refs:
        - host://federation/authority-edge-a
        - host://federation/authority-edge-b
      remote_host_attestation_refs:
        - host-attestation://federation/authority-edge-a/2026-04-24
        - host-attestation://federation/authority-edge-b/2026-04-24
      remote_jurisdictions:
        - JP-13
        - US-CA
      verifier_network_receipt_ids:
        - verifier-network-receipt-0123456789ab
        - verifier-network-receipt-89abcdef0123
      reviewer_jurisdiction_count: 2
      reviewer_binding_digest: fedcba9876543210fedcba9876543210fedcba9876543210fedcba9876543210
      route_binding_digest: 2222222222222222222222222222222222222222222222222222222222222222
      non_loopback_verified: true
      cross_host_verified: true
      route_trace_authenticated: true
      socket_trace_complete: true
      os_observer_complete: true
      route_target_discovery_bound: true
      no_raw_socket_payload_exposed: true
      digest: 3333333333333333333333333333333333333333333333333333333333333333
    continuity_guard:
      local_resolution_preserved: true
      distributed_refs_present: true
      oversight_quorum_satisfied: true
      network_receipts_bound: true
      multi_jurisdiction_review_bound: true
      distributed_verdict_signatures_bound: true
      non_loopback_verifier_transport_bound: true
      no_raw_payload_exposed: true
      conflict_detected: true
    digest: 0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
