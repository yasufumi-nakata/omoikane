        $ref: "#/$defs/sha256"
      mtls_client_certificate_previous_retirement_ref:
        type: string
        pattern: "^registry-client-cert-retirement://"
      mtls_client_certificate_previous_retirement_digest:
        $ref: "#/$defs/sha256"
      mtls_client_certificate_renewal_event_ref:
        type: string
        pattern: "^registry-client-cert-renewal://"
      mtls_client_certificate_renewal_event_digest:
        $ref: "#/$defs/sha256"
      mtls_client_certificate_lifecycle_status:
        enum:
          - renewed
          - stale
          - revoked
      mtls_client_certificate_lifecycle_window_seconds:
        const: 172800
      mtls_client_certificate_lifecycle_checked_at:
        type: string
        format: date-time
      mtls_client_certificate_lifecycle_fail_closed_action:
        enum:
          - accept-renewed-client-certificate
          - reject-stale-client-certificate
          - reject-revoked-client-certificate
      mtls_client_certificate_lifecycle_proof_digest:
        $ref: "#/$defs/sha256"
      raw_client_certificate_lifecycle_payload_stored:
        const: false
  ack_mtls_client_certificate_lifecycle_chain_proof:
    type: object
    additionalProperties: false
    required:
      - probe_id
      - ack_receipt_digest
      - registry_authority_ref
      - registry_jurisdiction
      - registry_ack_endpoint_ref
      - mtls_client_certificate_ref
      - mtls_client_certificate_lifecycle_proof_digest
      - mtls_client_certificate_lifecycle_chain_depth
      - mtls_client_certificate_lifecycle_chain_refs
      - mtls_client_certificate_lifecycle_chain_fingerprints
      - mtls_client_certificate_lifecycle_chain_retirement_digests
      - mtls_client_certificate_lifecycle_chain_renewal_event_digests
      - mtls_client_certificate_lifecycle_chain_set_digest
      - mtls_client_certificate_lifecycle_chain_status
      - mtls_client_certificate_lifecycle_chain_proof_digest
      - raw_client_certificate_lifecycle_chain_payload_stored
    properties:
      probe_id:
        type: string
        pattern: "^collective-registry-ack-probe-[a-f0-9]{12}$"
      ack_receipt_digest:
        $ref: "#/$defs/sha256"
      registry_authority_ref:
        type: string
        pattern: "^(legal-registry|governance-registry)://"
      registry_jurisdiction:
        type: string
        minLength: 2
      registry_ack_endpoint_ref:
        type: string
        pattern: "^https?://"
      mtls_client_certificate_ref:
        type: string
        pattern: "^registry-client-cert://"
      mtls_client_certificate_lifecycle_proof_digest:
        $ref: "#/$defs/sha256"
      mtls_client_certificate_lifecycle_chain_depth:
        const: 3
      mtls_client_certificate_lifecycle_chain_refs:
        type: array
        minItems: 3
        maxItems: 3
        items:
          type: string
          pattern: "^registry-client-cert://"
      mtls_client_certificate_lifecycle_chain_fingerprints:
        type: array
        minItems: 3
        maxItems: 3
        items:
          $ref: "#/$defs/sha256"
      mtls_client_certificate_lifecycle_chain_retirement_digests:
        type: array
        minItems: 2
        maxItems: 2
        items:
          $ref: "#/$defs/sha256"
      mtls_client_certificate_lifecycle_chain_renewal_event_digests:
        type: array
        minItems: 2
        maxItems: 2
        items:
          $ref: "#/$defs/sha256"
      mtls_client_certificate_lifecycle_chain_set_digest:
        $ref: "#/$defs/sha256"
      mtls_client_certificate_lifecycle_chain_status:
        const: complete
      mtls_client_certificate_lifecycle_chain_proof_digest:
        $ref: "#/$defs/sha256"
      raw_client_certificate_lifecycle_chain_payload_stored:
        const: false
  sha256:
    type: string
    pattern: "^[0-9a-f]{64}$"
