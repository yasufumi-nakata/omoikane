$schema: "https://json-schema.org/draft/2020-12/schema"
$id: "https://omoikane.dev/specs/schemas/collective_external_registry_sync.schema"
title: CollectiveExternalRegistrySync
description: >
  Digest-only receipt proving that a post-dissolution collective recovery chain
  was synchronized to external legal and governance registries without storing
  raw dissolution payloads, raw registry payloads, raw acknowledgement route
  payloads, or raw packet bodies.
type: object
additionalProperties: false
required:
  - kind
  - schema_version
  - profile_id
  - digest_profile
  - registry_entry_digest_profile
  - collective_id
  - recorded_at
  - status
  - source_capture_export_profile_id
  - recovery_capture_export_binding_digest
  - recovery_route_trace_binding_digest
  - recovery_verifier_transport_binding_digest
  - dissolution_receipt_digest
  - member_recovery_binding_digest
  - packet_capture_digest
  - privileged_capture_digest
  - member_capture_binding_digest_set_digest
  - legal_registry_ref
  - legal_jurisdiction
  - legal_registry_digest
  - governance_registry_ref
  - governance_jurisdiction
  - governance_registry_digest
  - registry_authority_digest
  - registry_entry_ref
  - registry_entry_digest
  - submission_profile_id
  - submission_receipt_ref
  - submission_receipt_digest
  - ack_profile_id
  - ack_receipt_ref
  - ack_receipt_digest
  - ack_quorum_profile_id
  - ack_quorum_digest_profile
  - ack_quorum_required_authority_count
  - ack_quorum_required_jurisdiction_count
  - ack_quorum_authority_refs
  - ack_quorum_jurisdictions
  - ack_quorum_receipts
  - ack_quorum_digest_set
  - ack_quorum_digest_set_digest
  - ack_quorum_digest
  - ack_quorum_status
  - ack_route_trace_profile_id
  - ack_route_trace_digest_profile
  - ack_authority_route_trace_ref
  - ack_authority_route_trace_digest
  - ack_authority_plane_ref
  - ack_authority_plane_digest
  - ack_route_trace_route_binding_refs
  - ack_route_trace_remote_host_refs
  - ack_route_trace_remote_host_attestation_refs
  - ack_route_trace_remote_jurisdictions
  - ack_route_trace_bindings
  - ack_route_trace_binding_digest_set
  - ack_route_trace_binding_digest_set_digest
  - ack_route_trace_binding_digest
  - ack_route_trace_binding_count
  - ack_route_capture_export_profile_id
  - ack_route_capture_export_digest_profile
  - ack_route_packet_capture_ref
  - ack_route_packet_capture_digest
  - ack_route_packet_capture_profile
  - ack_route_packet_capture_artifact_format
  - ack_route_packet_capture_artifact_digest
  - ack_route_packet_capture_readback_digest
  - ack_route_packet_count
  - ack_route_packet_capture_export_status
  - ack_route_packet_capture_route_binding_refs
  - ack_route_packet_capture_route_binding_set_digest
  - ack_route_os_native_readback_available
  - ack_route_os_native_readback_ok
  - ack_route_privileged_capture_ref
  - ack_route_privileged_capture_digest
  - ack_route_privileged_capture_profile
  - ack_route_privilege_mode
  - ack_route_broker_profile
  - ack_route_broker_attestation_ref
  - ack_route_lease_ref
  - ack_route_interface_name
  - ack_route_local_ips
  - ack_route_capture_filter_digest
  - ack_route_capture_command_digest
  - ack_route_acquisition_route_binding_refs
  - ack_route_acquisition_route_binding_set_digest
  - ack_route_capture_bindings
  - ack_route_capture_binding_digest_set
  - ack_route_capture_binding_digest_set_digest
  - ack_route_capture_binding_digest
  - ack_route_capture_binding_count
  - registry_digest_set
  - registry_digest_set_digest
  - capture_export_bound
  - legal_registry_bound
  - governance_registry_bound
  - registry_entry_bound
  - submission_ack_bound
  - ack_quorum_bound
  - ack_route_trace_bound
  - ack_route_capture_export_bound
  - ack_route_capture_route_binding_set_bound
  - external_registry_sync_complete
  - raw_dissolution_payload_stored
  - raw_registry_payload_stored
  - raw_ack_payload_stored
  - raw_ack_route_payload_stored
  - raw_packet_body_stored
  - digest
properties:
  kind:
    const: collective_external_registry_sync
  schema_version:
    const: "1.0.0"
  profile_id:
    const: collective-dissolution-external-registry-sync-v1
  digest_profile:
    const: collective-external-registry-sync-digest-v1
  registry_entry_digest_profile:
    const: collective-external-registry-entry-digest-v1
  collective_id:
    type: string
    minLength: 8
  recorded_at:
    type: string
    format: date-time
  status:
    const: synced
  source_capture_export_profile_id:
    const: collective-recovery-route-trace-capture-export-v1
  recovery_capture_export_binding_digest:
    $ref: "#/$defs/sha256"
  recovery_route_trace_binding_digest:
    $ref: "#/$defs/sha256"
  recovery_verifier_transport_binding_digest:
    $ref: "#/$defs/sha256"
  dissolution_receipt_digest:
    $ref: "#/$defs/sha256"
  member_recovery_binding_digest:
    $ref: "#/$defs/sha256"
  packet_capture_digest:
    $ref: "#/$defs/sha256"
  privileged_capture_digest:
    $ref: "#/$defs/sha256"
  member_capture_binding_digest_set_digest:
    $ref: "#/$defs/sha256"
  legal_registry_ref:
    type: string
    pattern: "^legal-registry://"
  legal_jurisdiction:
    type: string
    minLength: 2
  legal_registry_digest:
    $ref: "#/$defs/sha256"
  governance_registry_ref:
    type: string
    pattern: "^governance-registry://"
  governance_jurisdiction:
    type: string
    minLength: 2
  governance_registry_digest:
    $ref: "#/$defs/sha256"
  registry_authority_digest:
    $ref: "#/$defs/sha256"
  registry_entry_ref:
    type: string
    pattern: "^registry-entry://collective-dissolution/"
  registry_entry_digest:
    $ref: "#/$defs/sha256"
  submission_profile_id:
    const: collective-external-registry-submission-v1
  submission_receipt_ref:
    type: string
    pattern: "^registry-submission://collective-dissolution/"
  submission_receipt_digest:
    $ref: "#/$defs/sha256"
  ack_profile_id:
    const: collective-external-registry-ack-v1
  ack_receipt_ref:
    type: string
    pattern: "^registry-ack://collective-dissolution/"
  ack_receipt_digest:
    $ref: "#/$defs/sha256"
  ack_quorum_profile_id:
    const: collective-external-registry-ack-quorum-v1
  ack_quorum_digest_profile:
    const: collective-external-registry-ack-quorum-digest-v1
  ack_quorum_required_authority_count:
    const: 2
  ack_quorum_required_jurisdiction_count:
    const: 2
  ack_quorum_authority_refs:
    type: array
    minItems: 2
    maxItems: 2
    items:
      type: string
      pattern: "^(legal-registry|governance-registry)://"
  ack_quorum_jurisdictions:
    type: array
    minItems: 2
    maxItems: 2
    uniqueItems: true
    items:
      type: string
      minLength: 2
  ack_quorum_receipts:
    type: array
    minItems: 2
    maxItems: 2
    items:
      $ref: "#/$defs/ack_quorum_receipt"
  ack_quorum_digest_set:
    type: array
    minItems: 2
    maxItems: 2
    items:
      $ref: "#/$defs/sha256"
  ack_quorum_digest_set_digest:
    $ref: "#/$defs/sha256"
  ack_quorum_digest:
    $ref: "#/$defs/sha256"
  ack_quorum_status:
    const: complete
  ack_route_trace_profile_id:
    const: collective-external-registry-ack-route-trace-v1
  ack_route_trace_digest_profile:
    const: collective-external-registry-ack-route-trace-digest-v1
  ack_authority_route_trace_ref:
    type: string
    pattern: "^authority-route-trace://"
  ack_authority_route_trace_digest:
    $ref: "#/$defs/sha256"
  ack_authority_plane_ref:
    type: string
    pattern: "^authority-plane://"
  ack_authority_plane_digest:
    $ref: "#/$defs/sha256"
  ack_route_trace_route_binding_refs:
    type: array
    minItems: 2
    maxItems: 2
    items:
      type: string
      pattern: "^authority-route://"
  ack_route_trace_remote_host_refs:
    type: array
    minItems: 2
    maxItems: 2
    items:
      type: string
      pattern: "^host://"
  ack_route_trace_remote_host_attestation_refs:
    type: array
    minItems: 2
    maxItems: 2
    items:
      type: string
      pattern: "^host-attestation://"
  ack_route_trace_remote_jurisdictions:
    type: array
    minItems: 2
    maxItems: 2
    items:
      type: string
      minLength: 2
  ack_route_trace_bindings:
    type: array
    minItems: 2
    maxItems: 2
    items:
      $ref: "#/$defs/ack_route_trace_binding"
  ack_route_trace_binding_digest_set:
    type: array
    minItems: 2
    maxItems: 2
    items:
      $ref: "#/$defs/sha256"
  ack_route_trace_binding_digest_set_digest:
    $ref: "#/$defs/sha256"
  ack_route_trace_binding_digest:
    $ref: "#/$defs/sha256"
  ack_route_trace_binding_count:
    const: 2
  ack_route_capture_export_profile_id:
    const: collective-external-registry-ack-route-capture-export-v1
  ack_route_capture_export_digest_profile:
    const: collective-external-registry-ack-route-capture-export-digest-v1
  ack_route_packet_capture_ref:
    type: string
    pattern: "^authority-packet-capture://"
  ack_route_packet_capture_digest:
    $ref: "#/$defs/sha256"
  ack_route_packet_capture_profile:
    const: trace-bound-pcap-export-v1
  ack_route_packet_capture_artifact_format:
    const: pcap
  ack_route_packet_capture_artifact_digest:
    $ref: "#/$defs/sha256"
  ack_route_packet_capture_readback_digest:
    $ref: "#/$defs/sha256"
  ack_route_packet_count:
    const: 4
  ack_route_packet_capture_export_status:
    const: verified
  ack_route_packet_capture_route_binding_refs:
    type: array
    minItems: 2
    maxItems: 2
    items:
      type: string
      pattern: "^authority-route://"
  ack_route_packet_capture_route_binding_set_digest:
    $ref: "#/$defs/sha256"
  ack_route_os_native_readback_available:
    const: true
  ack_route_os_native_readback_ok:
    const: true
  ack_route_privileged_capture_ref:
    type: string
    pattern: "^authority-live-capture://"
  ack_route_privileged_capture_digest:
    $ref: "#/$defs/sha256"
  ack_route_privileged_capture_profile:
    const: bounded-live-interface-capture-acquisition-v1
  ack_route_privilege_mode:
    const: delegated-broker
  ack_route_broker_profile:
    type: string
    minLength: 8
  ack_route_broker_attestation_ref:
    type: string
    minLength: 8
  ack_route_lease_ref:
    type: string
    minLength: 8
  ack_route_interface_name:
    type: string
    minLength: 2
  ack_route_local_ips:
    type: array
    minItems: 1
    items:
      type: string
      minLength: 3
  ack_route_capture_filter_digest:
    $ref: "#/$defs/sha256"
  ack_route_capture_command_digest:
    $ref: "#/$defs/sha256"
  ack_route_acquisition_route_binding_refs:
    type: array
    minItems: 2
    maxItems: 2
    items:
      type: string
      pattern: "^authority-route://"
  ack_route_acquisition_route_binding_set_digest:
    $ref: "#/$defs/sha256"
  ack_route_capture_bindings:
    type: array
    minItems: 2
    maxItems: 2
    items:
      $ref: "#/$defs/ack_route_capture_binding"
  ack_route_capture_binding_digest_set:
    type: array
    minItems: 2
    maxItems: 2
    items:
      $ref: "#/$defs/sha256"
  ack_route_capture_binding_digest_set_digest:
    $ref: "#/$defs/sha256"
  ack_route_capture_binding_digest:
    $ref: "#/$defs/sha256"
  ack_route_capture_binding_count:
    const: 2
  registry_digest_set:
    type: array
    minItems: 8
    maxItems: 8
    items:
      $ref: "#/$defs/sha256"
  registry_digest_set_digest:
    $ref: "#/$defs/sha256"
  capture_export_bound:
    const: true
  legal_registry_bound:
    const: true
  governance_registry_bound:
    const: true
  registry_entry_bound:
    const: true
  submission_ack_bound:
    const: true
  ack_quorum_bound:
    const: true
  ack_route_trace_bound:
    const: true
  ack_route_capture_export_bound:
    const: true
  ack_route_capture_route_binding_set_bound:
    const: true
  external_registry_sync_complete:
    const: true
  raw_dissolution_payload_stored:
    const: false
  raw_registry_payload_stored:
    const: false
  raw_ack_payload_stored:
    const: false
  raw_ack_route_payload_stored:
    const: false
  raw_packet_body_stored:
    const: false
  digest:
    $ref: "#/$defs/sha256"
$defs:
  ack_quorum_receipt:
    type: object
    additionalProperties: false
    required:
      - ack_receipt_ref
      - ack_receipt_digest
      - ack_status
      - registry_authority_ref
      - registry_jurisdiction
      - registry_digest
      - submission_receipt_digest
      - raw_ack_payload_stored
    properties:
      ack_receipt_ref:
        type: string
        pattern: "^registry-ack://collective-dissolution/"
      ack_receipt_digest:
        $ref: "#/$defs/sha256"
      ack_status:
        const: accepted
      registry_authority_ref:
        type: string
        pattern: "^(legal-registry|governance-registry)://"
      registry_jurisdiction:
        type: string
        minLength: 2
      registry_digest:
        $ref: "#/$defs/sha256"
      submission_receipt_digest:
        $ref: "#/$defs/sha256"
      raw_ack_payload_stored:
        const: false
  ack_route_trace_binding:
    type: object
    additionalProperties: false
    required:
      - ack_receipt_ref
      - ack_receipt_digest
      - registry_authority_ref
      - registry_jurisdiction
      - authority_route_trace_ref
      - authority_route_trace_digest
      - route_binding_ref
      - remote_host_ref
      - remote_host_attestation_ref
      - authority_cluster_ref
      - remote_jurisdiction
      - remote_network_zone
      - os_observer_receipt_id
      - os_observer_host_binding_digest
      - socket_response_digest
      - mtls_status
      - ack_route_binding_digest
      - raw_ack_route_payload_stored
    properties:
      ack_receipt_ref:
        type: string
        pattern: "^registry-ack://collective-dissolution/"
      ack_receipt_digest:
        $ref: "#/$defs/sha256"
      registry_authority_ref:
        type: string
        pattern: "^(legal-registry|governance-registry)://"
      registry_jurisdiction:
        type: string
        minLength: 2
      authority_route_trace_ref:
        type: string
        pattern: "^authority-route-trace://"
      authority_route_trace_digest:
        $ref: "#/$defs/sha256"
      route_binding_ref:
        type: string
        pattern: "^authority-route://"
      remote_host_ref:
        type: string
        pattern: "^host://"
      remote_host_attestation_ref:
        type: string
        pattern: "^host-attestation://"
      authority_cluster_ref:
        type: string
        pattern: "^authority-cluster://"
      remote_jurisdiction:
        type: string
        minLength: 2
      remote_network_zone:
        type: string
        minLength: 2
      os_observer_receipt_id:
        type: string
        pattern: "^authority-os-observer://"
      os_observer_host_binding_digest:
        $ref: "#/$defs/sha256"
      socket_response_digest:
        $ref: "#/$defs/sha256"
      mtls_status:
        const: authenticated
      ack_route_binding_digest:
        $ref: "#/$defs/sha256"
      raw_ack_route_payload_stored:
        const: false
  ack_route_capture_binding:
    type: object
    additionalProperties: false
    required:
      - ack_receipt_ref
      - ack_receipt_digest
      - registry_authority_ref
      - registry_jurisdiction
      - ack_route_binding_digest
      - route_binding_ref
      - packet_capture_route_export_digest
      - outbound_tuple_digest
      - inbound_tuple_digest
      - outbound_payload_digest
      - inbound_payload_digest
      - readback_packet_count
      - readback_verified
      - os_native_readback_verified
      - privileged_capture_route_ref
      - ack_route_capture_binding_digest
      - raw_packet_body_stored
    properties:
      ack_receipt_ref:
        type: string
        pattern: "^registry-ack://collective-dissolution/"
      ack_receipt_digest:
        $ref: "#/$defs/sha256"
      registry_authority_ref:
        type: string
        pattern: "^(legal-registry|governance-registry)://"
      registry_jurisdiction:
        type: string
        minLength: 2
      ack_route_binding_digest:
        $ref: "#/$defs/sha256"
      route_binding_ref:
        type: string
        pattern: "^authority-route://"
      packet_capture_route_export_digest:
        $ref: "#/$defs/sha256"
      outbound_tuple_digest:
        $ref: "#/$defs/sha256"
      inbound_tuple_digest:
        $ref: "#/$defs/sha256"
      outbound_payload_digest:
        $ref: "#/$defs/sha256"
      inbound_payload_digest:
        $ref: "#/$defs/sha256"
      readback_packet_count:
        const: 2
      readback_verified:
        const: true
      os_native_readback_verified:
        const: true
      privileged_capture_route_ref:
        type: string
        pattern: "^authority-route://"
      ack_route_capture_binding_digest:
        $ref: "#/$defs/sha256"
      raw_packet_body_stored:
        const: false
  sha256:
    type: string
    pattern: "^[0-9a-f]{64}$"
