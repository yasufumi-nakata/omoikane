  raw_client_certificate_lifecycle_payload_stored:
    const: false
  raw_client_certificate_lifecycle_chain_payload_stored:
    const: false
  raw_packet_body_stored:
    const: false
  digest:
    $ref: "#/$defs/sha256"
$defs:
  ack_quorum_receipt:
    type: object
    additionalProperties: false
    required:
      - ack_receipt_ref
      - ack_receipt_digest
      - ack_status
      - registry_authority_ref
      - registry_jurisdiction
      - registry_digest
      - submission_receipt_digest
