        $ref: "#/$defs/sha256"
      mtls_client_certificate_authority_ref:
        type: string
        pattern: "^registry-client-ca://"
      mtls_client_certificate_proof_digest:
        $ref: "#/$defs/sha256"
      mtls_client_certificate_bound:
