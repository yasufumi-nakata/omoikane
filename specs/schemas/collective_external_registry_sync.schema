      mtls_client_certificate_lifecycle_chain_set_digest:
        $ref: "#/$defs/sha256"
      mtls_client_certificate_lifecycle_chain_status:
        const: complete
      mtls_client_certificate_lifecycle_chain_proof_digest:
        $ref: "#/$defs/sha256"
      mtls_client_certificate_lifecycle_chain_bound:
        const: true
      checked_at:
        type: string
        format: date-time
      raw_ack_payload_stored:
        const: false
      raw_endpoint_payload_stored:
        const: false
      raw_response_signature_payload_stored:
        const: false
      raw_client_certificate_payload_stored:
        const: false
      raw_client_certificate_freshness_payload_stored:
        const: false
      raw_client_certificate_lifecycle_payload_stored:
        const: false
      raw_client_certificate_lifecycle_chain_payload_stored:
