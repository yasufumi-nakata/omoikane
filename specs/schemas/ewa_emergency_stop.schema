$schema: "https://json-schema.org/draft/2020-12/schema"
$id: "https://omoikane.dev/specs/schemas/ewa_emergency_stop.schema"
title: EWAEmergencyStop
description: >
  Latched emergency-stop receipt for one active External World Agent handle,
  binding the last actuation command, optional authorization artifact, safe-state
  interlock, and forced-release requirement.
type: object
additionalProperties: false
required:
  - kind
  - schema_version
  - stop_id
  - policy_id
  - handle_id
  - device_id
  - command_id
  - authorization_id
  - trigger_source
  - reason
  - triggered_at
  - bound_command_digest
  - bound_authorization_digest
  - stop_signal_path_id
  - stop_signal_path_digest
  - stop_signal_bus_profile_id
  - stop_signal_adapter_receipt_id
  - stop_signal_adapter_receipt_digest
  - stop_signal_adapter_profile_id
  - production_connector_attestation_id
  - production_connector_attestation_digest
  - production_connector_profile_id
  - vendor_api_ref
  - installation_site_ref
  - regulator_permit_quorum_receipt_id
  - regulator_permit_quorum_receipt_digest
  - regulator_permit_quorum_profile_id
  - regulator_permit_quorum_status
  - regulator_permit_threshold_policy_digest
  - regulator_permit_verifier_roster_digest
  - regulator_permit_revocation_registry_digest
  - kill_switch_wiring_ref
  - activated_binding_id
  - activated_channel_ref
  - activated_signal_path_ref
  - activated_interlock_ref
  - bus_delivery_status
  - safe_state_ref
  - actuator_state
  - safe_state_status
  - hardware_interlock_state
  - release_required
  - release_window_seconds
  - audit_event_ref
  - stop_digest
properties:
  kind:
    const: ewa_emergency_stop
  schema_version:
    const: "1.0"
  stop_id:
    type: string
    pattern: "^ewa-stop-[a-f0-9]{12}$"
  policy_id:
    type: string
    const: guardian-latched-emergency-stop-v1
  handle_id:
    type: string
    minLength: 8
  device_id:
    type: string
    minLength: 1
  command_id:
    type: string
    minLength: 1
  authorization_id:
    type: string
    pattern: "^$|^ewa-authz-[a-f0-9]{12}$"
  trigger_source:
    type: string
    enum:
      - guardian-manual-stop
      - watchdog-timeout
      - sensor-drift
      - emergency-disconnect
  reason:
    type: string
    minLength: 8
  triggered_at:
    type: string
    format: date-time
  bound_command_digest:
    type: string
    pattern: "^[a-f0-9]{64}$"
  bound_authorization_digest:
    type: string
    pattern: "^$|^[a-f0-9]{64}$"
  stop_signal_path_id:
    type: string
    minLength: 8
  stop_signal_path_digest:
    type: string
    pattern: "^[a-f0-9]{64}$"
  stop_signal_bus_profile_id:
    type: string
    const: bounded-hardware-kill-switch-bus-v1
  stop_signal_adapter_receipt_id:
    type: string
    pattern: "^ewa-stop-adapter-[a-f0-9]{12}$"
  stop_signal_adapter_receipt_digest:
    type: string
    pattern: "^[a-f0-9]{64}$"
  stop_signal_adapter_profile_id:
    type: string
    const: plc-firmware-stop-signal-adapter-v1
  production_connector_attestation_id:
    type: string
    pattern: "^ewa-connector-[a-f0-9]{12}$"
  production_connector_attestation_digest:
    type: string
    pattern: "^[a-f0-9]{64}$"
  production_connector_profile_id:
    type: string
    const: vendor-api-safety-plc-installation-attestation-v1
  vendor_api_ref:
    type: string
    minLength: 1
  installation_site_ref:
    type: string
    minLength: 1
  regulator_permit_quorum_receipt_id:
    type: string
    pattern: "^ewa-permit-quorum-[a-f0-9]{12}$"
  regulator_permit_quorum_receipt_digest:
    type: string
    pattern: "^[a-f0-9]{64}$"
  regulator_permit_quorum_profile_id:
    type: string
    const: ewa-regulator-permit-verifier-quorum-v1
  regulator_permit_quorum_status:
    type: string
    const: complete
  regulator_permit_threshold_policy_digest:
    type: string
    pattern: "^sha256:[a-f0-9]{64}$"
  regulator_permit_verifier_roster_digest:
    type: string
    pattern: "^sha256:[a-f0-9]{64}$"
  regulator_permit_revocation_registry_digest:
    type: string
    pattern: "^sha256:[a-f0-9]{64}$"
  kill_switch_wiring_ref:
    type: string
    minLength: 1
  activated_binding_id:
    type: string
    minLength: 8
  activated_channel_ref:
    type: string
    minLength: 1
  activated_signal_path_ref:
    type: string
    minLength: 1
  activated_interlock_ref:
    type: string
    minLength: 1
  bus_delivery_status:
    type: string
    const: latched
  safe_state_ref:
    type: string
    minLength: 1
  actuator_state:
    type: string
    const: emergency-stopped
  safe_state_status:
    type: string
    const: latched-safe
  hardware_interlock_state:
    type: string
    const: engaged
  release_required:
    const: true
  release_window_seconds:
    type: integer
    const: 30
  audit_event_ref:
    type: string
    minLength: 1
  stop_digest:
    type: string
    pattern: "^[a-f0-9]{64}$"
